<?xml version="1.0" ?>
<!--
    Fragment: Content blocks container with all 11 global block type references.
    Users can create their own blocks.xml with a subset of types.
-->
<properties xmlns="http://schemas.sulu.io/template/template">
    <block name="blocks" default-type="text" minOccurs="0">
        <meta>
            <title>iw_sulu_tailwind_theme.content_blocks</title>
        </meta>
        <types>
            <type ref="text"/>
            <type ref="text_images"/>
            <type ref="gallery"/>
            <type ref="key_figures"/>
            <type ref="linked_pages"/>
            <type ref="location"/>
            <type ref="form"/>
            <type ref="document"/>
            <type ref="cta"/>
            <type ref="testimonial"/>
            <type ref="separator"/>
        </types>
    </block>
</properties>
