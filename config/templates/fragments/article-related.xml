<?xml version="1.0" ?>
<!--
    Fragment: Related articles selection.
    Uses smart_content to automatically fetch related articles,
    with manual override via article_selection when available.
-->
<properties xmlns="http://schemas.sulu.io/template/template">
    <property name="relatedArticles" type="smart_content" colspan="12">
        <meta>
            <title>iw_sulu_tailwind_theme.article.related_articles</title>
            <info_text>iw_sulu_tailwind_theme.article.related_articles_info</info_text>
        </meta>
        <params>
            <param name="provider" value="articles"/>
            <param name="max_per_page" value="3"/>
            <param name="properties" type="collection">
                <param name="title" value="title"/>
            </param>
        </params>
    </property>
</properties>
