<?xml version="1.0" ?>
<!--
    Fragment: Additional article authors.
    The primary author comes from Sulu's native article settings (author field).
    This block allows adding co-authors or additional contributors.
    Supports three types: free text, Sulu contact, or Sulu organization.
-->
<properties xmlns="http://schemas.sulu.io/template/template">
    <block name="additionalAuthors" default-type="custom" minOccurs="0" maxOccurs="5">
        <meta>
            <title>iw_sulu_tailwind_theme.article.additional_authors</title>
            <info_text>iw_sulu_tailwind_theme.article.additional_authors_info</info_text>
        </meta>
        <types>
            <type name="custom">
                <meta><title>iw_sulu_tailwind_theme.article.author_custom</title></meta>
                <properties>
                    <property name="name" type="text_line" mandatory="true" colspan="6">
                        <meta><title>iw_sulu_tailwind_theme.article.author_name</title></meta>
                    </property>
                    <property name="role" type="text_line" colspan="6">
                        <meta><title>iw_sulu_tailwind_theme.article.author_role</title></meta>
                    </property>
                    <property name="avatar" type="media_selection" colspan="12">
                        <meta><title>iw_sulu_tailwind_theme.article.author_avatar</title></meta>
                        <params>
                            <param name="types" value="image"/>
                        </params>
                    </property>
                </properties>
            </type>
            <type name="contact">
                <meta><title>iw_sulu_tailwind_theme.article.author_contact</title></meta>
                <properties>
                    <property name="contact" type="single_contact_selection" mandatory="true" colspan="12">
                        <meta><title>iw_sulu_tailwind_theme.article.author_contact_select</title></meta>
                    </property>
                </properties>
            </type>
            <type name="organization">
                <meta><title>iw_sulu_tailwind_theme.article.author_organization</title></meta>
                <properties>
                    <property name="organization" type="single_account_selection" mandatory="true" colspan="12">
                        <meta><title>iw_sulu_tailwind_theme.article.author_organization_select</title></meta>
                    </property>
                </properties>
            </type>
        </types>
    </block>
</properties>
