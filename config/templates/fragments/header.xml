<?xml version="1.0" ?>
<!--
    Fragment: Page header properties (title + URL).
    Shared across all page templates.
-->
<properties xmlns="http://schemas.sulu.io/template/template">
    <property name="title" type="text_line" mandatory="true">
        <meta><title>iw_sulu_theme.title</title></meta>
        <params>
            <param name="headline" value="true"/>
        </params>
        <tag name="sulu.rlp.part"/>
    </property>

    <property name="url" type="route" mandatory="true">
        <meta><title>iw_sulu_theme.url</title></meta>
        <tag name="sulu.rlp"/>
    </property>
</properties>
