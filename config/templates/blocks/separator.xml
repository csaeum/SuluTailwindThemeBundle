<?xml version="1.0" ?>
<!-- Global block type: Separator -->
<template xmlns="http://schemas.sulu.io/template/template"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/template-1.0.xsd">

    <key>separator</key>
    <meta>
        <title>iw_sulu_tailwind_theme.block.separator</title>
    </meta>

    <properties>
        <!-- ── Content ── -->
        <section name="content">
            <meta><title>iw_sulu_tailwind_theme.content</title></meta>
            <properties>
                <property name="height" type="single_select"
                          visibleCondition="__parent.style == 'spacer'">
                    <meta><title>iw_sulu_tailwind_theme.height</title></meta>
                    <params>
                        <param name="default_value" value="md"/>
                        <param name="values" type="collection">
                            <param name="xs"><meta><title>iw_sulu_tailwind_theme.height_xs</title></meta></param>
                            <param name="sm"><meta><title>iw_sulu_tailwind_theme.height_sm</title></meta></param>
                            <param name="md"><meta><title>iw_sulu_tailwind_theme.height_md</title></meta></param>
                            <param name="lg"><meta><title>iw_sulu_tailwind_theme.height_lg</title></meta></param>
                            <param name="xl"><meta><title>iw_sulu_tailwind_theme.height_xl</title></meta></param>
                        </param>
                    </params>
                </property>
                <property name="lineStyle" type="single_select"
                          visibleCondition="__parent.style == 'line' OR __parent.style == 'divider'">
                    <meta><title>iw_sulu_tailwind_theme.line_style</title></meta>
                    <params>
                        <param name="default_value" value="solid"/>
                        <param name="values" type="collection">
                            <param name="solid"><meta><title>iw_sulu_tailwind_theme.line_solid</title></meta></param>
                            <param name="dashed"><meta><title>iw_sulu_tailwind_theme.line_dashed</title></meta></param>
                            <param name="dotted"><meta><title>iw_sulu_tailwind_theme.line_dotted</title></meta></param>
                        </param>
                    </params>
                </property>
                <property name="lineWidth" type="single_select"
                          visibleCondition="__parent.style == 'line' OR __parent.style == 'divider'">
                    <meta><title>iw_sulu_tailwind_theme.line_width</title></meta>
                    <params>
                        <param name="default_value" value="thin"/>
                        <param name="values" type="collection">
                            <param name="thin"><meta><title>iw_sulu_tailwind_theme.line_thin</title></meta></param>
                            <param name="medium"><meta><title>iw_sulu_tailwind_theme.line_medium</title></meta></param>
                            <param name="thick"><meta><title>iw_sulu_tailwind_theme.line_thick</title></meta></param>
                        </param>
                    </params>
                </property>
                <property name="text" type="text_line"
                          visibleCondition="__parent.style == 'divider'">
                    <meta><title>iw_sulu_tailwind_theme.center_text</title></meta>
                </property>
                <property name="icon" type="single_media_selection"
                          visibleCondition="__parent.style == 'divider'">
                    <meta>
                        <title>iw_sulu_tailwind_theme.center_icon</title>
                        <info_text>iw_sulu_tailwind_theme.center_icon_info</info_text>
                    </meta>
                </property>
                <property name="iconSize" type="single_select"
                          visibleCondition="__parent.style == 'divider'">
                    <meta><title>iw_sulu_tailwind_theme.icon_size</title></meta>
                    <params>
                        <param name="default_value" value="md"/>
                        <param name="values" type="collection">
                            <param name="sm"><meta><title>iw_sulu_tailwind_theme.icon_size_sm</title></meta></param>
                            <param name="md"><meta><title>iw_sulu_tailwind_theme.icon_size_md</title></meta></param>
                            <param name="lg"><meta><title>iw_sulu_tailwind_theme.icon_size_lg</title></meta></param>
                            <param name="xl"><meta><title>iw_sulu_tailwind_theme.icon_size_xl</title></meta></param>
                        </param>
                    </params>
                </property>
            </properties>
        </section>

        <!-- ── Appearance ── -->
        <section name="appearance">
            <meta><title>iw_sulu_tailwind_theme.appearance</title></meta>
            <properties>
                <property name="variant" type="iw_theme_variant_picker" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.color_variant</title></meta>
                </property>
                <property name="style" type="iw_theme_style_picker" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.layout_style</title></meta>
                    <params>
                        <param name="block_type" value="separator"/>
                    </params>
                </property>
            </properties>
        </section>

        <!-- ── Settings ── -->
        <section name="settings">
            <meta><title>iw_sulu_tailwind_theme.settings</title></meta>
            <properties>
                <property name="marginTop" type="iw_theme_margin_selector" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.margin_top</title></meta>
                    <params>
                        <param name="default_value" value="mt-5"/>
                    </params>
                </property>
                <property name="marginBottom" type="iw_theme_margin_selector" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.margin_bottom</title></meta>
                    <params>
                        <param name="default_value" value="mb-5"/>
                    </params>
                </property>
                <property name="lateralMargins" type="single_select">
                    <meta><title>iw_sulu_tailwind_theme.lateral_margins</title></meta>
                    <params>
                        <param name="default_value" value="exterior"/>
                        <param name="values" type="collection">
                            <param name="exterior"><meta><title>iw_sulu_tailwind_theme.lateral_margins_exterior</title></meta></param>
                            <param name="interior"><meta><title>iw_sulu_tailwind_theme.lateral_margins_interior</title></meta></param>
                            <param name="none"><meta><title>iw_sulu_tailwind_theme.lateral_margins_none</title></meta></param>
                        </param>
                    </params>
                </property>
                <property name="paddingTop" type="iw_theme_margin_selector" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.padding_top</title></meta>
                    <params>
                        <param name="default_value" value="pt-5"/>
                    </params>
                </property>
                <property name="paddingBottom" type="iw_theme_margin_selector" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.padding_bottom</title></meta>
                    <params>
                        <param name="default_value" value="pb-5"/>
                    </params>
                </property>
                <property name="paddingLateral" type="iw_theme_margin_selector">
                    <meta><title>iw_sulu_tailwind_theme.padding_lateral</title></meta>
                    <params>
                        <param name="prefix" value="px"/>
                        <param name="default_value" value="px-5"/>
                    </params>
                </property>
            </properties>
        </section>
    </properties>
</template>
