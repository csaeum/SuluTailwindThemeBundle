<?xml version="1.0" ?>
<!-- Global block type: Key figures -->
<template xmlns="http://schemas.sulu.io/template/template"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/template-1.0.xsd">

    <key>key_figures</key>
    <meta>
        <title>iw_sulu_tailwind_theme.block.key_figures</title>
    </meta>

    <properties>
        <!-- ── Content ── -->
        <section name="content">
            <meta><title>iw_sulu_tailwind_theme.content</title></meta>
            <properties>
                <block name="figures" default-type="figure" minOccurs="1">
                    <meta>
                        <title>iw_sulu_tailwind_theme.figures</title>
                    </meta>
                    <types>
                        <type name="figure">
                            <meta>
                                <title>iw_sulu_tailwind_theme.figure</title>
                            </meta>
                            <properties>
                                <property name="image" type="single_media_selection">
                                    <meta><title>iw_sulu_tailwind_theme.image_icon</title></meta>
                                </property>
                                <property name="title" type="text_line">
                                    <meta><title>iw_sulu_tailwind_theme.title</title></meta>
                                </property>
                                <property name="subTitle" type="text_line">
                                    <meta><title>iw_sulu_tailwind_theme.subtitle</title></meta>
                                </property>
                                <property name="number" type="text_line">
                                    <meta><title>iw_sulu_tailwind_theme.number</title></meta>
                                </property>
                            </properties>
                        </type>
                    </types>
                </block>
            </properties>
        </section>

        <!-- ── Appearance ── -->
        <section name="appearance">
            <meta><title>iw_sulu_tailwind_theme.appearance</title></meta>
            <properties>
                <property name="variant" type="iw_theme_variant_picker" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.color_variant</title></meta>
                </property>
                <property name="style" type="iw_theme_style_picker" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.layout_style</title></meta>
                    <params>
                        <param name="block_type" value="key_figures"/>
                    </params>
                </property>
            </properties>
        </section>

        <!-- ── Settings ── -->
        <section name="settings">
            <meta><title>iw_sulu_tailwind_theme.settings</title></meta>
            <properties>
                <property name="marginTop" type="iw_theme_margin_selector" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.margin_top</title></meta>
                    <params>
                        <param name="default_value" value="mt-5"/>
                    </params>
                </property>
                <property name="marginBottom" type="iw_theme_margin_selector" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.margin_bottom</title></meta>
                    <params>
                        <param name="default_value" value="mb-5"/>
                    </params>
                </property>
                <property name="lateralMargins" type="single_select">
                    <meta><title>iw_sulu_tailwind_theme.lateral_margins</title></meta>
                    <params>
                        <param name="default_value" value="exterior"/>
                        <param name="values" type="collection">
                            <param name="exterior"><meta><title>iw_sulu_tailwind_theme.lateral_margins_exterior</title></meta></param>
                            <param name="interior"><meta><title>iw_sulu_tailwind_theme.lateral_margins_interior</title></meta></param>
                            <param name="none"><meta><title>iw_sulu_tailwind_theme.lateral_margins_none</title></meta></param>
                        </param>
                    </params>
                </property>
                <property name="paddingTop" type="iw_theme_margin_selector" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.padding_top</title></meta>
                    <params>
                        <param name="default_value" value="pt-5"/>
                    </params>
                </property>
                <property name="paddingBottom" type="iw_theme_margin_selector" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.padding_bottom</title></meta>
                    <params>
                        <param name="default_value" value="pb-5"/>
                    </params>
                </property>
                <property name="paddingLateral" type="iw_theme_margin_selector">
                    <meta><title>iw_sulu_tailwind_theme.padding_lateral</title></meta>
                    <params>
                        <param name="prefix" value="px"/>
                        <param name="default_value" value="px-5"/>
                    </params>
                </property>
                <property name="blockRadius" type="iw_theme_radius_selector" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.block_radius</title></meta>
                    <params>
                        <param name="default_value" value="rounded-none"/>
                    </params>
                </property>
                <property name="paragraphImageRadius" type="iw_theme_radius_selector" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.paragraph_image_radius</title></meta>
                    <params>
                        <param name="default_value" value="rounded-none"/>
                    </params>
                </property>
                <property name="showBackground" type="checkbox">
                    <meta><title>iw_sulu_tailwind_theme.show_background</title></meta>
                </property>
                <property name="customId" type="text_line" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.custom_id</title></meta>
                </property>
                <property name="customClasses" type="text_line" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.custom_classes</title></meta>
                </property>
            </properties>
        </section>
    </properties>
</template>
