<?xml version="1.0" ?>
<template xmlns="http://schemas.sulu.io/template/template"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/template-1.0.xsd">

    <key>social_media</key>

    <meta>
        <title>iw_sulu_theme.snippet.social_media</title>
    </meta>

    <areas>
        <area key="menu_social_media_links" cache-invalidation="true">
            <meta>
                <title>iw_sulu_theme.snippet.social_media_menu_area</title>
            </meta>
        </area>

        <area key="footer_social_media_links" cache-invalidation="false">
            <meta>
                <title>iw_sulu_theme.snippet.social_media_footer_area</title>
            </meta>
        </area>
    </areas>

    <properties>
        <property name="title" type="text_line" mandatory="true">
            <meta>
                <title>sudcms.title_snippet</title>
            </meta>
            <tag name="sulu.node.name"/>
        </property>

        <block name="blocks_social_medias" minOccurs="1">
            <meta>
                <title>iw_sulu_theme.social_medias</title>
            </meta>

            <types>
                <type name="social_media">
                    <meta>
                        <title>iw_sulu_theme.social_media_item</title>
                    </meta>
                    <properties>
                        <property name="name" type="text_line" mandatory="true">
                            <meta>
                                <title>iw_sulu_theme.social_media_name</title>
                            </meta>
                        </property>

                        <property name="icon" colspan="6" type="single_media_selection">
                            <meta>
                                <title>iw_sulu_theme.icon</title>
                            </meta>
                        </property>

                        <property name="fa_icon" colspan="6" type="text_line">
                            <meta>
                                <title>iw_sulu_theme.fa_icon</title>
                                <info_text>iw_sulu_theme.fa_icon_info</info_text>
                            </meta>
                        </property>

                        <property name="url" type="url" mandatory="true">
                            <meta>
                                <title>iw_sulu_theme.url</title>
                            </meta>
                            <params>
                                <param name="schemes" type="collection">
                                    <param name="https://"/>
                                </param>
                            </params>
                        </property>
                    </properties>
                </type>
            </types>
        </block>
    </properties>
</template>
