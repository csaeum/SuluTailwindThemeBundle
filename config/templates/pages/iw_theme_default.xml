<?xml version="1.0" ?>
<!--
    Default page template for SuluTailwindThemeBundle.
    Uses global block types registered via sulu_admin.templates.block.directories.

    To create a custom page with fewer blocks, copy this file and remove
    unwanted <type ref="..."/> entries from the blocks list.
-->
<template xmlns="http://schemas.sulu.io/template/template"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/template-1.0.xsd">

    <key>iw_theme_default</key>
    <view>@ItechWorldSuluTailwindTheme/pages/default</view>
    <controller>Sulu\Content\UserInterface\Controller\Website\ContentController::indexAction</controller>
    <cacheLifetime>604800</cacheLifetime>

    <meta>
        <title>iw_sulu_tailwind_theme.page.default</title>
    </meta>

    <properties>
        <property name="title" type="text_line" mandatory="true">
            <meta><title>iw_sulu_tailwind_theme.title</title></meta>
            <params>
                <param name="headline" value="true"/>
            </params>
            <tag name="sulu.rlp.part"/>
        </property>

        <property name="url" type="route" mandatory="true">
            <meta><title>iw_sulu_tailwind_theme.url</title></meta>
            <tag name="sulu.rlp"/>
        </property>

        <block name="blocks" default-type="text" minOccurs="0">
            <meta>
                <title>iw_sulu_tailwind_theme.content_blocks</title>
            </meta>
            <types>
                <type ref="text"/>
                <type ref="text_images"/>
                <type ref="gallery"/>
                <type ref="key_figures"/>
                <type ref="linked_pages"/>
                <type ref="location"/>
                <type ref="form"/>
                <type ref="document"/>
                <type ref="cta"/>
                <type ref="testimonial"/>
                <type ref="separator"/>
                <type ref="article_carousel"/>
                <type ref="article_featured"/>
                <type ref="article_list"/>
            </types>
        </block>
    </properties>
</template>
