<?xml version="1.0" encoding="UTF-8"?>
<formats xmlns="http://schemas.sulu.io/media/formats"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:schemaLocation="http://schemas.sulu.io/media/formats http://schemas.sulu.io/media/formats-1.1.xsd">

    <!-- 16:9 widescreen format (hero images, banners) -->
    <format key="iw_theme_16_9">
        <meta>
            <title lang="en">Theme 16:9</title>
            <title lang="fr">Thème 16:9</title>
        </meta>
        <scale x="1920" y="1080" mode="outbound"/>
    </format>

    <!-- 4:3 standard format -->
    <format key="iw_theme_4_3">
        <meta>
            <title lang="en">Theme 4:3</title>
            <title lang="fr">Thème 4:3</title>
        </meta>
        <scale x="1200" y="900" mode="outbound"/>
    </format>

    <!-- 1:1 square format (icons, avatars, thumbnails) -->
    <format key="iw_theme_1_1">
        <meta>
            <title lang="en">Theme 1:1</title>
            <title lang="fr">Thème 1:1</title>
        </meta>
        <scale x="800" y="800" mode="outbound"/>
    </format>

    <!-- 3:4 portrait format -->
    <format key="iw_theme_3_4">
        <meta>
            <title lang="en">Theme 3:4</title>
            <title lang="fr">Thème 3:4</title>
        </meta>
        <scale x="600" y="800" mode="outbound"/>
    </format>

    <!-- Avatar (small square for profile pictures) -->
    <format key="iw_theme_avatar">
        <meta>
            <title lang="en">Theme Avatar</title>
            <title lang="fr">Thème Avatar</title>
        </meta>
        <scale x="200" y="200" mode="outbound"/>
    </format>

    <!-- Gallery thumbnail -->
    <format key="iw_theme_gallery_thumb">
        <meta>
            <title lang="en">Theme Gallery Thumbnail</title>
            <title lang="fr">Thème Miniature Galerie</title>
        </meta>
        <scale x="400" y="300" mode="outbound"/>
    </format>

    <!-- Logo desktop (max 400x80, keeps aspect ratio) -->
    <format key="iw_theme_logo_desktop">
        <meta>
            <title lang="en">Theme Logo Desktop</title>
            <title lang="fr">Thème Logo Desktop</title>
        </meta>
        <scale x="400" y="80" mode="inset"/>
    </format>

    <!-- Logo mobile (max 200x64, keeps aspect ratio) -->
    <format key="iw_theme_logo_mobile">
        <meta>
            <title lang="en">Theme Logo Mobile</title>
            <title lang="fr">Thème Logo Mobile</title>
        </meta>
        <scale x="200" y="64" mode="inset"/>
    </format>

    <!-- Mega menu image card (16:10 ratio, 400x250) -->
    <format key="iw_theme_mega_card">
        <meta>
            <title lang="en">Theme Mega Menu Card</title>
            <title lang="fr">Thème Mega Menu Carte</title>
        </meta>
        <scale x="400" y="250" mode="outbound"/>
    </format>

    <!-- Hero banner format (ultra-wide) -->
    <format key="iw_theme_hero">
        <meta>
            <title lang="en">Theme Hero Banner</title>
            <title lang="fr">Thème Bannière Hero</title>
        </meta>
        <scale x="1920" y="800" mode="outbound"/>
    </format>

</formats>
