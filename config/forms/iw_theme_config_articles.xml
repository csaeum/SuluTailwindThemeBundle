<?xml version="1.0" ?>
<!--
    Admin form: Articles tab.
    Style pickers for article page layouts, listing config, and display toggles.
-->
<form xmlns="http://schemas.sulu.io/template/template"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/form-1.0.xsd"
>
    <key>iw_theme_config_articles</key>

    <properties>
        <!-- Page styles section -->
        <section name="articlePageStyles">
            <meta>
                <title>iw_sulu_tailwind_theme.articles_section_page_styles</title>
            </meta>
            <properties>
                <property name="articles_newsStyle" type="iw_theme_article_style_picker" colspan="12">
                    <meta><title>iw_sulu_tailwind_theme.articles_news_style</title></meta>
                    <params>
                        <param name="article_type" value="news"/>
                    </params>
                </property>

                <property name="articles_eventStyle" type="iw_theme_article_style_picker" colspan="12">
                    <meta><title>iw_sulu_tailwind_theme.articles_event_style</title></meta>
                    <params>
                        <param name="article_type" value="event"/>
                    </params>
                </property>

                <property name="articles_blogStyle" type="iw_theme_article_style_picker" colspan="12">
                    <meta><title>iw_sulu_tailwind_theme.articles_blog_style</title></meta>
                    <params>
                        <param name="article_type" value="blog"/>
                    </params>
                </property>
            </properties>
        </section>

        <!-- Listing section -->
        <section name="articleListing">
            <meta>
                <title>iw_sulu_tailwind_theme.articles_section_listing</title>
            </meta>
            <properties>
                <property name="articles_listingStyle" type="iw_theme_article_style_picker" colspan="12">
                    <meta><title>iw_sulu_tailwind_theme.articles_listing_style</title></meta>
                    <params>
                        <param name="article_type" value="listing"/>
                    </params>
                </property>

                <property name="articles_cardImageRatio" type="single_select" colspan="4">
                    <meta><title>iw_sulu_tailwind_theme.articles_card_image_ratio</title></meta>
                    <params>
                        <param name="default_value" value="16:9"/>
                        <param name="values" type="collection">
                            <param name="16:9"><meta><title>16:9</title></meta></param>
                            <param name="4:3"><meta><title>4:3</title></meta></param>
                            <param name="1:1"><meta><title>1:1</title></meta></param>
                            <param name="3:4"><meta><title>3:4 (portrait)</title></meta></param>
                        </param>
                    </params>
                </property>
            </properties>
        </section>

        <!-- Card appearance section -->
        <section name="articleCardAppearance">
            <meta>
                <title>iw_sulu_tailwind_theme.articles_section_card_appearance</title>
            </meta>
            <properties>
                <!-- Surface -->
                <property name="articles_cardSurface" type="iw_theme_color_token_editor" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.articles_card_surface</title></meta>
                    <params>
                        <param name="show_palette" value="true"/>
                    </params>
                </property>

                <property name="articles_cardPadding" type="single_select" colspan="3">
                    <meta><title>iw_sulu_tailwind_theme.articles_card_padding</title></meta>
                    <params>
                        <param name="default_value" value="1rem"/>
                        <param name="values" type="collection">
                            <param name="0"><meta><title>iw_sulu_tailwind_theme.articles_card_padding_none</title></meta></param>
                            <param name="0.5rem"><meta><title>XS (p-2)</title></meta></param>
                            <param name="1rem"><meta><title>S (p-4)</title></meta></param>
                            <param name="1.5rem"><meta><title>M (p-6)</title></meta></param>
                            <param name="2rem"><meta><title>L (p-8)</title></meta></param>
                        </param>
                    </params>
                </property>

                <property name="articles_cardImagePadded" type="checkbox" colspan="3">
                    <params>
                        <param name="type" value="toggler"/>
                        <param name="default_value" value="true"/>
                        <param name="label">
                            <meta>
                                <title>iw_sulu_tailwind_theme.articles_card_image_padded</title>
                            </meta>
                        </param>
                    </params>
                </property>

                <!-- Border -->
                <property name="articles_cardBorder" type="iw_theme_color_token_editor" colspan="4">
                    <meta><title>iw_sulu_tailwind_theme.articles_card_border</title></meta>
                    <params>
                        <param name="show_palette" value="true"/>
                    </params>
                </property>

                <property name="articles_cardBorderWidth" type="single_select" colspan="4"
                          visibleCondition="articles_cardBorder != 'none'">
                    <meta><title>iw_sulu_tailwind_theme.articles_card_border_width</title></meta>
                    <params>
                        <param name="default_value" value="1px"/>
                        <param name="values" type="collection">
                            <param name="1px"><meta><title>1px</title></meta></param>
                            <param name="2px"><meta><title>2px</title></meta></param>
                            <param name="3px"><meta><title>3px</title></meta></param>
                            <param name="4px"><meta><title>4px</title></meta></param>
                        </param>
                    </params>
                </property>

                <property name="articles_cardBorderStyle" type="single_select" colspan="4"
                          visibleCondition="articles_cardBorder != 'none'">
                    <meta><title>iw_sulu_tailwind_theme.articles_card_border_style</title></meta>
                    <params>
                        <param name="default_value" value="solid"/>
                        <param name="values" type="collection">
                            <param name="solid"><meta><title>Solid</title></meta></param>
                            <param name="dashed"><meta><title>Dashed</title></meta></param>
                            <param name="dotted"><meta><title>Dotted</title></meta></param>
                            <param name="double"><meta><title>Double</title></meta></param>
                        </param>
                    </params>
                </property>

                <!-- Hover effects -->
                <property name="articles_cardHoverTransform" type="single_select" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.articles_card_hover_transform</title></meta>
                    <params>
                        <param name="default_value" value="none"/>
                        <param name="values" type="collection">
                            <param name="none"><meta><title>iw_sulu_tailwind_theme.articles_card_hover_transform_none</title></meta></param>
                            <param name="lift"><meta><title>iw_sulu_tailwind_theme.articles_card_hover_transform_lift</title></meta></param>
                            <param name="lift-strong"><meta><title>iw_sulu_tailwind_theme.articles_card_hover_transform_lift_strong</title></meta></param>
                            <param name="scale-up"><meta><title>iw_sulu_tailwind_theme.articles_card_hover_transform_scale_up</title></meta></param>
                            <param name="scale-down"><meta><title>iw_sulu_tailwind_theme.articles_card_hover_transform_scale_down</title></meta></param>
                            <param name="tilt"><meta><title>iw_sulu_tailwind_theme.articles_card_hover_transform_tilt</title></meta></param>
                        </param>
                    </params>
                </property>

                <property name="articles_cardHoverImage" type="single_select" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.articles_card_hover_image</title></meta>
                    <params>
                        <param name="default_value" value="zoom"/>
                        <param name="values" type="collection">
                            <param name="none"><meta><title>iw_sulu_tailwind_theme.articles_card_hover_image_none</title></meta></param>
                            <param name="zoom"><meta><title>iw_sulu_tailwind_theme.articles_card_hover_image_zoom</title></meta></param>
                            <param name="zoom-strong"><meta><title>iw_sulu_tailwind_theme.articles_card_hover_image_zoom_strong</title></meta></param>
                            <param name="grayscale"><meta><title>iw_sulu_tailwind_theme.articles_card_hover_image_grayscale</title></meta></param>
                            <param name="brightness"><meta><title>iw_sulu_tailwind_theme.articles_card_hover_image_brightness</title></meta></param>
                        </param>
                    </params>
                </property>

                <property name="articles_cardHoverShadow" type="single_select" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.articles_card_hover_shadow</title></meta>
                    <params>
                        <param name="default_value" value="none"/>
                        <param name="values" type="collection">
                            <param name="none"><meta><title>iw_sulu_tailwind_theme.articles_card_hover_shadow_none</title></meta></param>
                            <param name="sm"><meta><title>iw_sulu_tailwind_theme.articles_card_hover_shadow_sm</title></meta></param>
                            <param name="md"><meta><title>iw_sulu_tailwind_theme.articles_card_hover_shadow_md</title></meta></param>
                            <param name="lg"><meta><title>iw_sulu_tailwind_theme.articles_card_hover_shadow_lg</title></meta></param>
                            <param name="xl"><meta><title>iw_sulu_tailwind_theme.articles_card_hover_shadow_xl</title></meta></param>
                            <param name="glow-primary"><meta><title>iw_sulu_tailwind_theme.articles_card_hover_shadow_glow_primary</title></meta></param>
                            <param name="glow-accent"><meta><title>iw_sulu_tailwind_theme.articles_card_hover_shadow_glow_accent</title></meta></param>
                        </param>
                    </params>
                </property>

                <property name="articles_cardHoverBorder" type="iw_theme_color_token_editor" colspan="6"
                          visibleCondition="articles_cardBorder != 'none'">
                    <meta><title>iw_sulu_tailwind_theme.articles_card_hover_border</title></meta>
                    <params>
                        <param name="show_palette" value="true"/>
                    </params>
                </property>

                <property name="articles_cardHoverDuration" type="single_select" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.articles_card_hover_duration</title></meta>
                    <params>
                        <param name="default_value" value="300ms"/>
                        <param name="values" type="collection">
                            <param name="150ms"><meta><title>150ms</title></meta></param>
                            <param name="300ms"><meta><title>300ms</title></meta></param>
                            <param name="500ms"><meta><title>500ms</title></meta></param>
                            <param name="700ms"><meta><title>700ms</title></meta></param>
                        </param>
                    </params>
                </property>

                <property name="articles_cardHoverEasing" type="single_select" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.articles_card_hover_easing</title></meta>
                    <params>
                        <param name="default_value" value="ease-out"/>
                        <param name="values" type="collection">
                            <param name="linear"><meta><title>iw_sulu_tailwind_theme.articles_card_hover_easing_linear</title></meta></param>
                            <param name="ease-out"><meta><title>iw_sulu_tailwind_theme.articles_card_hover_easing_ease_out</title></meta></param>
                            <param name="ease-in-out"><meta><title>iw_sulu_tailwind_theme.articles_card_hover_easing_ease_in_out</title></meta></param>
                            <param name="bounce"><meta><title>iw_sulu_tailwind_theme.articles_card_hover_easing_bounce</title></meta></param>
                        </param>
                    </params>
                </property>
            </properties>
        </section>

        <!-- Display elements section -->
        <section name="articleDisplay">
            <meta>
                <title>iw_sulu_tailwind_theme.articles_section_display</title>
            </meta>
            <properties>
                <property name="articles_showDates" type="single_select" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.articles_show_dates</title></meta>
                    <params>
                        <param name="default_value" value="both"/>
                        <param name="values" type="collection">
                            <param name="hidden"><meta><title>iw_sulu_tailwind_theme.articles_visibility_hidden</title></meta></param>
                            <param name="page"><meta><title>iw_sulu_tailwind_theme.articles_visibility_page</title></meta></param>
                            <param name="listing"><meta><title>iw_sulu_tailwind_theme.articles_visibility_listing</title></meta></param>
                            <param name="both"><meta><title>iw_sulu_tailwind_theme.articles_visibility_both</title></meta></param>
                        </param>
                    </params>
                </property>

                <property name="articles_showAuthors" type="single_select" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.articles_show_authors</title></meta>
                    <params>
                        <param name="default_value" value="both"/>
                        <param name="values" type="collection">
                            <param name="hidden"><meta><title>iw_sulu_tailwind_theme.articles_visibility_hidden</title></meta></param>
                            <param name="page"><meta><title>iw_sulu_tailwind_theme.articles_visibility_page</title></meta></param>
                            <param name="listing"><meta><title>iw_sulu_tailwind_theme.articles_visibility_listing</title></meta></param>
                            <param name="both"><meta><title>iw_sulu_tailwind_theme.articles_visibility_both</title></meta></param>
                        </param>
                    </params>
                </property>

                <property name="articles_showCategories" type="single_select" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.articles_show_categories</title></meta>
                    <params>
                        <param name="default_value" value="both"/>
                        <param name="values" type="collection">
                            <param name="hidden"><meta><title>iw_sulu_tailwind_theme.articles_visibility_hidden</title></meta></param>
                            <param name="page"><meta><title>iw_sulu_tailwind_theme.articles_visibility_page</title></meta></param>
                            <param name="listing"><meta><title>iw_sulu_tailwind_theme.articles_visibility_listing</title></meta></param>
                            <param name="both"><meta><title>iw_sulu_tailwind_theme.articles_visibility_both</title></meta></param>
                        </param>
                    </params>
                </property>

                <property name="articles_showExcerpts" type="single_select" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.articles_show_excerpts</title></meta>
                    <params>
                        <param name="default_value" value="listing"/>
                        <param name="values" type="collection">
                            <param name="hidden"><meta><title>iw_sulu_tailwind_theme.articles_visibility_hidden</title></meta></param>
                            <param name="listing"><meta><title>iw_sulu_tailwind_theme.articles_visibility_listing</title></meta></param>
                            <param name="both"><meta><title>iw_sulu_tailwind_theme.articles_visibility_both</title></meta></param>
                        </param>
                    </params>
                </property>

                <property name="articles_showBreadcrumbs" type="single_select" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.articles_show_breadcrumbs</title></meta>
                    <params>
                        <param name="default_value" value="page"/>
                        <param name="values" type="collection">
                            <param name="hidden"><meta><title>iw_sulu_tailwind_theme.articles_visibility_hidden</title></meta></param>
                            <param name="page"><meta><title>iw_sulu_tailwind_theme.articles_visibility_page</title></meta></param>
                        </param>
                    </params>
                </property>

                <property name="articles_showRelated" type="single_select" colspan="6">
                    <meta><title>iw_sulu_tailwind_theme.articles_show_related</title></meta>
                    <params>
                        <param name="default_value" value="page"/>
                        <param name="values" type="collection">
                            <param name="hidden"><meta><title>iw_sulu_tailwind_theme.articles_visibility_hidden</title></meta></param>
                            <param name="page"><meta><title>iw_sulu_tailwind_theme.articles_visibility_page</title></meta></param>
                        </param>
                    </params>
                </property>

                <property name="articles_relatedCount" type="number" colspan="4"
                          visibleCondition="articles_showRelated != 'hidden'">
                    <meta><title>iw_sulu_tailwind_theme.articles_related_count</title></meta>
                    <params>
                        <param name="default_value" value="3"/>
                    </params>
                </property>
            </properties>
        </section>
    </properties>
</form>
