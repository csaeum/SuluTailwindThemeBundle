<?xml version="1.0" ?>
<form xmlns="http://schemas.sulu.io/template/template"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/form-1.0.xsd"
>
    <key>iw_theme_config_variants</key>

    <properties>
        <block name="blockVariants" default-type="variant" minOccurs="0">
            <meta>
                <title>iw_sulu_theme.variants</title>
                <info_text>iw_sulu_theme.variants_info</info_text>
            </meta>
            <types>
                <type name="variant">
                    <meta>
                        <title>iw_sulu_theme.variant</title>
                    </meta>
                    <properties>
                        <property name="key" type="text_line" visibleCondition="false">
                            <meta>
                                <title>iw_sulu_theme.variant_key</title>
                                <info_text>iw_sulu_theme.variant_key_auto_info</info_text>
                            </meta>
                        </property>

                        <property name="label" type="text_line" colspan="12" mandatory="true">
                            <meta>
                                <title>iw_sulu_theme.variant_label</title>
                            </meta>
                        </property>

                        <property name="title" type="iw_theme_color_token_editor" colspan="4">
                            <meta>
                                <title>iw_sulu_theme.variant_title_color</title>
                            </meta>
                        </property>

                        <property name="subtitle" type="iw_theme_color_token_editor" colspan="4">
                            <meta>
                                <title>iw_sulu_theme.variant_subtitle_color</title>
                            </meta>
                        </property>

                        <property name="paragraph" type="iw_theme_color_token_editor" colspan="4">
                            <meta>
                                <title>iw_sulu_theme.variant_paragraph_color</title>
                            </meta>
                        </property>

                        <property name="link" type="iw_theme_color_token_editor" colspan="4">
                            <meta>
                                <title>iw_sulu_theme.variant_link_color</title>
                            </meta>
                        </property>

                        <property name="linkHover" type="iw_theme_color_token_editor" colspan="4">
                            <meta>
                                <title>iw_sulu_theme.variant_link_hover_color</title>
                            </meta>
                        </property>

                        <property name="list" type="iw_theme_color_token_editor" colspan="4">
                            <meta>
                                <title>iw_sulu_theme.variant_list_color</title>
                            </meta>
                        </property>

                        <property name="hr" type="iw_theme_color_token_editor" colspan="4">
                            <meta>
                                <title>iw_sulu_theme.variant_hr_color</title>
                            </meta>
                        </property>

                        <property name="paragraphBg" type="iw_theme_color_token_editor" colspan="4">
                            <meta>
                                <title>iw_sulu_theme.variant_paragraphBg</title>
                            </meta>
                        </property>

                        <property name="blockBg" type="iw_theme_color_token_editor" colspan="4">
                            <meta>
                                <title>iw_sulu_theme.variant_blockBg</title>
                            </meta>
                        </property>

                        <property name="separatorMode" type="single_select" colspan="4">
                            <meta>
                                <title>iw_sulu_theme.variant_separator_mode</title>
                            </meta>
                            <params>
                                <param name="default_value" type="string" value="style"/>
                                <param name="values" type="collection">
                                    <param name="style">
                                        <meta><title>iw_sulu_theme.variant_separator_mode_style</title></meta>
                                    </param>
                                    <param name="image">
                                        <meta><title>iw_sulu_theme.variant_separator_mode_image</title></meta>
                                    </param>
                                    <param name="none">
                                        <meta><title>iw_sulu_theme.variant_separator_mode_none</title></meta>
                                    </param>
                                </param>
                            </params>
                        </property>

                        <property name="separatorStyle" type="single_select" colspan="4"
                                  visibleCondition="__parent.separatorMode == 'style' OR __parent.separatorMode == null">
                            <meta>
                                <title>iw_sulu_theme.variant_separator_style</title>
                            </meta>
                            <params>
                                <param name="default_value" type="string" value="solid"/>
                                <param name="values" type="collection">
                                    <param name="solid"><meta><title>iw_sulu_theme.separator_solid</title></meta></param>
                                    <param name="dashed"><meta><title>iw_sulu_theme.separator_dashed</title></meta></param>
                                    <param name="dotted"><meta><title>iw_sulu_theme.separator_dotted</title></meta></param>
                                    <param name="double"><meta><title>iw_sulu_theme.separator_double</title></meta></param>
                                    <param name="gradient"><meta><title>iw_sulu_theme.separator_gradient</title></meta></param>
                                    <param name="wave"><meta><title>iw_sulu_theme.separator_wave</title></meta></param>
                                    <param name="zigzag"><meta><title>iw_sulu_theme.separator_zigzag</title></meta></param>
                                    <param name="dots"><meta><title>iw_sulu_theme.separator_dots</title></meta></param>
                                    <param name="diamond"><meta><title>iw_sulu_theme.separator_diamond</title></meta></param>
                                </param>
                            </params>
                        </property>

                        <property name="separatorImage" type="single_media_selection" colspan="4"
                                  visibleCondition="__parent.separatorMode == 'image'">
                            <meta>
                                <title>iw_sulu_theme.variant_separator_image</title>
                            </meta>
                        </property>
                    </properties>
                </type>
            </types>
        </block>
    </properties>
</form>
