<?xml version="1.0" ?>
<form xmlns="http://schemas.sulu.io/template/template"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/form-1.0.xsd"
>
    <key>iw_theme_config_variants</key>

    <properties>
        <block name="blockVariants" default-type="variant" minOccurs="0">
            <meta>
                <title>iw_sulu_tailwind_theme.variants</title>
                <info_text>iw_sulu_tailwind_theme.variants_info</info_text>
            </meta>
            <types>
                <type name="variant">
                    <meta>
                        <title>iw_sulu_tailwind_theme.variant</title>
                    </meta>
                    <properties>
                        <property name="label" type="text_line" mandatory="true">
                            <meta>
                                <title>iw_sulu_tailwind_theme.variant_label</title>
                            </meta>
                        </property>

                        <property name="title" type="iw_theme_color_token_editor" colspan="4">
                            <meta>
                                <title>iw_sulu_tailwind_theme.variant_title_color</title>
                            </meta>
                            <params>
                                <param name="show_palette" value="true"/>
                            </params>
                        </property>

                        <property name="subtitle" type="iw_theme_color_token_editor" colspan="4">
                            <meta>
                                <title>iw_sulu_tailwind_theme.variant_subtitle_color</title>
                            </meta>
                            <params>
                                <param name="show_palette" value="true"/>
                            </params>
                        </property>

                        <property name="paragraph" type="iw_theme_color_token_editor" colspan="4">
                            <meta>
                                <title>iw_sulu_tailwind_theme.variant_paragraph_color</title>
                            </meta>
                            <params>
                                <param name="show_palette" value="true"/>
                            </params>
                        </property>

                        <property name="link" type="iw_theme_color_token_editor" colspan="4">
                            <meta>
                                <title>iw_sulu_tailwind_theme.variant_link_color</title>
                            </meta>
                            <params>
                                <param name="show_palette" value="true"/>
                            </params>
                        </property>

                        <property name="linkHover" type="iw_theme_color_token_editor" colspan="4">
                            <meta>
                                <title>iw_sulu_tailwind_theme.variant_link_hover_color</title>
                            </meta>
                            <params>
                                <param name="show_palette" value="true"/>
                            </params>
                        </property>

                        <property name="list" type="iw_theme_color_token_editor" colspan="4">
                            <meta>
                                <title>iw_sulu_tailwind_theme.variant_list_color</title>
                            </meta>
                            <params>
                                <param name="show_palette" value="true"/>
                            </params>
                        </property>

                        <property name="hr" type="iw_theme_color_token_editor" colspan="4">
                            <meta>
                                <title>iw_sulu_tailwind_theme.variant_hr_color</title>
                            </meta>
                            <params>
                                <param name="show_palette" value="true"/>
                            </params>
                        </property>

                        <property name="paragraphBg" type="iw_theme_color_token_editor" colspan="4">
                            <meta>
                                <title>iw_sulu_tailwind_theme.variant_paragraphBg</title>
                            </meta>
                            <params>
                                <param name="show_palette" value="true"/>
                            </params>
                        </property>

                        <property name="blockBg" type="iw_theme_color_token_editor" colspan="4">
                            <meta>
                                <title>iw_sulu_tailwind_theme.variant_blockBg</title>
                            </meta>
                            <params>
                                <param name="show_palette" value="true"/>
                            </params>
                        </property>

                        <property name="buttonStyle" type="iw_theme_button_style_picker">
                            <meta>
                                <title>iw_sulu_tailwind_theme.variant_button_style</title>
                            </meta>
                        </property>

                        <property name="formBg" type="iw_theme_color_token_editor" colspan="4">
                            <meta>
                                <title>iw_sulu_tailwind_theme.variant_form_bg</title>
                            </meta>
                            <params>
                                <param name="show_palette" value="true"/>
                            </params>
                        </property>

                        <property name="formText" type="iw_theme_color_token_editor" colspan="4">
                            <meta>
                                <title>iw_sulu_tailwind_theme.variant_form_text</title>
                            </meta>
                            <params>
                                <param name="show_palette" value="true"/>
                            </params>
                        </property>

                        <property name="formLabel" type="iw_theme_color_token_editor" colspan="4">
                            <meta>
                                <title>iw_sulu_tailwind_theme.variant_form_label</title>
                            </meta>
                            <params>
                                <param name="show_palette" value="true"/>
                            </params>
                        </property>

                        <property name="formPlaceholder" type="iw_theme_color_token_editor" colspan="4">
                            <meta>
                                <title>iw_sulu_tailwind_theme.variant_form_placeholder</title>
                            </meta>
                            <params>
                                <param name="show_palette" value="true"/>
                            </params>
                        </property>

                        <property name="formBorder" type="iw_theme_color_token_editor" colspan="4">
                            <meta>
                                <title>iw_sulu_tailwind_theme.variant_form_border</title>
                            </meta>
                            <params>
                                <param name="show_palette" value="true"/>
                            </params>
                        </property>

                        <property name="formBorderFocus" type="iw_theme_color_token_editor" colspan="4">
                            <meta>
                                <title>iw_sulu_tailwind_theme.variant_form_border_focus</title>
                            </meta>
                            <params>
                                <param name="show_palette" value="true"/>
                            </params>
                        </property>

                        <property name="formBorderError" type="iw_theme_color_token_editor" colspan="4">
                            <meta>
                                <title>iw_sulu_tailwind_theme.variant_form_border_error</title>
                            </meta>
                            <params>
                                <param name="show_palette" value="true"/>
                            </params>
                        </property>

                        <property name="separatorMode" type="single_select" colspan="4">
                            <meta>
                                <title>iw_sulu_tailwind_theme.variant_separator_mode</title>
                            </meta>
                            <params>
                                <param name="default_value" value="style"/>
                                <param name="values" type="collection">
                                    <param name="style">
                                        <meta><title>iw_sulu_tailwind_theme.variant_separator_mode_style</title></meta>
                                    </param>
                                    <param name="image">
                                        <meta><title>iw_sulu_tailwind_theme.variant_separator_mode_image</title></meta>
                                    </param>
                                    <param name="none">
                                        <meta><title>iw_sulu_tailwind_theme.variant_separator_mode_none</title></meta>
                                    </param>
                                </param>
                            </params>
                        </property>

                        <property name="separatorStyle" type="single_select" colspan="4"
                                  visibleCondition="__parent.separatorMode == 'style' OR __parent.separatorMode == null">
                            <meta>
                                <title>iw_sulu_tailwind_theme.variant_separator_style</title>
                            </meta>
                            <params>
                                <param name="default_value" value="solid"/>
                                <param name="values" type="collection">
                                    <param name="solid"><meta><title>iw_sulu_tailwind_theme.separator_solid</title></meta></param>
                                    <param name="dashed"><meta><title>iw_sulu_tailwind_theme.separator_dashed</title></meta></param>
                                    <param name="dotted"><meta><title>iw_sulu_tailwind_theme.separator_dotted</title></meta></param>
                                    <param name="double"><meta><title>iw_sulu_tailwind_theme.separator_double</title></meta></param>
                                    <param name="gradient"><meta><title>iw_sulu_tailwind_theme.separator_gradient</title></meta></param>
                                    <param name="wave"><meta><title>iw_sulu_tailwind_theme.separator_wave</title></meta></param>
                                    <param name="zigzag"><meta><title>iw_sulu_tailwind_theme.separator_zigzag</title></meta></param>
                                    <param name="dots"><meta><title>iw_sulu_tailwind_theme.separator_dots</title></meta></param>
                                    <param name="diamond"><meta><title>iw_sulu_tailwind_theme.separator_diamond</title></meta></param>
                                </param>
                            </params>
                        </property>

                        <property name="separatorImage" type="single_media_selection" colspan="4"
                                  visibleCondition="__parent.separatorMode == 'image'">
                            <meta>
                                <title>iw_sulu_tailwind_theme.variant_separator_image</title>
                            </meta>
                        </property>
                    </properties>
                </type>
            </types>
        </block>
    </properties>
</form>
