<?xml version="1.0" ?>
<form xmlns="http://schemas.sulu.io/template/template"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/form-1.0.xsd"
>
    <key>iw_theme_config_buttons</key>

    <properties>
        <!-- Primary Button -->
        <section name="primaryButton">
            <meta>
                <title>iw_sulu_theme.buttons_primary</title>
            </meta>
            <properties>
                <property name="buttons_primary_bg" type="iw_theme_color_token_editor" colspan="4">
                    <meta>
                        <title>iw_sulu_theme.buttons_bg</title>
                    </meta>
                </property>
                <property name="buttons_primary_text" type="iw_theme_color_token_editor" colspan="4">
                    <meta>
                        <title>iw_sulu_theme.buttons_text</title>
                    </meta>
                </property>
                <property name="buttons_primary_border" type="iw_theme_color_token_editor" colspan="4">
                    <meta>
                        <title>iw_sulu_theme.buttons_border</title>
                    </meta>
                </property>
                <property name="buttons_primary_hoverBg" type="iw_theme_color_token_editor" colspan="4">
                    <meta>
                        <title>iw_sulu_theme.buttons_hoverBg</title>
                    </meta>
                </property>
                <property name="buttons_primary_hoverText" type="iw_theme_color_token_editor" colspan="4">
                    <meta>
                        <title>iw_sulu_theme.buttons_hoverText</title>
                    </meta>
                </property>
                <property name="buttons_primary_hoverBorder" type="iw_theme_color_token_editor" colspan="4">
                    <meta>
                        <title>iw_sulu_theme.buttons_hoverBorder</title>
                    </meta>
                </property>
                <property name="buttons_primary_radius" type="iw_theme_radius_selector" colspan="12">
                    <meta>
                        <title>iw_sulu_theme.buttons_radius</title>
                    </meta>
                </property>
            </properties>
        </section>

        <!-- Secondary Button -->
        <section name="secondaryButton">
            <meta>
                <title>iw_sulu_theme.buttons_secondary</title>
            </meta>
            <properties>
                <property name="buttons_secondary_bg" type="iw_theme_color_token_editor" colspan="4">
                    <meta>
                        <title>iw_sulu_theme.buttons_bg</title>
                    </meta>
                </property>
                <property name="buttons_secondary_text" type="iw_theme_color_token_editor" colspan="4">
                    <meta>
                        <title>iw_sulu_theme.buttons_text</title>
                    </meta>
                </property>
                <property name="buttons_secondary_border" type="iw_theme_color_token_editor" colspan="4">
                    <meta>
                        <title>iw_sulu_theme.buttons_border</title>
                    </meta>
                </property>
                <property name="buttons_secondary_hoverBg" type="iw_theme_color_token_editor" colspan="4">
                    <meta>
                        <title>iw_sulu_theme.buttons_hoverBg</title>
                    </meta>
                </property>
                <property name="buttons_secondary_hoverText" type="iw_theme_color_token_editor" colspan="4">
                    <meta>
                        <title>iw_sulu_theme.buttons_hoverText</title>
                    </meta>
                </property>
                <property name="buttons_secondary_hoverBorder" type="iw_theme_color_token_editor" colspan="4">
                    <meta>
                        <title>iw_sulu_theme.buttons_hoverBorder</title>
                    </meta>
                </property>
                <property name="buttons_secondary_radius" type="iw_theme_radius_selector" colspan="12">
                    <meta>
                        <title>iw_sulu_theme.buttons_radius</title>
                    </meta>
                </property>
            </properties>
        </section>
    </properties>
</form>
