{
    "name": "itech-world/sulu-tailwind-theme-bundle",
    "description": "Complete theming system for Sulu CMS 3.x based on design tokens compiled to CSS custom properties",
    "type": "sulu-bundle",
    "license": "MIT",
    "keywords": ["sulu", "symfony", "symfony-ux", "cms", "php", "theme", "design-tokens", "css-variables"],
    "authors": [
        {
            "name": "Steeven THOMAS",
            "homepage": "https://github.com/steeven-th"
        }
    ],
    "require": {
        "php": "^8.2",
        "sulu/sulu": "^3.0",
        "symfony/framework-bundle": "^7.0",
        "doctrine/orm": "^3.0",
        "doctrine/doctrine-bundle": "^2.11"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "symfony/debug-bundle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "ItechWorld\\SuluTailwindThemeBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ItechWorld\\SuluTailwindThemeBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true
        }
    },
    "extra": {
        "branch-alias": {
            "dev-dev": "1.0.x-dev"
        }
    }
}
