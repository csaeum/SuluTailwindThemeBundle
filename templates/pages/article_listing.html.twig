{#
    Article listing page template.
    Renders a paginated list of articles using the active listing style
    from theme configuration (grid/list/cards).

    Uses Sulu's native smart_content for article fetching and filtering.
    The admin selects the source, categories, tags, and sorting in the
    smart_content configuration panel.
#}
{% extends 'base.html.twig' %}

{% block content %}
<div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    {# Page title #}
    {% if content.title is defined and content.title is not empty %}
        <h1 class="font-[var(--font-family-heading)] text-[var(--font-size-h1)] font-[var(--font-h1-weight)] leading-[var(--line-height-h1)] mb-8">
            {{ content.title }}
        </h1>
    {% endif %}

    {# Article listing with active style #}
    {% if content.articles is defined and content.articles is iterable and content.articles|length > 0 %}
        {% set listingStyle = iw_sulu_tailwind_theme_listing_style() %}

        {% set stylePath = '@ItechWorldSuluTailwindTheme/articles/listing/_style_' ~ listingStyle ~ '.html.twig' %}
        {% set fallbackPath = '@ItechWorldSuluTailwindTheme/articles/listing/_style_grid.html.twig' %}

        {% include [stylePath, fallbackPath] with {
            articles: content.articles,
            currentPage: view.articles.page|default(1),
            totalPages: view.articles.hasNextPage is defined and view.articles.hasNextPage ? view.articles.page + 1 : view.articles.page|default(1),
            baseUrl: sulu_content_path(content.url),
        } only %}
    {% else %}
        <p class="text-center text-[var(--color-secondary-500)] py-16">
            {{ 'iw_sulu_tailwind_theme.article.no_articles'|trans }}
        </p>
    {% endif %}
</div>
{% endblock %}
