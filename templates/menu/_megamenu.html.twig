{# Menu — mega menu with full-width dropdowns (native or snippet mode) #}

{# Data source: native (page tree) or snippet (manual structure) #}
{% set megaSource = config.megamenuSource|default('native') %}

{# Navigation position: left, center (default), right #}
{% set navPosition = config.navPosition|default('center') %}

{# Resolve logo media URLs #}
{% set logoDesktopUrl = null %}
{% set logoMobileUrl = null %}
{% if config.logoDesktop is defined and config.logoDesktop.id|default(null) is not null %}
    {% set logoDesktopMedia = sulu_resolve_media(config.logoDesktop.id, app.request.locale) %}
    {% if logoDesktopMedia is not null %}
        {% set logoDesktopUrl = logoDesktopMedia.thumbnails['iw_theme_logo_desktop']|default(logoDesktopMedia.url)|default(null) %}
    {% endif %}
{% endif %}
{% if config.logoMobile is defined and config.logoMobile.id|default(null) is not null %}
    {% set logoMobileMedia = sulu_resolve_media(config.logoMobile.id, app.request.locale) %}
    {% if logoMobileMedia is not null %}
        {% set logoMobileUrl = logoMobileMedia.thumbnails['iw_theme_logo_mobile']|default(logoMobileMedia.url)|default(null) %}
    {% endif %}
{% endif %}

{# Load social media links from snippet area #}
{% set socialLinks = [] %}
{% if config.displaySocialMedia|default(false) %}
    {% set socialSnippet = sulu_snippet_load_by_area('iw_theme_menu_social_media_links') %}
    {% if socialSnippet is not null and socialSnippet.content is defined and socialSnippet.content.blocks_social_medias is defined %}
        {% set socialLinks = socialSnippet.content.blocks_social_medias %}
    {% endif %}
{% endif %}

{# Load menu data based on source mode #}
{% if megaSource == 'snippet' %}
    {% set megaSnippet = sulu_snippet_load_by_area('iw_theme_mega_menu') %}
    {% set menuItems = megaSnippet is not null and megaSnippet.content is defined ? megaSnippet.content.menu_items|default([]) : [] %}
    {% set ctaTitle = megaSnippet is not null and megaSnippet.content is defined ? megaSnippet.content.cta_title|default(null) : null %}
    {% set ctaLink = megaSnippet is not null and megaSnippet.content is defined ? megaSnippet.content.cta_link|default(null) : null %}
    {% set ctaStyle = megaSnippet is not null and megaSnippet.content is defined ? megaSnippet.content.cta_style|default('primary') : 'primary' %}
{% else %}
    {% set navItems = sulu_page_navigation_root_tree('main', config.childLevels|default(3), {title: 'title', url: 'url'}) %}
{% endif %}

<header
    data-controller="menu"
    data-menu-animation-value="none"
    data-menu-slide-direction-value="top"
    class="iw-menu {{ config.transparentNavbar|default(false) ? 'iw-menu-transparent' : '' }} sticky top-0 z-40 w-full transition-shadow"
>
    {# ─── Desktop navbar ─── #}
    <nav class="relative z-50 md:container md:mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16 md:h-20">

            {# LEFT — Logo + Site Name #}
            <div class="flex-shrink-0 flex items-center {{ navPosition == 'left' ? 'mr-0' : '' }}">
                <a href="{{ sulu_content_path('/') }}" class="iw-menu-text flex items-center gap-2 no-underline">
                    {% if config.displayLogoDesktop|default(false) and logoDesktopUrl %}
                        <img src="{{ logoDesktopUrl }}" alt="" class="iw-menu-logo-desktop hidden md:block w-auto">
                    {% endif %}
                    {% if config.displayLogoMobile|default(false) and logoMobileUrl %}
                        <img src="{{ logoMobileUrl }}" alt="" class="iw-menu-logo-mobile block md:hidden w-auto">
                    {% endif %}
                    {% if config.displaySiteName|default(false) %}
                        <span class="text-xl font-bold">{{ config.siteName|default('') }}</span>
                    {% endif %}
                    {# Fallback: show site name if no logo and no siteName option checked #}
                    {% if not config.displayLogoDesktop|default(false) and not config.displayLogoMobile|default(false) and not config.displaySiteName|default(false) %}
                        <span class="text-xl font-bold">{{ config.siteName|default('Site') }}</span>
                    {% endif %}
                </a>
            </div>

            {# CENTER — Desktop L1 navigation items #}
            {% set navPositionClass = {
                'left': 'md:ml-6 md:mr-auto',
                'center': 'md:mx-auto',
                'right': 'md:ml-auto md:mr-6'
            } %}
            <div class="hidden md:flex items-center gap-1 {{ navPositionClass[navPosition]|default('md:mx-auto') }}">
                {% if megaSource == 'snippet' %}
                    {# ─── Snippet mode: render from snippet data ─── #}
                    {% for item in menuItems %}
                        {% if item.type == 'simple_link' %}
                            <a
                                href="{{ sulu_content_path(item.link.url|default('#')) }}"
                                class="iw-menu-text px-4 py-2 text-sm font-medium rounded-md transition-opacity no-underline hover:opacity-80"
                                {{ item.open_in_new_tab|default(false) ? 'target="_blank" rel="noopener noreferrer"' : '' }}
                            >
                                {{ item.title }}
                            </a>
                        {% elseif item.type == 'mega_dropdown' %}
                            <button
                                type="button"
                                data-action="menu#toggleMegaDropdown"
                                data-menu-target="megaParent"
                                class="iw-menu-text flex items-center gap-1 px-4 py-2 text-sm font-medium rounded-md transition-opacity cursor-pointer"
                            >
                                {{ item.title }}
                                <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                            </button>
                        {% endif %}
                    {% endfor %}
                {% else %}
                    {# ─── Native mode: render from page tree ─── #}
                    {% for item in navItems %}
                        {% if item.children is defined and item.children|length > 0 %}
                            <button
                                type="button"
                                data-action="menu#toggleMegaDropdown"
                                data-menu-target="megaParent"
                                class="iw-menu-text flex items-center gap-1 px-4 py-2 text-sm font-medium rounded-md transition-opacity cursor-pointer"
                            >
                                {{ item.title }}
                                <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                            </button>
                        {% else %}
                            <a
                                href="{{ sulu_content_path(item.url) }}"
                                class="iw-menu-text px-4 py-2 text-sm font-medium rounded-md transition-opacity no-underline hover:opacity-80"
                            >
                                {{ item.title }}
                            </a>
                        {% endif %}
                    {% endfor %}
                {% endif %}
            </div>

            {# RIGHT — Social media + CTA (snippet) + Burger (mobile) #}
            <div class="flex items-center gap-3">
                {# Social media icons — desktop #}
                {% if socialLinks|length > 0 %}
                    <div class="hidden md:flex items-center gap-2">
                        {% for link in socialLinks %}
                            <a href="{{ link.url }}" target="_blank" rel="noopener noreferrer"
                               class="inline-flex items-center">
                                {% if link.icon is defined and link.icon.id is defined %}
                                    {% set iconMedia = sulu_resolve_media(link.icon.id, app.request.locale) %}
                                    {% if iconMedia is not null and iconMedia.url is defined %}
                                        {% set iconUrl = iconMedia.thumbnails['50x50']|default(iconMedia.url) %}
                                        <span class="iw-social-icon w-5 h-5"
                                              style="-webkit-mask-image: url('{{ iconUrl }}'); mask-image: url('{{ iconUrl }}');"
                                              aria-label="{{ link.name|default('') }}"></span>
                                    {% else %}
                                        <span class="iw-social-text text-sm">{{ link.name|default('') }}</span>
                                    {% endif %}
                                {% else %}
                                    <span class="iw-social-text text-sm">{{ link.name|default('') }}</span>
                                {% endif %}
                            </a>
                        {% endfor %}
                    </div>
                {% endif %}

                {# CTA button — snippet mode only, desktop #}
                {% if megaSource == 'snippet' and ctaTitle and ctaLink %}
                    <a
                        href="{{ sulu_content_path(ctaLink.url|default('#')) }}"
                        class="hidden md:inline-block btn-{{ ctaStyle }} px-5 py-2 text-sm font-medium no-underline"
                    >
                        {{ ctaTitle }}
                    </a>
                {% endif %}

                {# Animated burger button — mobile only (3 lines → X) #}
                <button
                    type="button"
                    data-action="menu#toggle"
                    data-menu-target="burger"
                    class="iw-menu-burger md:hidden w-10 h-10 flex flex-col items-center justify-center gap-1.5"
                    aria-label="Menu"
                >
                    <span class="iw-menu-burger-line"></span>
                    <span class="iw-menu-burger-line"></span>
                    <span class="iw-menu-burger-line"></span>
                </button>
            </div>
        </div>
    </nav>

    {# ─── Mega dropdowns (desktop) — one per L1 with children ─── #}
    {% if megaSource == 'snippet' %}
        {# Snippet mode dropdowns #}
        {% for item in menuItems %}
            {% if item.type == 'mega_dropdown' %}
                <div
                    data-menu-target="megaDropdown"
                    class="iw-mega-dropdown hidden absolute left-0 right-0 z-40 shadow-lg"
                >
                    <div class="md:container md:mx-auto px-4 sm:px-6 lg:px-8 py-8">
                        <div class="iw-mega-grid-{{ min(item.columns|default([])|length|default(1), 5) }}">
                            {% for column in item.columns|default([]) %}
                                {% if column.type == 'link_column' %}
                                    {# Link column: title + list of links #}
                                    <div>
                                        {% if column.column_title|default(null) %}
                                            <span class="iw-menu-text-l2 font-semibold mb-3 block text-sm uppercase tracking-wider">
                                                {{ column.column_title }}
                                            </span>
                                        {% endif %}
                                        <ul class="space-y-2 mt-2 list-none p-0">
                                            {% for linkItem in column.links|default([]) %}
                                                <li>
                                                    <a href="{{ sulu_content_path(linkItem.link.url|default('#')) }}"
                                                       class="iw-menu-text-l3 block no-underline hover:opacity-80 transition-opacity">
                                                        <span class="text-sm">{{ linkItem.title }}</span>
                                                        {% if linkItem.description|default(null) %}
                                                            <span class="block text-xs opacity-60 mt-0.5">{{ linkItem.description }}</span>
                                                        {% endif %}
                                                    </a>
                                                </li>
                                            {% endfor %}
                                        </ul>
                                    </div>
                                {% elseif column.type == 'image_column' %}
                                    {# Image column: title + image cards (vertical or horizontal layout) #}
                                    {% set cardLayout = column.layout|default('vertical') %}
                                    {% set imgPos = column.image_position|default('left') %}
                                    <div>
                                        {% if column.column_title|default(null) %}
                                            <span class="iw-menu-text-l2 font-semibold mb-3 block text-sm uppercase tracking-wider">
                                                {{ column.column_title }}
                                            </span>
                                        {% endif %}
                                        <div class="grid gap-3 mt-2">
                                            {% set ratioClasses = {'1-1': 'aspect-square', '9-16': 'aspect-[9/16]', '16-9': 'aspect-video'} %}
                                            {% for card in column.cards|default([]) %}
                                                {% set cardRatioClass = ratioClasses[card.image_ratio|default('auto')]|default('') %}
                                                {% set cardHasBg = card.show_background|default(false) %}
                                                <a href="{{ sulu_content_path(card.link.url|default('#')) }}"
                                                   class="iw-mega-card block no-underline group {{ cardHasBg ? 'iw-mega-card-bg' : '' }} {{ cardLayout == 'horizontal' ? 'iw-mega-card-horizontal' : '' }} {{ cardLayout == 'horizontal' and imgPos == 'right' ? 'iw-mega-card-img-right' : '' }}">
                                                    {% if card.image is defined and card.image.id|default(null) is not null %}
                                                        {% set cardMedia = sulu_resolve_media(card.image.id, app.request.locale) %}
                                                        {% if cardMedia is not null %}
                                                            <img src="{{ cardMedia.thumbnails['iw_theme_mega_card']|default(cardMedia.url) }}"
                                                                 alt="{{ card.title }}"
                                                                 loading="lazy"
                                                                 class="{{ cardRatioClass }}">
                                                        {% endif %}
                                                    {% endif %}
                                                    <div class="{{ cardLayout == 'horizontal' ? 'iw-mega-card-body' : '' }} p-2">
                                                        <span class="iw-menu-text-l3 text-sm font-medium">{{ card.title }}</span>
                                                        {% if card.description|default(null) %}
                                                            <span class="iw-menu-text-l3 block text-xs opacity-60 mt-0.5">{{ card.description }}</span>
                                                        {% endif %}
                                                    </div>
                                                </a>
                                            {% endfor %}
                                        </div>
                                    </div>
                                {% elseif column.type == 'featured_column' %}
                                    {# Featured column: highlight with image, description, CTA (vertical or horizontal layout) #}
                                    {% set featLayout = column.layout|default('vertical') %}
                                    {% set featImgPos = column.image_position|default('left') %}
                                    {% set featRatioClasses = {'1-1': 'aspect-square', '9-16': 'aspect-[9/16]', '16-9': 'aspect-video'} %}
                                    {% set featRatioClass = featRatioClasses[column.image_ratio|default('auto')]|default('') %}
                                    {% set featBtnStyle = column.cta_style|default('primary') %}
                                    <div class="iw-mega-featured {{ featLayout == 'horizontal' ? 'iw-mega-featured-horizontal' : '' }} {{ featLayout == 'horizontal' and featImgPos == 'right' ? 'iw-mega-featured-img-right' : '' }}">
                                        {% if column.image is defined and column.image.id|default(null) is not null %}
                                            {% set featMedia = sulu_resolve_media(column.image.id, app.request.locale) %}
                                            {% if featMedia is not null %}
                                                <img src="{{ featMedia.thumbnails['iw_theme_mega_card']|default(featMedia.url) }}"
                                                     alt="{{ column.title }}"
                                                     class="{{ featLayout == 'vertical' ? 'mb-4' : '' }} {{ featRatioClass }}"
                                                     loading="lazy">
                                            {% endif %}
                                        {% endif %}
                                        <div class="{{ featLayout == 'horizontal' ? 'iw-mega-featured-body' : '' }}">
                                            <span class="iw-menu-text-l2 font-semibold text-sm block mb-2">{{ column.title }}</span>
                                            {% if column.description|default(null) %}
                                                <p class="iw-menu-text-l3 text-xs opacity-70 mb-3">{{ column.description }}</p>
                                            {% endif %}
                                            {% if column.cta_title|default(null) and column.cta_link|default(null) %}
                                                <a href="{{ sulu_content_path(column.cta_link.url|default('#')) }}"
                                                   class="btn-{{ featBtnStyle }} text-xs">
                                                    {{ column.cta_title }}
                                                </a>
                                            {% endif %}
                                        </div>
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                </div>
            {% endif %}
        {% endfor %}
    {% else %}
        {# Native mode dropdowns #}
        {% for item in navItems %}
            {% if item.children is defined and item.children|length > 0 %}
                <div
                    data-menu-target="megaDropdown"
                    class="iw-mega-dropdown hidden absolute left-0 right-0 z-40 shadow-lg"
                >
                    <div class="md:container md:mx-auto px-4 sm:px-6 lg:px-8 py-8">
                        <div class="iw-mega-grid-{{ min(item.children|length, 5) }}">
                            {% for child in item.children %}
                                <div>
                                    <a href="{{ sulu_content_path(child.url) }}"
                                       class="iw-menu-text-l2 font-semibold mb-3 block text-sm no-underline hover:opacity-80 transition-opacity">
                                        {{ child.title }}
                                    </a>
                                    {% if child.children is defined and child.children|length > 0 %}
                                        <ul class="space-y-2 mt-2 list-none p-0">
                                            {% for grandchild in child.children %}
                                                <li>
                                                    <a href="{{ sulu_content_path(grandchild.url) }}"
                                                       class="iw-menu-text-l3 text-sm no-underline hover:opacity-80 transition-opacity">
                                                        {{ grandchild.title }}
                                                    </a>
                                                </li>
                                            {% endfor %}
                                        </ul>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            {% endif %}
        {% endfor %}
    {% endif %}

    {# ─── Mobile overlay panel ─── #}
    <div
        data-menu-target="panel"
        class="iw-menu-overlay fixed left-0 right-0 bottom-0 top-16 z-30 md:hidden invisible opacity-0"
    >
        <nav class="iw-menu-overlay-nav px-6 sm:px-8 overflow-y-auto h-full">
            {% if megaSource == 'snippet' %}
                {# ─── Snippet mode: mobile accordion ─── #}
                {% for item in menuItems %}
                    {% if item.type == 'simple_link' %}
                        <a
                            href="{{ sulu_content_path(item.link.url|default('#')) }}"
                            class="iw-menu-text iw-menu-divider block py-4 text-lg font-medium border-b no-underline"
                            {{ item.open_in_new_tab|default(false) ? 'target="_blank" rel="noopener noreferrer"' : '' }}
                        >
                            {{ item.title }}
                        </a>
                    {% elseif item.type == 'mega_dropdown' %}
                        <div class="iw-menu-divider border-b">
                            <button
                                type="button"
                                data-action="menu#toggleMobileSubmenu"
                                class="iw-menu-text flex items-center justify-between w-full py-4 text-left cursor-pointer"
                            >
                                <span class="text-lg font-medium">{{ item.title }}</span>
                                <svg class="w-5 h-5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                            </button>
                            <div data-menu-target="submenu" class="hidden pb-3 mt-1 px-4">
                                {# Self-link if configured #}
                                {% if item.link is defined and item.link.url|default(null) %}
                                    <a
                                        href="{{ sulu_content_path(item.link.url) }}"
                                        class="iw-menu-text-l2 block py-2.5 opacity-80 hover:opacity-100 no-underline italic"
                                    >
                                        {{ item.title }}
                                    </a>
                                {% endif %}
                                {# Columns stacked vertically on mobile #}
                                {% for column in item.columns|default([]) %}
                                    {% if column.type == 'link_column' %}
                                        {% if column.column_title|default(null) %}
                                            <span class="iw-menu-text-l2 block py-2 font-semibold text-sm">{{ column.column_title }}</span>
                                        {% endif %}
                                        {% for linkItem in column.links|default([]) %}
                                            <a href="{{ sulu_content_path(linkItem.link.url|default('#')) }}"
                                               class="iw-menu-text-l3 block py-1.5 text-sm opacity-70 hover:opacity-100 no-underline">
                                                {{ linkItem.title }}
                                            </a>
                                        {% endfor %}
                                    {% elseif column.type == 'image_column' %}
                                        {% if column.column_title|default(null) %}
                                            <span class="iw-menu-text-l2 block py-2 font-semibold text-sm">{{ column.column_title }}</span>
                                        {% endif %}
                                        {% for card in column.cards|default([]) %}
                                            <a href="{{ sulu_content_path(card.link.url|default('#')) }}"
                                               class="iw-menu-text-l3 block py-1.5 text-sm opacity-70 hover:opacity-100 no-underline">
                                                {{ card.title }}
                                            </a>
                                        {% endfor %}
                                    {% elseif column.type == 'featured_column' %}
                                        <span class="iw-menu-text-l2 block py-2 font-semibold text-sm">{{ column.title }}</span>
                                        {% if column.cta_title|default(null) and column.cta_link|default(null) %}
                                            <a href="{{ sulu_content_path(column.cta_link.url|default('#')) }}"
                                               class="iw-menu-text-l3 block py-1.5 text-sm opacity-70 hover:opacity-100 no-underline">
                                                {{ column.cta_title }}
                                            </a>
                                        {% endif %}
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}

                {# CTA button — mobile #}
                {% if ctaTitle|default(null) and ctaLink|default(null) %}
                    <div class="pt-4 pb-2">
                        <a
                            href="{{ sulu_content_path(ctaLink.url|default('#')) }}"
                            class="btn-{{ ctaStyle }} block text-center px-5 py-3 text-base font-medium no-underline"
                        >
                            {{ ctaTitle }}
                        </a>
                    </div>
                {% endif %}
            {% else %}
                {# ─── Native mode: mobile accordion from page tree ─── #}
                {% for item in navItems %}
                    {% if item.children is defined and item.children|length > 0 %}
                        <div class="iw-menu-divider border-b">
                            <button
                                type="button"
                                data-action="menu#toggleMobileSubmenu"
                                class="iw-menu-text flex items-center justify-between w-full py-4 text-left cursor-pointer"
                            >
                                <span class="text-lg font-medium">{{ item.title }}</span>
                                <svg class="w-5 h-5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                            </button>
                            <div data-menu-target="submenu" class="hidden pb-3 mt-1 px-4">
                                {% for child in item.children %}
                                    {% if child.children is defined and child.children|length > 0 %}
                                        {# Level 2 with L3 sub-accordion #}
                                        <button
                                            type="button"
                                            data-action="menu#toggleMobileSubmenu"
                                            class="iw-menu-text-l2 flex items-center justify-between w-full py-2.5 text-left cursor-pointer"
                                        >
                                            <span>{{ child.title }}</span>
                                            <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                        </button>
                                        <div data-menu-target="submenu" class="hidden pb-2 mt-1 px-4">
                                            <a
                                                href="{{ sulu_content_path(child.url) }}"
                                                class="iw-menu-text-l3 block py-2 text-sm opacity-70 hover:opacity-100 no-underline italic"
                                            >
                                                {{ child.title }}
                                            </a>
                                            {% for grandchild in child.children %}
                                                <a
                                                    href="{{ sulu_content_path(grandchild.url) }}"
                                                    class="iw-menu-text-l3 block py-2 text-sm opacity-70 hover:opacity-100 no-underline"
                                                >
                                                    {{ grandchild.title }}
                                                </a>
                                            {% endfor %}
                                        </div>
                                    {% else %}
                                        <a
                                            href="{{ sulu_content_path(child.url) }}"
                                            class="iw-menu-text-l2 block py-2.5 opacity-80 hover:opacity-100 no-underline"
                                        >
                                            {{ child.title }}
                                        </a>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                    {% else %}
                        <a
                            href="{{ sulu_content_path(item.url) }}"
                            class="iw-menu-text iw-menu-divider block py-4 text-lg font-medium border-b no-underline"
                        >
                            {{ item.title }}
                        </a>
                    {% endif %}
                {% endfor %}
            {% endif %}

            {# Social media icons in mobile overlay #}
            {% if socialLinks|length > 0 %}
                <div class="flex items-center gap-3 pt-6 pb-4">
                    {% for link in socialLinks %}
                        <a href="{{ link.url }}" target="_blank" rel="noopener noreferrer"
                           class="inline-flex items-center">
                            {% if link.icon is defined and link.icon.id is defined %}
                                {% set iconMedia = sulu_resolve_media(link.icon.id, app.request.locale) %}
                                {% if iconMedia is not null and iconMedia.url is defined %}
                                    {% set iconUrl = iconMedia.thumbnails['50x50']|default(iconMedia.url) %}
                                    <span class="iw-social-icon w-6 h-6"
                                          style="-webkit-mask-image: url('{{ iconUrl }}'); mask-image: url('{{ iconUrl }}');"
                                          aria-label="{{ link.name|default('') }}"></span>
                                {% else %}
                                    <span class="iw-social-text">{{ link.name|default('') }}</span>
                                {% endif %}
                            {% else %}
                                <span class="iw-social-text">{{ link.name|default('') }}</span>
                            {% endif %}
                        </a>
                    {% endfor %}
                </div>
            {% endif %}
        </nav>
    </div>
</header>
