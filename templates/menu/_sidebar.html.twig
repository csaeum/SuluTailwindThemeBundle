{# Menu — fixed sidebar navigation #}
{% set menuBg = config.bg|default('var(--menu-bg)') %}
{% set menuText = config.text|default('var(--menu-text)') %}
{% set sidebarWidth = config.sidebarWidth|default('280px') %}

{# Sidebar — fixed on desktop, toggle on mobile #}
<aside
    data-controller="menu"
    class="fixed top-0 left-0 h-full z-40"
    style="width: {{ sidebarWidth }};"
>
    {# Mobile toggle button (shown when sidebar is collapsed) #}
    <button
        type="button"
        data-action="menu#toggle"
        data-menu-target="burger"
        class="lg:hidden fixed top-4 left-4 z-50 w-10 h-10 flex items-center justify-center rounded-full shadow-lg"
        aria-label="Menu"
        style="background-color: {{ menuBg }}; color: {{ menuText }};"
    >
        <svg data-menu-target="iconOpen" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        <svg data-menu-target="iconClose" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>

    {# Sidebar panel #}
    <div
        data-menu-target="panel"
        class="hidden lg:flex flex-col h-full overflow-y-auto p-6 shadow-xl"
        style="background-color: {{ menuBg }}; width: {{ sidebarWidth }};"
    >
        {# Logo / Brand #}
        <div class="mb-8">
            <a href="{{ sulu_content_path('/') }}" class="flex items-center no-underline" style="color: {{ menuText }};">
                {% if config.logo is defined and config.logo is not empty %}
                    <img src="{{ config.logo }}" alt="{{ config.siteName|default('') }}" class="h-10 w-auto">
                {% else %}
                    <span class="text-xl font-bold">{{ config.siteName|default('Site') }}</span>
                {% endif %}
            </a>
        </div>

        {# Navigation links #}
        {% if sulu_navigation_root_tree() is defined %}
            <nav class="flex-1 space-y-1">
                {% for item in sulu_navigation_root_tree() %}
                    {% if item.children is defined and item.children|length > 0 %}
                        <div>
                            <button
                                type="button"
                                data-action="menu#toggleMobileSubmenu"
                                class="flex items-center justify-between w-full py-2.5 px-3 text-left text-sm font-medium rounded-md hover:opacity-80 transition-opacity"
                                style="color: {{ menuText }};"
                            >
                                {{ item.title }}
                                <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                            </button>
                            <div data-menu-target="submenu" class="hidden pl-4 space-y-0.5">
                                {% for child in item.children %}
                                    <a
                                        href="{{ sulu_content_path(child.url) }}"
                                        class="block py-2 px-3 text-sm rounded-md opacity-75 hover:opacity-100 transition-opacity no-underline"
                                        style="color: {{ menuText }};"
                                    >
                                        {{ child.title }}
                                    </a>
                                {% endfor %}
                            </div>
                        </div>
                    {% else %}
                        <a
                            href="{{ sulu_content_path(item.url) }}"
                            class="block py-2.5 px-3 text-sm font-medium rounded-md hover:opacity-80 transition-opacity no-underline"
                            style="color: {{ menuText }};"
                        >
                            {{ item.title }}
                        </a>
                    {% endif %}
                {% endfor %}
            </nav>
        {% endif %}
    </div>
</aside>

{# Offset the page content on desktop to account for the sidebar width #}
<style>
    @media (min-width: 1024px) {
        body > main { margin-left: {{ sidebarWidth }}; }
    }
</style>
