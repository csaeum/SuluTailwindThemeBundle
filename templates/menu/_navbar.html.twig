{# Menu — classic horizontal navbar with responsive burger on mobile #}
{% set menuBg = config.bg|default('var(--menu-bg)') %}
{% set menuText = config.text|default('var(--menu-text)') %}

<header
    data-controller="menu"
    class="sticky top-0 z-40 w-full"
    style="background-color: {{ menuBg }}; color: {{ menuText }};"
>
    <nav class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16 md:h-20">
            {# Logo / Brand #}
            <div class="flex-shrink-0">
                <a href="{{ sulu_content_path('/') }}" class="flex items-center no-underline" style="color: {{ menuText }};">
                    {% if config.logo is defined and config.logo is not empty %}
                        <img src="{{ config.logo }}" alt="{{ config.siteName|default('') }}" class="h-8 md:h-10 w-auto">
                    {% else %}
                        <span class="text-xl font-bold">{{ config.siteName|default('Site') }}</span>
                    {% endif %}
                </a>
            </div>

            {# Desktop navigation #}
            <div class="hidden md:flex items-center gap-1">
                {% if sulu_navigation_root_tree() is defined %}
                    {% for item in sulu_navigation_root_tree() %}
                        {% if item.children is defined and item.children|length > 0 %}
                            {# Dropdown parent #}
                            <div class="relative group">
                                <button
                                    type="button"
                                    data-action="menu#toggleDropdown"
                                    class="flex items-center gap-1 px-4 py-2 text-sm font-medium rounded-md hover:opacity-80 transition-opacity"
                                    style="color: {{ menuText }};"
                                >
                                    {{ item.title }}
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                                </button>
                                <div
                                    data-menu-target="dropdown"
                                    class="hidden absolute top-full left-0 mt-1 w-48 rounded-md shadow-lg py-1 z-50"
                                    style="background-color: {{ menuBg }};"
                                >
                                    {% for child in item.children %}
                                        <a
                                            href="{{ sulu_content_path(child.url) }}"
                                            class="block px-4 py-2 text-sm hover:opacity-80 transition-opacity no-underline"
                                            style="color: {{ menuText }};"
                                        >
                                            {{ child.title }}
                                        </a>
                                    {% endfor %}
                                </div>
                            </div>
                        {% else %}
                            <a
                                href="{{ sulu_content_path(item.url) }}"
                                class="px-4 py-2 text-sm font-medium rounded-md hover:opacity-80 transition-opacity no-underline"
                                style="color: {{ menuText }};"
                            >
                                {{ item.title }}
                            </a>
                        {% endif %}
                    {% endfor %}
                {% endif %}
            </div>

            {# Mobile burger button #}
            <button
                type="button"
                data-action="menu#toggle"
                data-menu-target="burger"
                class="md:hidden w-10 h-10 flex items-center justify-center"
                aria-label="Menu"
                style="color: {{ menuText }};"
            >
                <svg data-menu-target="iconOpen" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
                <svg data-menu-target="iconClose" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>

        {# Mobile menu panel #}
        <div
            data-menu-target="panel"
            class="hidden md:hidden pb-4"
        >
            {% if sulu_navigation_root_tree() is defined %}
                {% for item in sulu_navigation_root_tree() %}
                    {% if item.children is defined and item.children|length > 0 %}
                        <div class="border-b border-white/10">
                            <button
                                type="button"
                                data-action="menu#toggleMobileSubmenu"
                                class="flex items-center justify-between w-full py-3 text-left"
                                style="color: {{ menuText }};"
                            >
                                <span class="font-medium">{{ item.title }}</span>
                                <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                            </button>
                            <div data-menu-target="submenu" class="hidden pl-4 pb-2">
                                {% for child in item.children %}
                                    <a
                                        href="{{ sulu_content_path(child.url) }}"
                                        class="block py-2 text-sm opacity-80 hover:opacity-100 no-underline"
                                        style="color: {{ menuText }};"
                                    >
                                        {{ child.title }}
                                    </a>
                                {% endfor %}
                            </div>
                        </div>
                    {% else %}
                        <a
                            href="{{ sulu_content_path(item.url) }}"
                            class="block py-3 font-medium border-b border-white/10 no-underline"
                            style="color: {{ menuText }};"
                        >
                            {{ item.title }}
                        </a>
                    {% endif %}
                {% endfor %}
            {% endif %}
        </div>
    </nav>
</header>
