{# Menu — classic horizontal navbar with fullscreen mobile overlay #}

{# Animation config for mobile menu #}
{% set animation = config.animation|default('none') %}
{% set slideDirection = config.slideDirection|default('top') %}

{# Resolve logo media URLs #}
{% set logoDesktopUrl = null %}
{% set logoMobileUrl = null %}
{% if config.logoDesktop is defined and config.logoDesktop.id|default(null) is not null %}
    {% set logoDesktopMedia = sulu_resolve_media(config.logoDesktop.id, app.request.locale) %}
    {% if logoDesktopMedia is not null %}
        {% set logoDesktopUrl = logoDesktopMedia.thumbnails['iw_theme_logo_desktop']|default(logoDesktopMedia.url)|default(null) %}
    {% endif %}
{% endif %}
{% if config.logoMobile is defined and config.logoMobile.id|default(null) is not null %}
    {% set logoMobileMedia = sulu_resolve_media(config.logoMobile.id, app.request.locale) %}
    {% if logoMobileMedia is not null %}
        {% set logoMobileUrl = logoMobileMedia.thumbnails['iw_theme_logo_mobile']|default(logoMobileMedia.url)|default(null) %}
    {% endif %}
{% endif %}

{# Navigation position: left, center (default), right #}
{% set navPosition = config.navPosition|default('center') %}

{# Load social media links from snippet area #}
{% set socialLinks = [] %}
{% if config.displaySocialMedia|default(false) %}
    {% set socialSnippet = sulu_snippet_load_by_area('iw_theme_menu_social_media_links') %}
    {% if socialSnippet is not null and socialSnippet.content is defined and socialSnippet.content.blocks_social_medias is defined %}
        {% set socialLinks = socialSnippet.content.blocks_social_medias %}
    {% endif %}
{% endif %}

<header
    data-controller="menu"
    data-menu-animation-value="{{ animation }}"
    data-menu-slide-direction-value="{{ slideDirection }}"
    class="iw-menu {{ config.transparentNavbar|default(false) ? 'iw-menu-transparent' : '' }} sticky top-0 z-40 w-full transition-shadow"
>
    <nav class="relative z-50 md:container md:mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16 md:h-20">

            {# LEFT — Logo + Site Name #}
            <div class="flex-shrink-0 flex items-center {{ navPosition == 'left' ? 'mr-0' : '' }}">
                <a href="{{ sulu_content_path('/') }}" class="iw-menu-text flex items-center gap-2 no-underline">
                    {% if config.displayLogoDesktop|default(false) and logoDesktopUrl %}
                        <img src="{{ logoDesktopUrl }}" alt="" class="iw-menu-logo-desktop hidden md:block w-auto">
                    {% endif %}
                    {% if config.displayLogoMobile|default(false) and logoMobileUrl %}
                        <img src="{{ logoMobileUrl }}" alt="" class="iw-menu-logo-mobile block md:hidden w-auto">
                    {% endif %}
                    {% if config.displaySiteName|default(false) %}
                        <span class="text-xl font-bold">{{ config.siteName|default('') }}</span>
                    {% endif %}
                    {# Fallback: show site name if no logo and no siteName option checked #}
                    {% if not config.displayLogoDesktop|default(false) and not config.displayLogoMobile|default(false) and not config.displaySiteName|default(false) %}
                        <span class="text-xl font-bold">{{ config.siteName|default('Site') }}</span>
                    {% endif %}
                </a>
            </div>

            {# Desktop navigation — position depends on navPosition setting #}
            {% set navItems = sulu_page_navigation_root_tree('main', config.childLevels|default(2), {title: 'title', url: 'url'}) %}
            {% set navPositionClass = {
                'left': 'md:ml-6 md:mr-auto',
                'center': 'md:mx-auto',
                'right': 'md:ml-auto md:mr-6'
            } %}
            <div class="hidden md:flex items-center gap-1 {{ navPositionClass[navPosition]|default('md:mx-auto') }}">
                {% if navItems is not empty %}
                    {% for item in navItems %}
                        {% if item.children is defined and item.children|length > 0 %}
                            {# Dropdown parent #}
                            <div class="relative" data-menu-target="dropdownParent">
                                <button
                                    type="button"
                                    data-action="menu#toggleDropdown"
                                    class="iw-menu-text flex items-center gap-1 px-4 py-2 text-sm font-medium rounded-md transition-opacity"
                                >
                                    {{ item.title }}
                                    <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                                </button>
                                <div
                                    data-menu-target="dropdown"
                                    class="iw-menu-dropdown-l2 hidden absolute top-full mt-1 w-48 shadow-lg py-1 z-50"
                                >
                                    {% for child in item.children %}
                                        {% if child.children is defined and child.children|length > 0 %}
                                            {# Level 2 item with level 3 sub-dropdown #}
                                            <div class="relative" data-menu-target="subdropdownParent">
                                                <a
                                                    href="{{ sulu_content_path(child.url) }}"
                                                    class="iw-menu-text-l2 flex items-center justify-between px-4 py-2 text-sm transition-opacity no-underline hover:opacity-80"
                                                >
                                                    {{ child.title }}
                                                    <svg class="w-3 h-3 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                                                </a>
                                                <div
                                                    data-menu-target="subdropdown"
                                                    class="iw-menu-dropdown-l3 hidden absolute left-full top-0 ml-0.5 w-48 shadow-lg py-1 z-50"
                                                >
                                                    {% for grandchild in child.children %}
                                                        <a
                                                            href="{{ sulu_content_path(grandchild.url) }}"
                                                            class="iw-menu-text-l3 block px-4 py-2 text-sm transition-opacity no-underline hover:opacity-80"
                                                        >
                                                            {{ grandchild.title }}
                                                        </a>
                                                    {% endfor %}
                                                </div>
                                            </div>
                                        {% else %}
                                            <a
                                                href="{{ sulu_content_path(child.url) }}"
                                                class="iw-menu-text-l2 block px-4 py-2 text-sm transition-opacity no-underline hover:opacity-80"
                                            >
                                                {{ child.title }}
                                            </a>
                                        {% endif %}
                                    {% endfor %}
                                </div>
                            </div>
                        {% else %}
                            <a
                                href="{{ sulu_content_path(item.url) }}"
                                class="iw-menu-text px-4 py-2 text-sm font-medium rounded-md transition-opacity no-underline hover:opacity-80"
                            >
                                {{ item.title }}
                            </a>
                        {% endif %}
                    {% endfor %}
                {% endif %}
            </div>

            {# RIGHT — Social media (desktop + mobile) + Burger #}
            <div class="flex items-center gap-3">
                {# Social media icons — desktop #}
                {% if socialLinks|length > 0 %}
                    <div class="hidden md:flex items-center gap-2">
                        {% for link in socialLinks %}
                            <a href="{{ link.url }}" target="_blank" rel="noopener noreferrer"
                               class="inline-flex items-center">
                                {% if link.icon is defined and link.icon.id is defined %}
                                    {% set iconMedia = sulu_resolve_media(link.icon.id, app.request.locale) %}
                                    {% if iconMedia is not null and iconMedia.url is defined %}
                                        {% set iconUrl = iconMedia.thumbnails['50x50']|default(iconMedia.url) %}
                                        <span class="iw-social-icon w-5 h-5"
                                              style="-webkit-mask-image: url('{{ iconUrl }}'); mask-image: url('{{ iconUrl }}');"
                                              aria-label="{{ link.name|default('') }}"></span>
                                    {% else %}
                                        <span class="iw-social-text text-sm">{{ link.name|default('') }}</span>
                                    {% endif %}
                                {% else %}
                                    <span class="iw-social-text text-sm">{{ link.name|default('') }}</span>
                                {% endif %}
                            </a>
                        {% endfor %}
                    </div>
                {% endif %}

                {# Animated burger button — mobile only (3 lines → X) #}
                <button
                    type="button"
                    data-action="menu#toggle"
                    data-menu-target="burger"
                    class="iw-menu-burger md:hidden w-10 h-10 flex flex-col items-center justify-center gap-1.5"
                    aria-label="Menu"
                >
                    <span class="iw-menu-burger-line"></span>
                    <span class="iw-menu-burger-line"></span>
                    <span class="iw-menu-burger-line"></span>
                </button>
            </div>
        </div>

    </nav>

    {# Mobile overlay panel — positioned below the navbar #}
    <div
        data-menu-target="panel"
        class="iw-menu-overlay fixed left-0 right-0 bottom-0 top-16 z-30 md:hidden invisible opacity-0"
    >
        {# Navigation links #}
        <nav class="iw-menu-overlay-nav px-6 sm:px-8 overflow-y-auto h-full">
            {% if navItems is not empty %}
                {% for item in navItems %}
                    {% if item.children is defined and item.children|length > 0 %}
                        <div class="iw-menu-divider border-b">
                            <button
                                type="button"
                                data-action="menu#toggleMobileSubmenu"
                                class="iw-menu-text flex items-center justify-between w-full py-4 text-left"
                            >
                                <span class="text-lg font-medium">{{ item.title }}</span>
                                <svg class="w-5 h-5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                            </button>
                            <div data-menu-target="submenu" class="iw-menu-dropdown-l2 hidden pb-3 mt-1 px-4">
                                {% for child in item.children %}
                                    {% if child.children is defined and child.children|length > 0 %}
                                        {# Level 2 with level 3 sub-accordion #}
                                        <button
                                            type="button"
                                            data-action="menu#toggleMobileSubmenu"
                                            class="iw-menu-text-l2 flex items-center justify-between w-full py-2.5 text-left"
                                        >
                                            <span>{{ child.title }}</span>
                                            <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                        </button>
                                        <div data-menu-target="submenu" class="iw-menu-dropdown-l3 hidden pb-2 mt-1 px-4">
                                            {% for grandchild in child.children %}
                                                <a
                                                    href="{{ sulu_content_path(grandchild.url) }}"
                                                    class="iw-menu-text-l3 block py-2 text-sm opacity-70 hover:opacity-100 no-underline"
                                                >
                                                    {{ grandchild.title }}
                                                </a>
                                            {% endfor %}
                                        </div>
                                    {% else %}
                                        <a
                                            href="{{ sulu_content_path(child.url) }}"
                                            class="iw-menu-text-l2 block py-2.5 opacity-80 hover:opacity-100 no-underline"
                                        >
                                            {{ child.title }}
                                        </a>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                    {% else %}
                        <a
                            href="{{ sulu_content_path(item.url) }}"
                            class="iw-menu-text iw-menu-divider block py-4 text-lg font-medium border-b no-underline"
                        >
                            {{ item.title }}
                        </a>
                    {% endif %}
                {% endfor %}
            {% endif %}

            {# Social media icons in mobile overlay #}
            {% if socialLinks|length > 0 %}
                <div class="flex items-center gap-3 pt-6 pb-4">
                    {% for link in socialLinks %}
                        <a href="{{ link.url }}" target="_blank" rel="noopener noreferrer"
                           class="inline-flex items-center">
                            {% if link.icon is defined and link.icon.id is defined %}
                                {% set iconMedia = sulu_resolve_media(link.icon.id, app.request.locale) %}
                                {% if iconMedia is not null and iconMedia.url is defined %}
                                    {% set iconUrl = iconMedia.thumbnails['50x50']|default(iconMedia.url) %}
                                    <span class="iw-social-icon w-6 h-6"
                                          style="-webkit-mask-image: url('{{ iconUrl }}'); mask-image: url('{{ iconUrl }}');"
                                          aria-label="{{ link.name|default('') }}"></span>
                                {% else %}
                                    <span class="iw-social-text">{{ link.name|default('') }}</span>
                                {% endif %}
                            {% else %}
                                <span class="iw-social-text">{{ link.name|default('') }}</span>
                            {% endif %}
                        </a>
                    {% endfor %}
                </div>
            {% endif %}
        </nav>
    </div>
</header>
