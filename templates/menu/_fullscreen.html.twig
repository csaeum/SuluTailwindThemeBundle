{# Menu — fullscreen overlay menu #}

{# Resolve fullscreen image media URL #}
{% set fullscreenImageUrl = null %}
{% if config.fullscreenImage is defined and config.fullscreenImage.id|default(null) is not null %}
    {% set fsMedia = sulu_resolve_media(config.fullscreenImage.id, app.request.locale) %}
    {% if fsMedia is not null %}
        {% set fullscreenImageUrl = fsMedia.url|default(null) %}
    {% endif %}
{% endif %}
{% set twoColumns = config.twoColumns|default(false) %}

{# Parent page click mode: none, split, or selflink (backward compat: boolean → string) #}
{% set clickMode = config.clickParentPage|default('none') %}
{% if clickMode is same as(true) %}{% set clickMode = 'selflink' %}{% endif %}
{% if clickMode is same as(false) %}{% set clickMode = 'none' %}{% endif %}

{# Animation: curtain (split) when image present, slide from right otherwise #}
{% set animation = fullscreenImageUrl ? 'curtain' : 'slide' %}

{# Resolve logo media URLs #}
{% set logoDesktopUrl = null %}
{% set logoMobileUrl = null %}
{% if config.logoDesktop is defined and config.logoDesktop.id|default(null) is not null %}
    {% set logoDesktopMedia = sulu_resolve_media(config.logoDesktop.id, app.request.locale) %}
    {% if logoDesktopMedia is not null %}
        {% set logoDesktopUrl = logoDesktopMedia.thumbnails['iw_theme_logo_desktop']|default(logoDesktopMedia.url)|default(null) %}
    {% endif %}
{% endif %}
{% if config.logoMobile is defined and config.logoMobile.id|default(null) is not null %}
    {% set logoMobileMedia = sulu_resolve_media(config.logoMobile.id, app.request.locale) %}
    {% if logoMobileMedia is not null %}
        {% set logoMobileUrl = logoMobileMedia.thumbnails['iw_theme_logo_mobile']|default(logoMobileMedia.url)|default(null) %}
    {% endif %}
{% endif %}

{# Load social media links from snippet area #}
{% set socialLinks = [] %}
{% if config.displaySocialMedia|default(false) %}
    {% set socialSnippet = sulu_snippet_load_by_area('iw_theme_menu_social_media_links') %}
    {% if socialSnippet is not null and socialSnippet.content is defined and socialSnippet.content.blocks_social_medias is defined %}
        {% set socialLinks = socialSnippet.content.blocks_social_medias %}
    {% endif %}
{% endif %}

<header
    data-controller="menu"
    data-menu-animation-value="{{ animation }}"
    data-menu-slide-direction-value="right"
    class="iw-menu {{ config.transparentNavbar|default(false) ? 'iw-menu-transparent' : '' }} sticky top-0 z-40 w-full transition-shadow"
>
    {# Navbar — z-30 so the fullscreen panel (z-50) covers it when open #}
    <nav class="relative z-30 container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16 md:h-20">

            {# LEFT — Logo + Site Name #}
            <div class="flex-shrink-0 flex items-center">
                <a href="{{ sulu_content_path('/') }}" class="iw-menu-text flex items-center gap-2 no-underline">
                    {% if config.displayLogoDesktop|default(false) and logoDesktopUrl %}
                        <img src="{{ logoDesktopUrl }}" alt="" class="iw-menu-logo-desktop hidden md:block w-auto">
                    {% endif %}
                    {% if config.displayLogoMobile|default(false) and logoMobileUrl %}
                        <img src="{{ logoMobileUrl }}" alt="" class="iw-menu-logo-mobile block md:hidden w-auto">
                    {% endif %}
                    {% if config.displaySiteName|default(false) %}
                        <span class="text-xl font-bold">{{ config.siteName|default('') }}</span>
                    {% endif %}
                    {# Fallback: show site name if no logo and no siteName option checked #}
                    {% if not config.displayLogoDesktop|default(false) and not config.displayLogoMobile|default(false) and not config.displaySiteName|default(false) %}
                        <span class="text-xl font-bold">{{ config.siteName|default('Site') }}</span>
                    {% endif %}
                </a>
            </div>

            {# RIGHT — Social media + Burger #}
            <div class="flex items-center gap-3">
                {# Social media icons #}
                {% if socialLinks|length > 0 %}
                    <div class="hidden md:flex items-center gap-2">
                        {% for link in socialLinks %}
                            <a href="{{ link.url }}" target="_blank" rel="noopener noreferrer"
                               class="inline-flex items-center">
                                {% if link.icon is defined and link.icon.id is defined %}
                                    {% set iconMedia = sulu_resolve_media(link.icon.id, app.request.locale) %}
                                    {% if iconMedia is not null and iconMedia.url is defined %}
                                        {% set iconUrl = iconMedia.thumbnails['50x50']|default(iconMedia.url) %}
                                        <span class="iw-social-icon w-5 h-5"
                                              style="-webkit-mask-image: url('{{ iconUrl }}'); mask-image: url('{{ iconUrl }}');"
                                              aria-label="{{ link.name|default('') }}"></span>
                                    {% else %}
                                        <span class="iw-social-text text-sm">{{ link.name|default('') }}</span>
                                    {% endif %}
                                {% else %}
                                    <span class="iw-social-text text-sm">{{ link.name|default('') }}</span>
                                {% endif %}
                            </a>
                        {% endfor %}
                    </div>
                {% endif %}

                {# Animated burger button — always visible #}
                <button
                    type="button"
                    data-action="menu#toggle"
                    data-menu-target="burger"
                    class="iw-menu-burger w-10 h-10 flex flex-col items-center justify-center gap-1.5"
                    aria-label="Menu"
                >
                    <span class="iw-menu-burger-line"></span>
                    <span class="iw-menu-burger-line"></span>
                    <span class="iw-menu-burger-line"></span>
                </button>
            </div>
        </div>
    </nav>

    {# Fullscreen overlay — covers full viewport, passes IN FRONT of navbar (z-50 > z-30) #}
    {% set navItems = sulu_page_navigation_root_tree('main', config.childLevels|default(2), {title: 'title', url: 'url'}) %}

    {# Macro: close button — same visual as the burger in its X state #}
    {% macro render_close_button() %}
        <div class="absolute top-0 right-0 h-16 md:h-20 flex items-center px-4 sm:px-6 lg:px-8">
            <button
                type="button"
                data-action="menu#toggle"
                class="iw-menu-burger is-open w-10 h-10 flex flex-col items-center justify-center gap-1.5"
                aria-label="Close"
            >
                <span class="iw-menu-burger-line"></span>
                <span class="iw-menu-burger-line"></span>
                <span class="iw-menu-burger-line"></span>
            </button>
        </div>
    {% endmacro %}

    {# Macro: navigation items (L1 / L2 / L3) #}
    {% macro render_nav_items(navItems, twoColumns, clickMode) %}
        {% set navClasses = twoColumns
            ? 'grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-2 text-left'
            : 'space-y-4 md:space-y-6 text-center'
        %}
        <nav class="{{ navClasses }} overflow-y-auto max-h-full px-6 sm:px-8 py-8">
            {% for item in navItems %}
                <div>
                    {# L1 link — always a direct link in fullscreen #}
                    <a
                        href="{{ sulu_content_path(item.url) }}"
                        class="iw-menu-text text-2xl md:text-4xl lg:text-5xl font-bold hover:opacity-80 transition-opacity no-underline"
                    >
                        {{ item.title }}
                    </a>

                    {# L2 children #}
                    {% if item.children is defined and item.children|length > 0 %}
                        <div class="mt-2 space-y-1">
                            {% for child in item.children %}
                                {% if child.children is defined and child.children|length > 0 %}
                                    {# L2 with L3 children #}
                                    <div class="iw-menu-parent-item">
                                        {% if clickMode == 'split' %}
                                            {# Split button: L2 is a link + separate chevron #}
                                            <div class="flex items-center gap-2 w-full {{ twoColumns ? 'justify-start' : 'justify-center' }}">
                                                <a
                                                    href="{{ sulu_content_path(child.url) }}"
                                                    class="iw-menu-text-l2 text-base md:text-lg opacity-60 hover:opacity-100 transition-opacity no-underline"
                                                >
                                                    {{ child.title }}
                                                </a>
                                                <button
                                                    type="button"
                                                    data-action="menu#toggleMobileSubmenu"
                                                    class="iw-menu-text-l2 opacity-60 hover:opacity-100 cursor-pointer"
                                                >
                                                    <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                                                    </svg>
                                                </button>
                                            </div>
                                        {% else %}
                                            {# Default button (none + selflink) #}
                                            <button
                                                type="button"
                                                data-action="menu#toggleMobileSubmenu"
                                                class="iw-menu-text-l2 flex items-center gap-2 text-base md:text-lg opacity-60 hover:opacity-100 transition-opacity w-full cursor-pointer {{ twoColumns ? 'justify-start' : 'justify-center' }}"
                                            >
                                                <span>{{ child.title }}</span>
                                                <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                                                </svg>
                                            </button>
                                        {% endif %}
                                        <div data-menu-target="submenu" class="hidden mt-1 space-y-1 {{ twoColumns ? '' : 'text-center' }}">
                                            {% if clickMode == 'selflink' %}
                                                {# Self-link to the L2 page itself #}
                                                <a
                                                    href="{{ sulu_content_path(child.url) }}"
                                                    class="iw-menu-text-l3 block text-sm opacity-50 hover:opacity-100 transition-opacity no-underline italic"
                                                >
                                                    {{ child.title }}
                                                </a>
                                            {% endif %}
                                            {# L3 grandchildren #}
                                            {% for grandchild in child.children %}
                                                <a
                                                    href="{{ sulu_content_path(grandchild.url) }}"
                                                    class="iw-menu-text-l3 block text-sm opacity-60 hover:opacity-100 transition-opacity no-underline"
                                                >
                                                    {{ grandchild.title }}
                                                </a>
                                            {% endfor %}
                                        </div>
                                    </div>
                                {% else %}
                                    {# L2 without children — simple link #}
                                    <a
                                        href="{{ sulu_content_path(child.url) }}"
                                        class="iw-menu-text-l2 block text-base md:text-lg opacity-60 hover:opacity-100 transition-opacity no-underline"
                                    >
                                        {{ child.title }}
                                    </a>
                                {% endif %}
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            {% endfor %}
        </nav>
    {% endmacro %}

    {# Macro: logo in overlay — respects admin display toggles #}
    {% macro render_overlay_logo(displayDesktop, logoDesktopUrl, displayMobile, logoMobileUrl) %}
        {% if (displayDesktop and logoDesktopUrl) or (displayMobile and logoMobileUrl) %}
            <div class="flex items-center justify-center pt-4 pb-2">
                {% if displayDesktop and logoDesktopUrl %}
                    <img src="{{ logoDesktopUrl }}" alt="" class="iw-menu-logo-desktop hidden md:block w-auto">
                {% endif %}
                {% if displayMobile and logoMobileUrl %}
                    <img src="{{ logoMobileUrl }}" alt="" class="iw-menu-logo-mobile block md:hidden w-auto">
                {% endif %}
            </div>
        {% endif %}
    {% endmacro %}

    {# Macro: social media icons #}
    {% macro render_social_links(socialLinks) %}
        {% if socialLinks|length > 0 %}
            <div class="flex items-center justify-center gap-3 py-6">
                {% for link in socialLinks %}
                    <a href="{{ link.url }}" target="_blank" rel="noopener noreferrer"
                       class="inline-flex items-center">
                        {% if link.icon is defined and link.icon.id is defined %}
                            {% set iconMedia = sulu_resolve_media(link.icon.id, app.request.locale) %}
                            {% if iconMedia is not null and iconMedia.url is defined %}
                                {% set iconUrl = iconMedia.thumbnails['50x50']|default(iconMedia.url) %}
                                <span class="iw-social-icon w-6 h-6"
                                      style="-webkit-mask-image: url('{{ iconUrl }}'); mask-image: url('{{ iconUrl }}');"
                                      aria-label="{{ link.name|default('') }}"></span>
                            {% else %}
                                <span class="iw-social-text">{{ link.name|default('') }}</span>
                            {% endif %}
                        {% else %}
                            <span class="iw-social-text">{{ link.name|default('') }}</span>
                        {% endif %}
                    </a>
                {% endfor %}
            </div>
        {% endif %}
    {% endmacro %}

    {% if fullscreenImageUrl %}
        {# ═══ WITH IMAGE — curtain split: image left, nav+bg right ═══ #}
        {# Panel is transparent (no bg), each volet carries its own content #}
        <div
            data-menu-target="panel"
            class="fixed inset-0 z-50 invisible opacity-0"
        >
            <div class="flex h-full">
                {# Left volet — image, slides from the left, full height #}
                <div data-menu-target="curtainLeft" class="w-1/2 h-full overflow-hidden hidden md:block">
                    <img src="{{ fullscreenImageUrl }}" alt="" class="w-full h-full object-cover">
                </div>
                {# Right volet — nav + background, slides from the right #}
                <div data-menu-target="curtainRight" class="iw-menu-fullscreen-nav relative w-full md:w-1/2 h-full overflow-y-auto flex flex-col items-center justify-center">
                    {{ _self.render_close_button() }}
                    {% if navItems is not empty %}
                        {{ _self.render_nav_items(navItems, twoColumns, clickMode) }}
                    {% endif %}
                    {{ _self.render_overlay_logo(config.displayLogoDesktop|default(false), logoDesktopUrl, config.displayLogoMobile|default(false), logoMobileUrl) }}
                    {{ _self.render_social_links(socialLinks) }}
                </div>
            </div>
        </div>
    {% else %}
        {# ═══ WITHOUT IMAGE — full panel slides from right ═══ #}
        {# Panel has iw-menu-overlay background, slides as one block #}
        <div
            data-menu-target="panel"
            class="iw-menu-overlay relative fixed inset-0 z-50 invisible opacity-0 flex flex-col items-center justify-center"
        >
            {{ _self.render_close_button() }}
            {% if navItems is not empty %}
                {{ _self.render_nav_items(navItems, twoColumns, clickMode) }}
            {% endif %}
            {{ _self.render_overlay_logo(config.displayLogoDesktop|default(false), logoDesktopUrl, config.displayLogoMobile|default(false), logoMobileUrl) }}
            {{ _self.render_social_links(socialLinks) }}
        </div>
    {% endif %}
</header>
