{#
    Event style: Card Info
    Hero image → floating info card (dates/location/organizer) → content blocks
#}
{% extends '@ItechWorldSuluTailwindTheme/articles/common/_article_base.html.twig' %}

{% block article_hero %}
    <div class="relative">
        {% include '@ItechWorldSuluTailwindTheme/articles/common/_article_hero.html.twig' with {
            image: content.heroImage|default(null),
            style: 'fullwidth',
            maxHeight: '450px',
        } only %}

        {# Floating info card overlapping the hero #}
        <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative">
            <div class="-mt-20 relative z-10 max-w-sm ml-auto">
                {% include '@ItechWorldSuluTailwindTheme/articles/common/_event_info_card.html.twig' with {
                    startDate: content.startDate|default(null),
                    endDate: content.endDate|default(null),
                    isOnline: content.isOnline|default(false),
                    location: content.location|default(''),
                    locationUrl: content.locationUrl|default(''),
                    organizer: content.organizer|default([]),
                } only %}
            </div>
        </div>
    </div>
{% endblock %}

{% block article_header %}
    <header class="article-header mt-8 mb-6">
        {% if articleConfig.showBreadcrumbs|iw_article_visible('page') %}
            {% include '@ItechWorldSuluTailwindTheme/articles/common/_breadcrumbs.html.twig' with {
                items: breadcrumb|default([]),
            } only %}
        {% endif %}

        {% if articleConfig.showCategories|iw_article_visible('page') %}
            {% include '@ItechWorldSuluTailwindTheme/articles/common/_article_categories.html.twig' with {
                categories: content.excerptCategories|default([]),
            } only %}
        {% endif %}

        <h1 class="font-[var(--font-family-heading)] text-[var(--font-size-h1)] font-[var(--font-h1-weight)] leading-[var(--line-height-h1)] mt-3 mb-4" itemprop="headline">
            {{ content.title }}
        </h1>

        {% if content.subtitle is defined and content.subtitle is not empty %}
            <p class="text-[var(--font-size-h4)] text-[var(--color-secondary-600)] leading-relaxed">
                {{ content.subtitle }}
            </p>
        {% endif %}
    </header>
{% endblock %}

{% block article_meta %}{% endblock %}

{% block article_footer %}
    <footer class="article-footer mt-10 pt-6 border-t border-[var(--color-border)]">
        {% include '@ItechWorldSuluTailwindTheme/articles/common/_article_tags.html.twig' with {
            tags: content.excerptTags|default([]),
        } only %}
    </footer>
{% endblock %}
