{#
    News style: Magazine
    Image left (40%) + title/meta/excerpt right (60%), content below full width
#}
{% extends '@ItechWorldSuluTailwindTheme/articles/common/_article_base.html.twig' %}

{% block article_hero %}{% endblock %}

{% block article_header %}
    <div class="grid grid-cols-1 md:grid-cols-5 gap-8 mt-8 mb-8">
        {# Image left (40%) #}
        {% if content.heroImage is defined and content.heroImage is not empty %}
            {% set heroIds = content.heroImage %}
            {% if heroIds is iterable %}
                {% set heroId = heroIds|first %}
            {% else %}
                {% set heroId = heroIds %}
            {% endif %}
            {% if heroId %}
                {% set heroMedia = sulu_resolve_media(heroId, app.request.locale) %}
                <div class="md:col-span-2">
                    <img src="{{ heroMedia.thumbnails['iw_hero_md']|default(heroMedia.thumbnails['sulu-400x400']|default(heroMedia.url)) }}"
                         alt="{{ heroMedia.title|default(content.title) }}"
                         class="w-full h-full object-cover rounded-[var(--border-imageRadius,var(--border-radius))]"
                         loading="eager" itemprop="image">
                </div>
            {% endif %}
        {% endif %}

        {# Title + meta right (60%) #}
        <div class="md:col-span-3 flex flex-col justify-center">
            {% include '@ItechWorldSuluTailwindTheme/articles/common/_article_categories.html.twig' with {
                categories: content.excerptCategories|default([]),
            } only %}

            <h1 class="font-[var(--font-family-heading)] text-[var(--font-size-h1)] font-[var(--font-h1-weight)] leading-[var(--line-height-h1)] mt-3 mb-4" itemprop="headline">
                {{ content.title }}
            </h1>

            {% if content.subtitle is defined and content.subtitle is not empty %}
                <p class="text-[var(--font-size-h5)] text-[var(--color-secondary-600)] leading-relaxed mb-4">
                    {{ content.subtitle }}
                </p>
            {% endif %}

            {% include '@ItechWorldSuluTailwindTheme/articles/common/_article_meta.html.twig' with {
                date: content.datePublished|default(null),
                authors: content.authors|default([]),
                showCategories: false,
            } only %}
        </div>
    </div>
    <hr class="mb-8 border-[var(--color-border)]">
{% endblock %}

{% block article_meta %}{% endblock %}

{% block article_footer %}
    <footer class="article-footer mt-10 pt-6 border-t border-[var(--color-border)]">
        {% include '@ItechWorldSuluTailwindTheme/articles/common/_article_tags.html.twig' with {
            tags: content.excerptTags|default([]),
        } only %}
    </footer>
{% endblock %}
