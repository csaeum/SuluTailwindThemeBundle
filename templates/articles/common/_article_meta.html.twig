{#
    Article meta information (date, authors, categories, reading time).

    Parameters:
    - date: DateTimeInterface or string (publication date)
    - authors: array of author block entries
    - categories: array of Sulu category objects (from excerpt)
    - readingTime: string or null (e.g. "5 min")
    - showDate: bool (default true)
    - showAuthors: bool (default true)
    - showCategories: bool (default true)
    - showReadingTime: bool (default true)
    - compact: bool (default false) — uses smaller layout
#}
{% set showDate = showDate|default(true) %}
{% set showAuthors = showAuthors|default(true) %}
{% set showCategories = showCategories|default(true) %}
{% set showReadingTime = showReadingTime|default(true) %}
{% set compact = compact|default(false) %}

<div class="article-meta flex flex-wrap items-center gap-3 {{ compact ? 'text-sm' : 'text-base' }} text-[var(--color-secondary-600)]">
    {% if showDate and date is defined and date is not empty %}
        <time datetime="{{ date|date('c') }}" itemprop="datePublished" class="flex items-center gap-1.5">
            <svg class="w-4 h-4 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            {{ iw_sulu_tailwind_theme_format_date(date) }}
        </time>
    {% endif %}

    {% if showAuthors and authors is defined and authors is iterable and authors|length > 0 %}
        <span class="text-[var(--color-border)]">|</span>
        <span class="flex items-center gap-1.5" itemprop="author" itemscope itemtype="https://schema.org/Person">
            <svg class="w-4 h-4 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
            {% for author in authors %}
                <span itemprop="name">{{ iw_sulu_tailwind_theme_author_name(author) }}</span>
                {% if not loop.last %}, {% endif %}
            {% endfor %}
        </span>
    {% endif %}

    {% if showCategories and categories is defined and categories is iterable and categories|length > 0 %}
        <span class="text-[var(--color-border)]">|</span>
        {% for category in categories %}
            <span class="inline-block px-2 py-0.5 text-xs font-medium rounded-full bg-[var(--color-primary-100)] text-[var(--color-primary-700)]">
                {{ category.name|default(category.title|default('')) }}
            </span>
        {% endfor %}
    {% endif %}

    {% if showReadingTime and readingTime is defined and readingTime is not empty %}
        <span class="text-[var(--color-border)]">|</span>
        <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            {{ readingTime }}
        </span>
    {% endif %}
</div>
