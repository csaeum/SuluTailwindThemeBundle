{#
    Related articles section — renders a grid of article cards.

    Parameters:
    - articles: array of resolved article objects (from smart_content)
    - title: section title (default: translation key)
    - columns: number of grid columns (default: 3)
    - maxItems: maximum items to show (default: 3)
#}
{% set columns = columns|default(3) %}
{% set maxItems = maxItems|default(3) %}
{% set sectionTitle = title|default('iw_sulu_tailwind_theme.article.related_articles'|trans) %}

{% if articles is defined and articles is iterable and articles|length > 0 %}
    <section class="article-related mt-16 mb-8">
        <div class="container mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="font-[var(--font-family-heading)] text-[var(--font-size-h3)] font-semibold mb-8">
                {{ sectionTitle }}
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-{{ columns }} gap-8">
                {% for article in articles|slice(0, maxItems) %}
                    {% include '@ItechWorldSuluTailwindTheme/articles/common/_article_card.html.twig' with {
                        article: article,
                    } only %}
                {% endfor %}
            </div>
        </div>
    </section>
{% endif %}
