{#
    Event info card — floating card with dates, location, organizer.

    Parameters:
    - startDate: DateTimeInterface (required)
    - endDate: DateTimeInterface or null
    - isOnline: bool
    - location: string (physical location name)
    - locationUrl: string (online event URL)
    - organizer: array (organizer block entry) or null
#}
{% set isOnline = isOnline|default(false) %}

<div class="event-info-card bg-white/95 backdrop-blur-md rounded-[var(--border-radius)] shadow-lg p-6 space-y-4">
    {# Dates #}
    {% if startDate is defined and startDate is not empty %}
        <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[var(--color-primary)] mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <div>
                <div class="font-medium text-[var(--color-text)]">
                    {{ iw_sulu_tailwind_theme_format_date(startDate, 'd MMMM yyyy, HH:mm') }}
                </div>
                {% if endDate is defined and endDate is not empty %}
                    <div class="text-sm text-[var(--color-secondary-500)]">
                        {{ 'iw_sulu_tailwind_theme.article.event_until'|trans }} {{ iw_sulu_tailwind_theme_format_date(endDate, 'd MMMM yyyy, HH:mm') }}
                    </div>
                {% endif %}
            </div>
        </div>
    {% endif %}

    {# Location / Online badge #}
    <div class="flex items-start gap-3">
        {% if isOnline %}
            <svg class="w-5 h-5 text-[var(--color-primary)] mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
            </svg>
            <div>
                <span class="inline-block px-2 py-0.5 text-xs font-semibold rounded-full bg-[var(--color-success-100)] text-[var(--color-success-700)]">
                    {{ 'iw_sulu_tailwind_theme.article.event_online_badge'|trans }}
                </span>
                {% if locationUrl is defined and locationUrl is not empty %}
                    <a href="{{ locationUrl }}" target="_blank" rel="noopener" class="block text-sm text-[var(--color-primary)] hover:underline mt-1">
                        {{ 'iw_sulu_tailwind_theme.article.event_join_link'|trans }}
                    </a>
                {% endif %}
            </div>
        {% elseif location is defined and location is not empty %}
            <svg class="w-5 h-5 text-[var(--color-primary)] mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span class="text-[var(--color-text)]">{{ location }}</span>
        {% endif %}
    </div>

    {# Organizer #}
    {% if organizer is defined and organizer is iterable and organizer|length > 0 %}
        {% set org = organizer|first %}
        {% set orgName = iw_sulu_tailwind_theme_author_name(org) %}
        {% if orgName is not empty %}
            <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[var(--color-primary)] mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
                <div>
                    <span class="text-xs text-[var(--color-secondary-500)] uppercase tracking-wide">
                        {{ 'iw_sulu_tailwind_theme.article.organized_by'|trans }}
                    </span>
                    <span class="block font-medium text-[var(--color-text)]">{{ orgName }}</span>
                </div>
            </div>
        {% endif %}
    {% endif %}
</div>
