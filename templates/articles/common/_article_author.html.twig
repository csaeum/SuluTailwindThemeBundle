{#
    Article author component — avatar + name + role.

    Parameters:
    - author: a single author entry (type: sulu_user|custom|contact|organization)
    - showAvatar: bool (default true)
    - size: 'sm' | 'md' (default) | 'lg'

    For sulu_user type, the author name is resolved from the Sulu user's contact.
#}
{% set showAvatar = showAvatar is defined ? showAvatar : true %}
{% set size = size|default('md') %}
{% set sizeClasses = {
    'sm': 'w-8 h-8 text-sm',
    'md': 'w-10 h-10 text-base',
    'lg': 'w-14 h-14 text-lg',
} %}

{% set authorType = author.type|default('custom') %}
{% set authorRole = author.role|default('') %}

{# Resolve author name — handles all types: sulu_user, custom, contact, organization #}
{% set authorName = iw_sulu_tailwind_theme_author_name(author) %}

{% if authorName is not empty %}
    <div class="article-author flex items-center gap-3" itemprop="author" itemscope itemtype="https://schema.org/Person">
        {% if showAvatar %}
            {% set avatarMedia = null %}
            {% if authorType == 'custom' and author.avatar is defined and author.avatar is iterable and author.avatar|length > 0 %}
                {% set avatarMedia = sulu_resolve_media(author.avatar|first, app.request.locale) %}
            {% endif %}

            {% if avatarMedia %}
                <img src="{{ avatarMedia.thumbnails['sulu-100x100']|default(avatarMedia.url) }}"
                     alt="{{ authorName }}"
                     class="{{ sizeClasses[size]|split(' ')|first }} {{ sizeClasses[size]|split(' ')[1]|default('') }} rounded-full object-cover">
            {% else %}
                {# Initials fallback #}
                {% set initials = authorName|split(' ')|map(w => w|first|upper)|join('')|slice(0, 2) %}
                <span class="{{ sizeClasses[size] }} rounded-full bg-[var(--color-primary-100)] text-[var(--color-primary-700)] flex items-center justify-center font-semibold">
                    {{ initials }}
                </span>
            {% endif %}
        {% endif %}

        <div>
            <span class="font-medium text-[var(--color-text)]" itemprop="name">{{ authorName }}</span>
            {% if authorRole is not empty %}
                <span class="block text-sm text-[var(--color-secondary-500)]">{{ authorRole }}</span>
            {% endif %}
        </div>
    </div>
{% endif %}
