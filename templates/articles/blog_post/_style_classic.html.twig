{#
    Blog Post style: Classic
    Hero image → title → prominent author avatar + date + reading time → content → tags → related
#}
{% extends '@ItechWorldSuluTailwindTheme/articles/common/_article_base.html.twig' %}

{% block article_hero %}
    {% include '@ItechWorldSuluTailwindTheme/articles/common/_article_hero.html.twig' with {
        image: content.heroImage|default(null),
        style: 'fullwidth',
    } only %}
{% endblock %}

{% block article_header %}
    <header class="article-header mt-8 mb-6">
        <h1 class="font-[var(--font-family-heading)] text-[var(--font-size-h1)] font-[var(--font-h1-weight)] leading-[var(--line-height-h1)] mb-6" itemprop="headline">
            {{ content.title }}
        </h1>

        {# Prominent author display #}
        {% if content.authors is defined and content.authors is iterable and content.authors|length > 0 %}
            <div class="flex items-center gap-4 mb-4">
                {% for author in content.authors %}
                    {% include '@ItechWorldSuluTailwindTheme/articles/common/_article_author.html.twig' with {
                        author: author,
                        size: 'lg',
                    } only %}
                {% endfor %}
            </div>
        {% endif %}

        {% include '@ItechWorldSuluTailwindTheme/articles/common/_article_meta.html.twig' with {
            date: content.datePublished|default(null),
            readingTime: content.readingTime|default(null),
            categories: content.excerptCategories|default([]),
            showAuthors: false,
        } only %}
    </header>
    <hr class="mb-8 border-[var(--color-border)]">
{% endblock %}

{% block article_meta %}{% endblock %}

{% block article_footer %}
    <footer class="article-footer mt-10 pt-6 border-t border-[var(--color-border)]">
        {% include '@ItechWorldSuluTailwindTheme/articles/common/_article_tags.html.twig' with {
            tags: content.excerptTags|default([]),
        } only %}
    </footer>
{% endblock %}

{% block article_related %}
    {% if content.relatedArticles is defined and content.relatedArticles is iterable %}
        {% include '@ItechWorldSuluTailwindTheme/articles/common/_article_related.html.twig' with {
            articles: content.relatedArticles,
        } only %}
    {% endif %}
{% endblock %}
