{#
    Listing style: List
    Full-width row cards with thumbnail left + title/meta/excerpt right.
    Each row is a horizontal `iw-article-card` so it picks up the same
    surface, border and hover effects as the other listing styles.
#}
{% set config = iw_sulu_tailwind_theme_article_config() %}
{# The list style ignores the configured ratio: a portrait image inside a
   horizontal row card would make every row prohibitively tall. We force
   16:9 and rely on object-fit:cover for the crop. #}
{% set cardRatio = '16/9' %}

{% if articles is defined and articles is iterable and articles|length > 0 %}
    <div class="iw-article-listing iw-article-listing--list">
        {% for article in articles %}
            {% include '@ItechWorldSuluTailwindTheme/articles/common/_article_card.html.twig' with {
                article: article,
                layout: 'horizontal',
                imageRatio: cardRatio,
                showDate: config.showDates|iw_article_visible('listing'),
                showExcerpt: config.showExcerpts|iw_article_visible('listing'),
                showCategory: config.showCategories|iw_article_visible('listing'),
                cardSurface: config.cardSurface,
                cardBorder: config.cardBorder,
                cardImagePadded: config.cardImagePadded,
                cardHoverTransform: config.cardHoverTransform,
                cardHoverImage: config.cardHoverImage,
                cardHoverShadow: config.cardHoverShadow,
                cardHoverBorder: config.cardHoverBorder,
            } only %}
        {% endfor %}
    </div>

    {% include '@ItechWorldSuluTailwindTheme/articles/common/_pagination.html.twig' with {
        currentPage: currentPage|default(1),
        totalPages: totalPages|default(1),
        baseUrl: baseUrl|default(''),
    } only %}
{% else %}
    <p class="iw-article-listing-empty">
        {{ 'iw_sulu_tailwind_theme.article.no_articles'|trans }}
    </p>
{% endif %}
