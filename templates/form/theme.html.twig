{# SuluFormBundle form theme — applies iw-form-field styling and variant-aware colors.
   Extends the SuluFormBundle basic theme and adds Tailwind-compatible classes
   so that forms automatically adapt to the active block variant via --form-* CSS variables.

   Layout: The <form> element is turned into a flex-wrap container with gap,
   and each row uses flex-basis for column widths instead of inline-block. #}

{% extends '@SuluForm/themes/basic.html.twig' %}

{# ── Form container — flex-wrap grid with gap ── #}
{%- block form_start -%}
    {% set attr = attr|merge({class: ('iw-form-grid ' ~ attr.class|default(''))|trim }) %}
    {{- parent() -}}
{%- endblock form_start -%}

{# ── Text inputs, emails, urls, tel, number, password, search, file ── #}
{%- block form_widget_simple -%}
    {%- if type|default('text') == 'file' -%}
        {% set serverMaxSize = iw_sulu_tailwind_theme_upload_max_size() %}
        <div data-controller="fileinput"
             data-fileinput-max-size-label-value="{{ serverMaxSize.label }}"
             data-fileinput-max-size-bytes-value="{{ serverMaxSize.bytes }}"
             data-fileinput-max-files-message-value="{{ 'iw_sulu_tailwind_theme.fileinput_max_reached'|trans({}, 'messages') }}"
             data-fileinput-max-size-message-value="{{ 'iw_sulu_tailwind_theme.fileinput_size_exceeded'|trans({}, 'messages') }}"
             class="iw-fileinput">
            {# Original input — hidden, kept in sync for form submission #}
            <div data-fileinput-target="input" class="hidden">
                {% set attr = attr|merge({ class: '' }) %}
                {{- parent() -}}
            </div>
            {# Proxy input — opens the file dialog, not part of the form #}
            <input type="file" data-fileinput-target="proxy"
                   data-action="change->fileinput#onFilesSelected"
                   class="hidden" tabindex="-1">
            {# Dropzone area #}
            <div data-fileinput-target="dropzone"
                 data-action="click->fileinput#openDialog dragover->fileinput#onDragOver dragenter->fileinput#onDragEnter dragleave->fileinput#onDragLeave drop->fileinput#onDrop"
                 class="iw-fileinput-dropzone">
                <svg class="iw-fileinput-dropzone-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                    <polyline points="17 8 12 3 7 8"/>
                    <line x1="12" y1="3" x2="12" y2="15"/>
                </svg>
                <span class="iw-fileinput-dropzone-text">{{ 'iw_sulu_tailwind_theme.fileinput_drop_or'|trans({}, 'messages') }}</span>
                <span class="iw-fileinput-dropzone-link">{{ 'iw_sulu_tailwind_theme.fileinput_browse'|trans({}, 'messages') }}</span>
                {# Info hints (accepted types, max files, max size) #}
                <div data-fileinput-target="info" class="iw-fileinput-info"></div>
            </div>
            {# Error message #}
            <div data-fileinput-target="error" class="iw-fileinput-error hidden"></div>
            {# File badges #}
            <div data-fileinput-target="list" class="iw-fileinput-list"></div>
        </div>
    {%- else -%}
        {% set attr = attr|merge({class: ('iw-form-field ' ~ attr.class|default(''))|trim }) %}
        {{- parent() -}}
    {%- endif -%}
{%- endblock form_widget_simple -%}

{# ── Textarea ── #}
{%- block textarea_widget -%}
    {% set attr = attr|merge({class: ('iw-form-field resize-y min-h-[120px] ' ~ attr.class|default(''))|trim }) %}
    {{- parent() -}}
{%- endblock textarea_widget -%}

{# ── Select (single / multiple) — wrapped with combobox Stimulus controller ── #}
{%- block choice_widget_collapsed -%}
    {% set isMultiple = multiple|default(false) %}
    {% set placeholderText = placeholder|default(null) is not null ? placeholder|trans : '—' %}
    <div data-controller="combobox"
         data-combobox-multiple-value="{{ isMultiple ? 'true' : 'false' }}"
         data-combobox-placeholder-value="{{ placeholderText }}"
         data-combobox-empty-label-value="{{ 'iw_sulu_tailwind_theme.combobox_none'|trans({}, 'messages') }}"
         class="iw-combobox relative">
        {# Hidden native select for form submission #}
        <div data-combobox-target="select" class="hidden">
            {% if isMultiple %}
                {% set attr = attr|merge({class: 'iw-form-select-multiple'}) %}
            {% else %}
                {% set attr = attr|merge({class: 'iw-form-select'}) %}
            {% endif %}
            {{- parent() -}}
        </div>
        {# Trigger button #}
        <button type="button"
                data-combobox-target="trigger"
                data-action="combobox#toggle"
                class="iw-form-field iw-combobox-trigger">
            <span data-combobox-target="display" class="iw-combobox-display"></span>
            <svg class="iw-combobox-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
        </button>
        {# Dropdown panel #}
        <div data-combobox-target="dropdown"
             class="iw-combobox-dropdown hidden">
            <div class="iw-combobox-search-wrap">
                <input type="text"
                       data-combobox-target="search"
                       data-action="input->combobox#onSearch"
                       placeholder="{{ 'iw_sulu_tailwind_theme.combobox_search'|trans({}, 'messages') }}"
                       class="iw-form-field iw-combobox-search"
                       autocomplete="off">
            </div>
            <div data-combobox-target="list" class="iw-combobox-list"></div>
        </div>
    </div>
{%- endblock choice_widget_collapsed -%}

{# ── Radio / Checkbox expanded choices — horizontal responsive grid ── #}
{%- block choice_widget_expanded -%}
    <div {{ block('widget_container_attributes') }} class="flex flex-wrap gap-x-6 gap-y-2 mt-1">
        {%- for child in form -%}
            <label class="inline-flex items-center gap-2 cursor-pointer text-sm">
                {{- form_widget(child) -}}
                <span>{{ child.vars.label|default(child.vars.name)|trans({}, choice_translation_domain) }}</span>
            </label>
        {%- endfor -%}
    </div>
{%- endblock choice_widget_expanded -%}

{# ── Labels ── #}
{%- block form_label -%}
    {%- if label is not same as(false) -%}
        {% set label_attr = label_attr|merge({class: ('block text-sm font-medium mb-1.5 ' ~ label_attr.class|default(''))|trim }) %}
        {%- set label %}{{ label|raw }}{% endset -%}
        {{ parent() }}
    {%- endif -%}
{%- endblock form_label -%}

{# ── Submit button row — extra top spacing, full width ── #}
{%- block button_row -%}
    <div class="iw-form-col-full pt-2">
        {{- form_widget(form) -}}
    </div>
{%- endblock button_row -%}

{# ── Submit button ── #}
{%- block button_widget -%}
    {% set attr = attr|merge({class: ('btn-variant inline-flex items-center justify-center px-8 py-3 text-sm font-medium transition cursor-pointer ' ~ attr.class|default(''))|trim }) %}
    {{- parent() -}}
{%- endblock button_widget -%}

{# ── Form row — uses flex-basis column class ── #}
{%- block form_row -%}
    {% set row_attr = row_attr|merge({class: (block('sulu_form_row_class_name') ~ ' ' ~ row_attr.class|default(''))|trim }) %}
    {{- parent() -}}
{%- endblock -%}

{# ── Errors ── #}
{%- block form_errors -%}
    {%- if errors|length > 0 -%}
        <ul class="iw-form-errors mt-1.5 text-sm">
            {%- for error in errors -%}
                <li>{{ error.message }}</li>
            {%- endfor -%}
        </ul>
    {%- endif -%}
{%- endblock form_errors -%}

{# ── Single checkbox row — label and checkbox inline ── #}
{%- block checkbox_row -%}
    {% set row_attr = row_attr|merge({class: (block('sulu_form_row_class_name') ~ ' ' ~ row_attr.class|default(''))|trim }) %}
    {%- set widget_attr = {} -%}
    {%- if help is not empty -%}
        {%- set widget_attr = {attr: {'aria-describedby': id ~"_help"}} -%}
    {%- endif -%}
    <div{% with {attr: row_attr} %}{{ block('attributes') }}{% endwith %}>
        <label class="inline-flex items-center gap-2 cursor-pointer text-sm">
            {{- form_widget(form, widget_attr) -}}
            <span>{{ label|default(name|humanize)|trans }}</span>
        </label>
        {{- form_errors(form) -}}
        {{- form_help(form) -}}
    </div>
{%- endblock checkbox_row -%}

{# ── Checkbox widget ── #}
{%- block checkbox_widget -%}
    {% set attr = attr|merge({class: ('iw-form-check ' ~ attr.class|default(''))|trim }) %}
    {{- parent() -}}
{%- endblock checkbox_widget -%}

{# ── Radio widget ── #}
{%- block radio_widget -%}
    {% set attr = attr|merge({class: ('iw-form-check ' ~ attr.class|default(''))|trim }) %}
    {{- parent() -}}
{%- endblock radio_widget -%}

{# ── Grid column classes — map SuluFormBundle widths to flex-basis ── #}
{%- block sulu_form_row_class_name -%}
    {%- set width = attr.width|default('full') -%}
    {%- if width == 'half' -%}
        {{- 'iw-form-col-half' -}}
    {%- elseif width == 'one-third' -%}
        {{- 'iw-form-col-third' -}}
    {%- elseif width == 'two-third' -%}
        {{- 'iw-form-col-two-third' -}}
    {%- elseif width == 'one-quarter' -%}
        {{- 'iw-form-col-quarter' -}}
    {%- elseif width == 'three-quarter' -%}
        {{- 'iw-form-col-three-quarter' -}}
    {%- else -%}
        {{- 'iw-form-col-full' -}}
    {%- endif -%}
{%- endblock sulu_form_row_class_name -%}

{# ── Headline (SuluFormBundle special field) ── #}
{%- block headline_row -%}
    <div class="iw-form-col-full pt-2">
        {{- form_widget(form) -}}
    </div>
{%- endblock headline_row -%}

{%- block headline_widget -%}
    <h4 class="text-xl font-semibold border-b pb-2" style="border-color: var(--form-border, var(--color-border, #e5e7eb))">{{- label|raw -}}</h4>
{%- endblock headline_widget -%}

{# ── FreeText (SuluFormBundle special field) ── #}
{%- block freeText_row -%}
    <div class="iw-form-col-full">
        {{- form_widget(form) -}}
    </div>
{%- endblock freeText_row -%}

{%- block freeText_widget -%}
    <div class="text-sm opacity-75 leading-relaxed">{{- label|raw -}}</div>
{%- endblock freeText_widget -%}

{# ── Honeypot — hidden from users ── #}
{%- block honeypot_row -%}
    <div class="!hidden" aria-hidden="true">
        {{- block('form_row') -}}
    </div>
{%- endblock -%}
