{# Text + Images block — mosaic layout with multiple images #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% include '@ItechWorldSuluTheme/blocks/common/_titles.html.twig' with {
        title: title|default(''),
        subTitle: subTitle|default('')
    } only %}

    {% set formatMap = {'16:9': 'iw_theme_16_9', '4:3': 'iw_theme_4_3', '1:1': 'iw_theme_1_1', '3:4': 'iw_theme_3_4', 'original': ''} %}
    {% set format = formatMap[imageFilter|default('original')]|default('') %}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {# Text area — takes 1 column #}
        <div class="lg:col-span-1">
            {% include '@ItechWorldSuluTheme/blocks/common/_paragraph.html.twig' with {
                text: text|default('')
            } only %}
        </div>

        {# Mosaic images — takes 2 columns #}
        {% if images is defined and images.ids is defined %}
            <div class="lg:col-span-2 grid grid-cols-2 gap-3">
                {% for mediaId in images.ids %}
                    {% set media = sulu_resolve_media(mediaId, app.request.locale) %}
                    <figure class="block-image {{ loop.first ? 'col-span-2' : '' }}">
                        <img
                            src="{{ media.thumbnails[format]|default(media.url) }}"
                            alt="{{ media.title|default('') }}"
                            loading="lazy"
                            class="w-full h-full object-cover rounded-[var(--radius-img)] {{ loop.first ? 'aspect-[16/9]' : 'aspect-square' }}"
                        >
                        {% if (showImagesName|default(false)) and media.title is defined and media.title is not empty %}
                            <figcaption class="mt-1 text-sm opacity-75">{{ media.title }}</figcaption>
                        {% endif %}
                    </figure>
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}
