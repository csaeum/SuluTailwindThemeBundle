{# Text + Images block — zigzag alternating layout #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% include '@ItechWorldSuluTheme/blocks/common/_titles.html.twig' with {
        title: title|default(''),
        subTitle: subTitle|default('')
    } only %}

    {% set formatMap = {'16:9': 'iw_theme_16_9', '4:3': 'iw_theme_4_3', '1:1': 'iw_theme_1_1', '3:4': 'iw_theme_3_4', 'original': 'iw_theme_16_9'} %}
    {% set format = formatMap[imageFilter|default('original')]|default('iw_theme_16_9') %}
    {% set ratioMap = {'iw_theme_16_9': '16/9', 'iw_theme_4_3': '4/3', 'iw_theme_1_1': '1/1', 'iw_theme_3_4': '3/4'} %}
    {% set ratio = ratioMap[format]|default('4/3') %}

    {% if images is defined and images is iterable and images|length > 0 %}
        <div class="space-y-12 md:space-y-16">
            {% for mediaId in images %}
                {% set media = sulu_resolve_media(mediaId, app.request.locale) %}
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
                    {# Image column #}
                    <div class="{{ loop.index is even ? 'md:order-2' : 'md:order-1' }}">
                        <img
                            src="{{ media.thumbnails[format]|default(media.url) }}"
                            alt="{{ media.title|default('') }}"
                            loading="lazy"
                            class="w-full object-cover rounded-[var(--radius-img)]"
                            style="aspect-ratio: {{ ratio }};"
                        >
                    </div>
                    {# Text column #}
                    <div class="{{ loop.index is even ? 'md:order-1' : 'md:order-2' }}">
                        {% if loop.first and text is defined and text is not empty %}
                            <div class="block-text prose max-w-none {% if paragraphRadius is defined and paragraphRadius %}{{ paragraphRadius }}{% endif %}">
                                {{ text|raw }}
                            </div>
                        {% elseif showImagesName|default(false) and media.title is defined %}
                            <h4 class="text-lg font-semibold">{{ media.title }}</h4>
                            {% if media.description is defined and media.description is not empty %}
                                <p class="mt-2 opacity-75">{{ media.description }}</p>
                            {% endif %}
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        {% include '@ItechWorldSuluTheme/blocks/common/_paragraph.html.twig' with {
            text: text|default(''),
            paragraphRadius: paragraphRadius|default('')
        } only %}
    {% endif %}
{% endblock %}
