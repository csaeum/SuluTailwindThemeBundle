{# Text + Images block — 50/50 split screen layout #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% set position = imagePosition|default('right') %}
    {% set formatMap = {'16:9': 'iw_theme_16_9', '4:3': 'iw_theme_4_3', '1:1': 'iw_theme_1_1', '3:4': 'iw_theme_3_4', 'original': 'iw_theme_16_9'} %}
    {% set format = formatMap[imageFilter|default('original')]|default('iw_theme_16_9') %}

    <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[400px]">
        {# Image side — full height cover #}
        <div class="{{ position == 'left' ? 'lg:order-1' : 'lg:order-2' }} relative min-h-[300px] lg:min-h-[400px]">
            {% if images is defined and images is iterable and images|length > 0 %}
                {% set firstMedia = sulu_resolve_media(images[0], app.request.locale) %}
                <img
                    src="{{ firstMedia.thumbnails[format]|default(firstMedia.url) }}"
                    alt="{{ firstMedia.title|default('') }}"
                    loading="lazy"
                    class="absolute inset-0 w-full h-full object-cover"
                >
            {% endif %}
        </div>

        {# Text side — vertically centered #}
        <div class="{{ position == 'left' ? 'lg:order-2' : 'lg:order-1' }} flex items-center">
            <div class="p-8 md:p-12 lg:p-16 w-full">
                {% include '@ItechWorldSuluTheme/blocks/common/_titles.html.twig' with {
                    title: title|default(''),
                    subTitle: subTitle|default('')
                } only %}

                {% include '@ItechWorldSuluTheme/blocks/common/_paragraph.html.twig' with {
                    text: text|default(''),
                    paragraphRadius: paragraphRadius|default('')
                } only %}
            </div>
        </div>
    </div>
{% endblock %}
