{# Text + Images block — image background with text overlay #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% set alignMap = {'left': 'text-left', 'center': 'text-center', 'right': 'text-right'} %}
    {% set titleAlignClass = alignMap[titleAlignment|default('left')]|default('text-left') %}

    {# For overlay, prefer a wide format for best cover result #}
    {# Fix: XML stores values with underscores (16_9, 4_3…), not colons #}
    {% set formatMap = {'16_9': 'iw_theme_16_9', '4_3': 'iw_theme_4_3', '1_1': 'iw_theme_1_1', '3_4': 'iw_theme_3_4', 'original': 'iw_theme_16_9'} %}
    {% set format = formatMap[imageFilter|default('original')]|default('iw_theme_16_9') %}

    {% set bgImageUrl = '' %}
    {% if images is defined and images is iterable and images|length > 0 %}
        {% set firstMedia = sulu_resolve_media(images[0], app.request.locale) %}
        {% set bgImageUrl = firstMedia.thumbnails[format]|default(firstMedia.url) %}
    {% endif %}

    <div class="relative min-h-[400px] md:min-h-[500px] flex items-center overflow-hidden"
         style="border-radius: var(--radius-img, 0);">
        {# Background image — covers the entire zone #}
        {% if bgImageUrl is not empty %}
            <img
                src="{{ bgImageUrl }}"
                alt=""
                loading="lazy"
                class="absolute inset-0 w-full h-full object-cover"
                style="border-radius: 0; min-width: 100%; min-height: 100%;"
            >
        {% endif %}

        {# Overlay gradient — direction depends on image position #}
        {% set position = imagePosition|default('right') %}
        <div class="absolute inset-0 {{ position == 'left' ? 'bg-gradient-to-l from-black/70 to-black/30' : 'bg-gradient-to-r from-black/70 to-black/30' }}" style="border-radius: 0;"></div>

        {# Content — positioned opposite to the image #}
        <div class="relative z-10 max-w-2xl p-8 md:p-12 text-white {{ position == 'left' ? 'ml-auto text-right' : '' }}">
            {% if title is defined and title is not empty %}
                <h2 class="block-title text-2xl md:text-3xl lg:text-4xl font-[var(--font-h2-weight)] text-white {{ titleAlignClass }}">{{ title }}</h2>
            {% endif %}
            {% if subTitle is defined and subTitle is not empty %}
                <h3 class="block-subtitle text-lg md:text-xl mt-2 text-white/80 {{ titleAlignClass }}">{{ subTitle }}</h3>
            {% endif %}

            {% if text is defined and text is not empty %}
                <div class="block-text prose prose-invert max-w-none mt-6">
                    {{ text|raw }}
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
