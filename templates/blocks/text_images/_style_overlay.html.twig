{# Text + Images block — image background with text overlay #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% set formatMap = {'16:9': 'iw_theme_16_9', '4:3': 'iw_theme_4_3', '1:1': 'iw_theme_1_1', '3:4': 'iw_theme_3_4', 'original': ''} %}
    {% set format = formatMap[imageFilter|default('original')]|default('') %}

    {% set bgImage = '' %}
    {% if images is defined and images.ids is defined and images.ids|length > 0 %}
        {% set firstMedia = sulu_resolve_media(images.ids[0], app.request.locale) %}
        {% set bgImage = firstMedia.thumbnails[format]|default(firstMedia.url) %}
    {% endif %}

    <div class="relative min-h-[400px] md:min-h-[500px] flex items-center rounded-[var(--radius-img)] overflow-hidden">
        {# Background image #}
        {% if bgImage is not empty %}
            <img
                src="{{ bgImage }}"
                alt=""
                loading="lazy"
                class="absolute inset-0 w-full h-full object-cover"
                style="border-radius: 0;"
            >
        {% endif %}

        {# Overlay gradient #}
        <div class="absolute inset-0 bg-gradient-to-r from-black/70 to-black/30"></div>

        {# Content #}
        <div class="relative z-10 max-w-2xl p-8 md:p-12 text-white">
            {% if title is defined and title is not empty %}
                <h2 class="block-title text-2xl md:text-3xl lg:text-4xl font-[var(--font-h2-weight)] text-white">{{ title }}</h2>
            {% endif %}
            {% if subTitle is defined and subTitle is not empty %}
                <h3 class="block-subtitle text-lg md:text-xl mt-2 text-white/80">{{ subTitle }}</h3>
            {% endif %}

            {% if text is defined and text is not empty %}
                <div class="block-text prose prose-invert max-w-none mt-6">
                    {{ text|raw }}
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
