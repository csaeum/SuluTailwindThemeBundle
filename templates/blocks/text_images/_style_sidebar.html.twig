{# Text + Images block — narrow sidebar with image, main text area #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% include '@ItechWorldSuluTheme/blocks/common/_titles.html.twig' with {
        title: title|default(''),
        subTitle: subTitle|default('')
    } only %}

    {% set formatMap = {'16:9': 'iw_theme_16_9', '4:3': 'iw_theme_4_3', '1:1': 'iw_theme_1_1', '3:4': 'iw_theme_3_4', 'original': 'iw_theme_3_4'} %}
    {% set format = formatMap[imageFilter|default('original')]|default('iw_theme_3_4') %}
    {% set position = imagePosition|default('right') %}

    {# Map image format to CSS aspect-ratio #}
    {% set ratioMap = {'iw_theme_16_9': '16/9', 'iw_theme_4_3': '4/3', 'iw_theme_1_1': '1/1', 'iw_theme_3_4': '3/4', 'iw_theme_hero': '12/5'} %}
    {% set ratio = ratioMap[format]|default('3/4') %}

    <div class="grid grid-cols-1 md:grid-cols-5 gap-8">
        {# Main text area — 3/5 = 60% #}
        <div class="{{ position == 'left' ? 'md:order-2 md:col-span-3' : 'md:order-1 md:col-span-3' }}">
            {% include '@ItechWorldSuluTheme/blocks/common/_paragraph.html.twig' with {
                text: text|default('')
            } only %}
        </div>

        {# Sidebar images — 2/5 = 40% #}
        <div class="{{ position == 'left' ? 'md:order-1 md:col-span-2' : 'md:order-2 md:col-span-2' }}">
            {% include '@ItechWorldSuluTheme/blocks/common/_image_slider.html.twig' with {
                images: images|default([]),
                imageFormat: format,
                showName: showImagesName|default(false),
                autoplay: true,
                aspectRatio: ratio
            } only %}
        </div>
    </div>
{% endblock %}
