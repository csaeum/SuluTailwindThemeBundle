{# Text + Images block — classic layout supporting left/right, top/bottom and background positions #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% include '@ItechWorldSuluTheme/blocks/common/_titles.html.twig' with {
        title: title|default(''),
        subTitle: subTitle|default(''),
        titleAlignment: titleAlignment|default('left'),
        variant: variant|default('clair')
    } only %}

    {% set position = imagePosition|default('right') %}
    {# Fix: XML stores values with underscores (16_9, 4_3…), not colons #}
    {% set formatMap = {'16_9': 'iw_theme_16_9', '4_3': 'iw_theme_4_3', '1_1': 'iw_theme_1_1', '3_4': 'iw_theme_3_4', 'original': 'iw_theme_16_9'} %}
    {% set format = formatMap[imageFilter|default('original')]|default('iw_theme_16_9') %}

    {# Map image format to CSS aspect-ratio for consistent slider sizing #}
    {% set ratioMap = {'iw_theme_16_9': '16/9', 'iw_theme_4_3': '4/3', 'iw_theme_1_1': '1/1', 'iw_theme_3_4': '3/4', 'iw_theme_hero': '12/5'} %}
    {% set ratio = ratioMap[format]|default('4/3') %}
    {% set radius = paragraphRadius|default('') %}

    {# Detect effective block padding per axis: defined + not empty + not zero = has padding #}
    {% set hasTopPad = paddingTop is defined and paddingTop is not empty and paddingTop != 'pt-0' %}
    {% set hasBotPad = paddingBottom is defined and paddingBottom is not empty and paddingBottom != 'pb-0' %}
    {% set hasLatPad = paddingLateral is defined and paddingLateral is not empty and paddingLateral != 'px-0' %}

    {# ── Background mode: first image replaces paragraph background ── #}
    {# Image wrapper follows same logic as BOTTOM position for radius/margins. #}
    {% if position == 'background' %}
        {% set bgImageUrl = '' %}
        {% if images is defined and images is iterable and images|length > 0 %}
            {% set firstMedia = sulu_resolve_media(images[0], app.request.locale) %}
            {% set bgImageUrl = firstMedia.thumbnails[format]|default(firstMedia.url) %}
        {% endif %}

        {% set lateralMode = lateralMargins|default('interior') %}

        {# Same margin logic as BOTTOM #}
        {% set bgClasses = ['relative', 'overflow-hidden', 'p-6', 'md:p-8', 'min-h-[200px]', 'flex', 'items-center'] %}
        {% if (hasTopPad or hasBotPad) and not hasLatPad %}
            {% if hasBotPad %}
                {% set pbVal = paddingBottom is defined ? paddingBottom|split('-')|last : '4' %}
                {% set bgClasses = bgClasses|merge(['mx-' ~ pbVal]) %}
            {% endif %}
        {% elseif hasLatPad and not hasBotPad %}
            {% set pxVal = paddingLateral is defined ? paddingLateral|split('-')|last : '4' %}
            {% set bgClasses = bgClasses|merge(['mb-' ~ pxVal]) %}
        {% endif %}

        {# Radius when any spacing exists #}
        {% if radius and (hasLatPad or hasBotPad or hasTopPad) %}
            {% set bgClasses = bgClasses|merge([radius]) %}
        {% endif %}

        {# Interior mode: responsive radius + bottom space from sm #}
        {% set bgWrapperClass = '' %}
        {% if lateralMode == 'interior' and not hasLatPad %}
            {% if radius %}
                {% set bgClasses = bgClasses|merge(['sm:' ~ radius]) %}
            {% endif %}
            {# Use padding on a wrapper instead of margin to avoid collapse #}
            {% set smPbVal = hasBotPad ? (paddingBottom is defined ? paddingBottom|split('-')|last : '4') : '4' %}
            {% set bgWrapperClass = 'sm:pb-' ~ smPbVal %}
        {% endif %}

        {# Exterior mode: no radius if no paddingBottom and no paddingLateral #}

        {% if bgWrapperClass %}
        <div class="{{ bgWrapperClass }}">
        {% endif %}
        <div class="{{ bgClasses|join(' ') }}">
            {% if bgImageUrl is not empty %}
                <img
                    src="{{ bgImageUrl }}"
                    alt=""
                    loading="lazy"
                    class="absolute inset-0 w-full h-full object-cover"
                >
                {# Dark overlay for text readability — hidden when paragraph has its own bg #}
                <div class="block-bg-overlay absolute inset-0 bg-black/60"></div>
            {% endif %}

            <div class="relative z-10 w-full">
                {% if text is defined and text is not empty %}
                    <div class="block-text prose prose-invert max-w-none{% if radius %} {{ radius }}{% endif %}">
                        {{ text|raw }}
                    </div>
                {% endif %}
            </div>
        </div>
        {% if bgWrapperClass %}
        </div>
        {% endif %}

    {# ── Top / Bottom mode: stacked layout ── #}
    {% elseif position == 'top' or position == 'bottom' %}
        {# Paragraph lateral margin: ALWAYS present when no lateral padding,
           value matches pb or pt so it aligns with the image. Fallback to 4. #}
        {% set paraMargin = '' %}
        {% if not hasLatPad %}
            {% if hasBotPad %}
                {% set paraMargin = 'mx-' ~ (paddingBottom is defined ? paddingBottom|split('-')|last : '4') %}
            {% elseif hasTopPad %}
                {% set paraMargin = 'mx-' ~ (paddingTop is defined ? paddingTop|split('-')|last : '4') %}
            {% else %}
                {% set paraMargin = 'mx-4' %}
            {% endif %}
        {% endif %}

        {# Image classes (BOTTOM only):
           · vertical pad but NO lateral → mx matching pb value
           · lateral pad but NO bottom → mb matching px value
           Radius + overflow-hidden added when image has margin. #}
        {% set imgClasses = [] %}
        {% if position == 'bottom' %}
            {% if (hasTopPad or hasBotPad) and not hasLatPad %}
                {% if hasBotPad %}
                    {% set pbVal = paddingBottom is defined ? paddingBottom|split('-')|last : '4' %}
                    {% set imgClasses = imgClasses|merge(['mx-' ~ pbVal]) %}
                {% endif %}
            {% elseif hasLatPad and not hasBotPad %}
                {% set pxVal = paddingLateral is defined ? paddingLateral|split('-')|last : '4' %}
                {% set imgClasses = imgClasses|merge(['mb-' ~ pxVal]) %}
            {% endif %}

        {% endif %}

        {# Radius: TOP only when lateral padding, BOTTOM when any spacing #}
        {% if radius %}
            {% if position == 'top' and hasLatPad %}
                {% set imgClasses = imgClasses|merge([radius, 'overflow-hidden']) %}
            {% elseif position == 'bottom' and (imgClasses|length > 0 or hasLatPad or hasBotPad or hasTopPad) %}
                {% set imgClasses = imgClasses|merge([radius, 'overflow-hidden']) %}
            {% endif %}
        {% endif %}

        {# Interior mode: container adds lateral space from sm breakpoint.
           When no explicit lateral padding, add responsive radius + alignment. #}
        {% set lateralMode = lateralMargins|default('interior') %}
        {% if lateralMode == 'interior' and not hasLatPad and radius %}
            {% if position == 'top' %}
                {% set imgClasses = imgClasses|merge(['sm:' ~ radius, 'sm:overflow-hidden']) %}
            {% elseif position == 'bottom' %}
                {% set imgClasses = imgClasses|merge(['sm:' ~ radius, 'sm:overflow-hidden']) %}
                {% if paraMargin %}
                    {% set imgClasses = imgClasses|merge(['sm:' ~ paraMargin|replace({'mx-': 'mb-'})]) %}
                {% endif %}
            {% endif %}
        {% endif %}

        <div class="flex flex-col gap-2 md:gap-5">
            {% if position == 'top' %}
                {# Image first, then text #}
                {% if imgClasses|length > 0 %}
                    <div class="{{ imgClasses|join(' ') }}">
                        {% include '@ItechWorldSuluTheme/blocks/common/_image_slider.html.twig' with {
                            images: images|default([]),
                            imageFormat: format,
                            showName: showImagesName|default(false),
                            autoplay: true,
                            aspectRatio: ratio
                        } only %}
                    </div>
                {% else %}
                    {% include '@ItechWorldSuluTheme/blocks/common/_image_slider.html.twig' with {
                        images: images|default([]),
                        imageFormat: format,
                        showName: showImagesName|default(false),
                        autoplay: true,
                        aspectRatio: ratio
                    } only %}
                {% endif %}

                {# Paragraph: mx on mobile, reset at sm in interior mode (container provides space) #}
                {% if paraMargin %}
                    <div class="{{ paraMargin }}{% if lateralMode == 'interior' %} sm:mx-0{% endif %}">
                        {% include '@ItechWorldSuluTheme/blocks/common/_paragraph.html.twig' with {
                            text: text|default(''),
                            paragraphRadius: radius
                        } only %}
                    </div>
                {% else %}
                    {% include '@ItechWorldSuluTheme/blocks/common/_paragraph.html.twig' with {
                        text: text|default(''),
                        paragraphRadius: radius
                    } only %}
                {% endif %}
            {% else %}
                {# Text first, then image #}
                {% if paraMargin %}
                    <div class="{{ paraMargin }}{% if lateralMode == 'interior' %} sm:mx-0{% endif %}">
                        {% include '@ItechWorldSuluTheme/blocks/common/_paragraph.html.twig' with {
                            text: text|default(''),
                            paragraphRadius: radius
                        } only %}
                    </div>
                {% else %}
                    {% include '@ItechWorldSuluTheme/blocks/common/_paragraph.html.twig' with {
                        text: text|default(''),
                        paragraphRadius: radius
                    } only %}
                {% endif %}

                {% if imgClasses|length > 0 %}
                    <div class="{{ imgClasses|join(' ') }}">
                        {% include '@ItechWorldSuluTheme/blocks/common/_image_slider.html.twig' with {
                            images: images|default([]),
                            imageFormat: format,
                            showName: showImagesName|default(false),
                            autoplay: true,
                            aspectRatio: ratio
                        } only %}
                    </div>
                {% else %}
                    {% include '@ItechWorldSuluTheme/blocks/common/_image_slider.html.twig' with {
                        images: images|default([]),
                        imageFormat: format,
                        showName: showImagesName|default(false),
                        autoplay: true,
                        aspectRatio: ratio
                    } only %}
                {% endif %}
            {% endif %}
        </div>

    {# ── Left / Right mode: side-by-side grid ── #}
    {# Always needs paddingBottom + paddingLateral; force minimum when explicitly set to 0. #}
    {% else %}
        {% set forcePb = paddingBottom is defined and paddingBottom == 'pb-0' %}
        {% set forcePx = paddingLateral is defined and paddingLateral == 'px-0' %}

        {% if forcePb or forcePx %}
        <div class="{% if forcePb %}pb-3{% endif %} {% if forcePx %}px-3{% endif %}">
        {% endif %}

        <div class="grid grid-cols-1 md:grid-cols-2 gap-2 md:gap-5 items-center">
            {# Text column #}
            <div class="{{ position == 'left' ? 'md:order-2' : 'md:order-1' }}">
                {% include '@ItechWorldSuluTheme/blocks/common/_paragraph.html.twig' with {
                    text: text|default(''),
                    paragraphRadius: radius
                } only %}
            </div>

            {# Images column: always has radius (never edge-to-edge in grid) #}
            <div class="{{ position == 'left' ? 'md:order-1' : 'md:order-2' }}{% if radius %} {{ radius }} overflow-hidden{% endif %}">
                {% include '@ItechWorldSuluTheme/blocks/common/_image_slider.html.twig' with {
                    images: images|default([]),
                    imageFormat: format,
                    showName: showImagesName|default(false),
                    autoplay: true,
                    aspectRatio: ratio
                } only %}
            </div>
        </div>

        {% if forcePb or forcePx %}
        </div>
        {% endif %}
    {% endif %}
{% endblock %}
