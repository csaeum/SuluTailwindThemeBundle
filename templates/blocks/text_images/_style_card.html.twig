{# Text + Images block — card layout with image on top #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% set formatMap = {'16:9': 'iw_theme_16_9', '4:3': 'iw_theme_4_3', '1:1': 'iw_theme_1_1', '3:4': 'iw_theme_3_4', 'original': 'iw_theme_16_9'} %}
    {% set format = formatMap[imageFilter|default('original')]|default('iw_theme_16_9') %}
    {% set ratioMap = {'iw_theme_16_9': '16/9', 'iw_theme_4_3': '4/3', 'iw_theme_1_1': '1/1', 'iw_theme_3_4': '3/4'} %}
    {% set ratio = ratioMap[format]|default('4/3') %}

    <div class="max-w-lg mx-auto rounded-[var(--border-radius,8px)] border border-[var(--color-border,#e5e7eb)] overflow-hidden transition-shadow duration-300 hover:shadow-lg">
        {# Image area #}
        {% if images is defined and images is iterable and images|length > 0 %}
            <div class="overflow-hidden">
                {% include '@ItechWorldSuluTheme/blocks/common/_image_slider.html.twig' with {
                    images: images|default([]),
                    imageFormat: format,
                    showName: showImagesName|default(false),
                    autoplay: true,
                    aspectRatio: ratio
                } only %}
            </div>
        {% endif %}

        {# Text area #}
        <div class="p-6">
            {% include '@ItechWorldSuluTheme/blocks/common/_titles.html.twig' with {
                title: title|default(''),
                subTitle: subTitle|default(''),
                titleAlignment: titleAlignment|default('left'),
                variant: variant|default('clair')
            } only %}

            {% include '@ItechWorldSuluTheme/blocks/common/_paragraph.html.twig' with {
                text: text|default(''),
                paragraphRadius: paragraphRadius|default('')
            } only %}
        </div>
    </div>
{% endblock %}
