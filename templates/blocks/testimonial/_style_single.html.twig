{# Testimonial block — single featured testimonial #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% include '@ItechWorldSuluTheme/blocks/common/_titles.html.twig' with {
        title: title|default(''),
        subTitle: subTitle|default('')
    } only %}

    {% if testimonials is defined and testimonials is iterable and testimonials|length > 0 %}
        {% set item = testimonials[0] %}
        <div class="max-w-3xl mx-auto text-center">
            {# Large decorative quotes #}
            <svg class="w-16 h-16 text-[var(--color-primary)] opacity-15 mx-auto mb-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11h4v10H0z"/>
            </svg>

            {# Large avatar #}
            {% if item.avatar is defined and item.avatar.id is defined %}
                {% set avatarMedia = sulu_resolve_media(item.avatar.id, app.request.locale) %}
                <div class="flex justify-center mb-6">
                    {% include '@ItechWorldSuluTheme/blocks/common/_avatar.html.twig' with {
                        avatar: avatarMedia,
                        name: item.author|default(''),
                        size: 'lg'
                    } only %}
                </div>
            {% endif %}

            {% if item.quote is defined and item.quote is not empty %}
                <p class="text-xl md:text-2xl lg:text-3xl italic leading-relaxed">{{ item.quote }}</p>
            {% endif %}

            <div class="mt-6">
                {% if item.author is defined and item.author is not empty %}
                    <span class="block font-semibold text-lg">{{ item.author }}</span>
                {% endif %}
                {% if item.role is defined and item.role is not empty %}
                    <span class="block text-sm opacity-60 mt-1">{{ item.role }}</span>
                {% endif %}
            </div>

            {# Rating #}
            {% if item.rating is defined and item.rating > 0 %}
                <div class="flex justify-center gap-1 mt-4">
                    {% for i in 1..5 %}
                        <svg class="w-5 h-5 {{ i <= item.rating ? 'text-yellow-400' : 'text-gray-300' }}" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                        </svg>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    {% endif %}
{% endblock %}
