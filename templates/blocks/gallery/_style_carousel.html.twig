{# Gallery block — 3D carousel with parallax tilt, blurred background and lightbox #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {# Resolve lateral mode and image radius #}
    {% set imageRadius = paragraphImageRadius|default('') %}
    {% set lateralMode = lateralMargins|default('interior') %}
    {% if lateralMode is same as(true) or lateralMode == '1' %}
        {% set lateralMode = 'exterior' %}
    {% elseif lateralMode is same as(false) or lateralMode == '0' or lateralMode == '' %}
        {% set lateralMode = 'interior' %}
    {% endif %}

    {# In interior mode, apply radius from sm: breakpoint only #}
    {% if lateralMode == 'interior' and imageRadius %}
        {% set imageRadiusClass = 'sm:' ~ imageRadius ~ ' sm:overflow-hidden' %}
    {% elseif imageRadius %}
        {% set imageRadiusClass = imageRadius ~ ' overflow-hidden' %}
    {% else %}
        {% set imageRadiusClass = '' %}
    {% endif %}

    {% if images is defined and images is iterable %}
        {% set showNames = showImagesName|default(false) %}

        {# Map imageFilter value to Sulu thumbnail name and CSS aspect-ratio #}
        {% set formatMap = {'16_9': 'iw_theme_16_9', '4_3': 'iw_theme_4_3', '1_1': 'iw_theme_1_1', '3_4': 'iw_theme_3_4', 'original': 'iw_theme_3_4'} %}
        {% set format = formatMap[imageFilter|default('original')]|default('iw_theme_3_4') %}
        {% set ratioMap = {'iw_theme_16_9': '16 / 9', 'iw_theme_4_3': '4 / 3', 'iw_theme_1_1': '1 / 1', 'iw_theme_3_4': '3 / 4'} %}
        {% set slideAspect = ratioMap[format]|default('3 / 4') %}

        {# Controller wraps everything: bg + titles + carousel #}
        <div
            data-controller="carousel3d"
            data-carousel3d-autoplay-value="true"
            data-carousel3d-interval-value="5000"
        >
            {# Blurred backgrounds — JS will move this to the parent <section> #}
            <div class="carousel-3d__bgs" data-carousel3d-target="bgsContainer">
                {% for mediaId in images %}
                    {% set media = sulu_resolve_media(mediaId, app.request.locale) %}
                    <div
                        class="carousel-3d__bg"
                        data-carousel3d-target="bg"
                        {% if loop.first %}data-current{% elseif loop.index0 == 1 %}data-next{% elseif loop.index0 == images|length - 1 %}data-previous{% else %}data-hidden{% endif %}
                        style="--bg: url('{{ media.thumbnails['iw_theme_16_9']|default(media.url) }}')"
                    ></div>
                {% endfor %}
            </div>

            {# Titles — sit on top of the blurred background #}
            <div class="relative z-10">
                {% include '@ItechWorldSuluTheme/blocks/common/_titles.html.twig' with {
                    title: title|default(''),
                    subTitle: subTitle|default(''),
                    titleAlignment: titleAlignment|default('left'),
                    variant: variant|default(0)
                } only %}
            </div>

            {# Carousel #}
            <div class="carousel-3d{{ imageRadiusClass ? ' ' ~ imageRadiusClass : '' }}" style="--slide-aspect: {{ slideAspect }};">
                {# Previous button #}
                <button
                    type="button"
                    data-action="carousel3d#prev"
                    class="gallery-nav relative z-30"
                    aria-label="Previous"
                >
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                </button>

                <div class="carousel-3d__wrapper">
                    {# ── Slides ── #}
                    <div class="carousel-3d__slides">
                        {% for mediaId in images %}
                            {% set media = sulu_resolve_media(mediaId, app.request.locale) %}
                            <div
                                class="carousel-3d__slide"
                                data-carousel3d-target="slide"
                                {% if loop.first %}data-current{% elseif loop.index0 == 1 %}data-next{% elseif loop.index0 == images|length - 1 %}data-previous{% else %}data-hidden{% endif %}
                            >
                                <div class="carousel-3d__slide-inner">
                                    <div class="carousel-3d__image-wrapper{{ imageRadius ? ' ' ~ imageRadius ~ ' overflow-hidden' : '' }}">
                                        <a
                                            href="{{ media.url }}"
                                            class="glightbox block w-full h-full"
                                            data-title="{{ showNames and media.title is defined ? media.title : '' }}"
                                        >
                                            <img
                                                src="{{ media.thumbnails[format]|default(media.url) }}"
                                                alt="{{ media.title|default('') }}"
                                                loading="lazy"
                                                class="w-full h-full object-cover"
                                            >
                                        </a>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>

                    {# ── Info overlays ── #}
                    {% if showNames %}
                        <div class="carousel-3d__infos">
                            {% for mediaId in images %}
                                {% set media = sulu_resolve_media(mediaId, app.request.locale) %}
                                <div
                                    class="carousel-3d__info"
                                    data-carousel3d-target="info"
                                    {% if loop.first %}data-current{% elseif loop.index0 == 1 %}data-next{% elseif loop.index0 == images|length - 1 %}data-previous{% else %}data-hidden{% endif %}
                                >
                                    <div class="carousel-3d__info-inner">
                                        <span class="carousel-3d__title">{{ media.title|default('') }}</span>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>

                {# Next button #}
                <button
                    type="button"
                    data-action="carousel3d#next"
                    class="gallery-nav relative z-30"
                    aria-label="Next"
                >
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </button>
            </div>
        </div>
    {% else %}
        {% include '@ItechWorldSuluTheme/blocks/common/_titles.html.twig' with {
            title: title|default(''),
            subTitle: subTitle|default(''),
            titleAlignment: titleAlignment|default('left'),
            variant: variant|default(0)
        } only %}
    {% endif %}
{% endblock %}
