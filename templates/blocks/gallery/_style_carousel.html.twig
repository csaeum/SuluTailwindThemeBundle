{# Gallery block — carousel with navigation dots #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% include '@ItechWorldSuluTheme/blocks/common/_titles.html.twig' with {
        title: title|default(''),
        subTitle: subTitle|default('')
    } only %}

    {% if images is defined and images.ids is defined %}
        <div
            data-controller="slider"
            data-slider-autoplay-value="true"
            data-slider-interval-value="5000"
            data-slider-mode-value="carousel"
            class="relative overflow-hidden rounded-[var(--radius-img)]"
        >
            {# Carousel slides #}
            <div data-slider-target="track" class="relative">
                {% for mediaId in images.ids %}
                    {% set media = sulu_resolve_media(mediaId, app.request.locale) %}
                    <div
                        data-slider-target="slide"
                        class="w-full {{ not loop.first ? 'hidden' : '' }}"
                    >
                        <figure class="block-image">
                            <img
                                src="{{ media.thumbnails['iw_theme_16_9']|default(media.url) }}"
                                alt="{{ media.title|default('') }}"
                                loading="lazy"
                                class="w-full aspect-[16/9] object-cover"
                                style="border-radius: 0;"
                            >
                            {% if (showImagesName|default(false)) and media.title is defined and media.title is not empty %}
                                <figcaption class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-black/60 text-white text-sm">
                                    {{ media.title }}
                                </figcaption>
                            {% endif %}
                        </figure>
                    </div>
                {% endfor %}
            </div>

            {# Prev / Next buttons #}
            <button
                type="button"
                data-action="slider#prev"
                class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 flex items-center justify-center rounded-full bg-white/20 backdrop-blur-sm hover:bg-white/40 transition-colors text-white"
                aria-label="Previous"
            >
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            </button>
            <button
                type="button"
                data-action="slider#next"
                class="absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 flex items-center justify-center rounded-full bg-white/20 backdrop-blur-sm hover:bg-white/40 transition-colors text-white"
                aria-label="Next"
            >
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </button>

            {# Dot indicators #}
            <div data-slider-target="dots" class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2">
                {% for mediaId in images.ids %}
                    <button
                        type="button"
                        data-action="slider#goTo"
                        data-slider-index-param="{{ loop.index0 }}"
                        class="w-3 h-3 rounded-full {{ loop.first ? 'bg-white' : 'bg-white/50' }} transition-colors"
                        aria-label="Slide {{ loop.index }}"
                    ></button>
                {% endfor %}
            </div>
        </div>
    {% endif %}
{% endblock %}
