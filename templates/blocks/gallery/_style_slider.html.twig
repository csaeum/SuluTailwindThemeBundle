{# Gallery block — horizontal slider with Stimulus controller #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% include '@ItechWorldSuluTheme/blocks/common/_titles.html.twig' with {
        title: title|default(''),
        subTitle: subTitle|default('')
    } only %}

    {% if images is defined and images.ids is defined %}
        <div
            data-controller="slider"
            data-slider-autoplay-value="false"
            class="relative"
        >
            {# Slider track #}
            <div
                data-slider-target="track"
                class="flex overflow-x-auto scroll-smooth snap-x snap-mandatory gap-4 pb-4 scrollbar-hide"
            >
                {% for mediaId in images.ids %}
                    {% set media = sulu_resolve_media(mediaId, app.request.locale) %}
                    <figure class="block-image flex-none w-[80%] sm:w-[60%] md:w-[40%] lg:w-[30%] snap-start">
                        <img
                            src="{{ media.thumbnails['iw_theme_16_9']|default(media.url) }}"
                            alt="{{ media.title|default('') }}"
                            loading="lazy"
                            class="w-full aspect-[16/9] object-cover rounded-[var(--radius-img)]"
                        >
                        {% if (showImagesName|default(false)) and media.title is defined and media.title is not empty %}
                            <figcaption class="mt-2 text-sm opacity-75">{{ media.title }}</figcaption>
                        {% endif %}
                    </figure>
                {% endfor %}
            </div>

            {# Navigation buttons #}
            <button
                type="button"
                data-action="slider#prev"
                class="absolute left-2 top-1/2 -translate-y-1/2 w-10 h-10 flex items-center justify-center rounded-full bg-[var(--color-background)] shadow-lg opacity-80 hover:opacity-100 transition-opacity"
                aria-label="Previous"
            >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            </button>
            <button
                type="button"
                data-action="slider#next"
                class="absolute right-2 top-1/2 -translate-y-1/2 w-10 h-10 flex items-center justify-center rounded-full bg-[var(--color-background)] shadow-lg opacity-80 hover:opacity-100 transition-opacity"
                aria-label="Next"
            >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </button>
        </div>
    {% endif %}
{% endblock %}
