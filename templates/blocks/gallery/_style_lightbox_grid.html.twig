{# Gallery block — grid with hover overlay and lightbox #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% include '@ItechWorldSuluTheme/blocks/common/_titles.html.twig' with {
        title: title|default(''),
        subTitle: subTitle|default('')
    } only %}

    {% if images is defined and images is iterable %}
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
            {% for mediaId in images %}
                {% set media = sulu_resolve_media(mediaId, app.request.locale) %}
                <a
                    href="{{ media.url }}"
                    class="glightbox group relative block overflow-hidden rounded-[var(--radius-img)]"
                    data-title="{{ (showImagesName|default(false)) and media.title is defined ? media.title : '' }}"
                >
                    <img
                        src="{{ media.thumbnails['iw_theme_1_1']|default(media.url) }}"
                        alt="{{ media.title|default('') }}"
                        loading="lazy"
                        class="w-full aspect-square object-cover transition-transform duration-300 group-hover:scale-105"
                    >
                    {# Hover overlay with expand icon #}
                    <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition-colors duration-300 flex items-center justify-center">
                        <svg class="w-8 h-8 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/>
                        </svg>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
