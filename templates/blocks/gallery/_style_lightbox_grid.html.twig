{# Gallery block — grid with lightbox on click #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% include '@ItechWorldSuluTheme/blocks/common/_titles.html.twig' with {
        title: title|default(''),
        subTitle: subTitle|default('')
    } only %}

    {% if images is defined and images.ids is defined %}
        <div
            data-controller="gallery"
            class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3"
        >
            {% for mediaId in images.ids %}
                {% set media = sulu_resolve_media(mediaId, app.request.locale) %}
                <a
                    href="{{ media.url }}"
                    data-action="click->gallery#open"
                    data-gallery-index-param="{{ loop.index0 }}"
                    class="block-image group cursor-pointer overflow-hidden rounded-[var(--radius-img)]"
                >
                    <img
                        src="{{ media.thumbnails['iw_theme_gallery_thumb']|default(media.url) }}"
                        alt="{{ media.title|default('') }}"
                        loading="lazy"
                        class="w-full aspect-square object-cover transition-transform duration-300 group-hover:scale-110"
                        style="border-radius: 0;"
                    >
                </a>
            {% endfor %}

            {# Lightbox overlay (hidden by default, managed by Stimulus) #}
            <div
                data-gallery-target="lightbox"
                class="hidden fixed inset-0 z-50 bg-black/90 flex items-center justify-center"
            >
                <button
                    type="button"
                    data-action="gallery#close"
                    class="absolute top-4 right-4 text-white w-10 h-10 flex items-center justify-center"
                    aria-label="Close"
                >
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>

                <button
                    type="button"
                    data-action="gallery#prev"
                    class="absolute left-4 top-1/2 -translate-y-1/2 text-white w-12 h-12 flex items-center justify-center"
                    aria-label="Previous"
                >
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                </button>

                <img
                    data-gallery-target="lightboxImage"
                    src=""
                    alt=""
                    class="max-w-[90vw] max-h-[90vh] object-contain"
                    style="border-radius: 0;"
                >

                <button
                    type="button"
                    data-action="gallery#next"
                    class="absolute right-4 top-1/2 -translate-y-1/2 text-white w-12 h-12 flex items-center justify-center"
                    aria-label="Next"
                >
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </button>

                <div data-gallery-target="counter" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white text-sm"></div>
            </div>
        </div>
    {% endif %}
{% endblock %}
