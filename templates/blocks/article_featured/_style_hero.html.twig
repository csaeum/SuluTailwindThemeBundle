{# Article featured block — hero style: single article, full-width image with overlay text #}
{% extends '@ItechWorldSuluTailwindTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% include '@ItechWorldSuluTailwindTheme/blocks/common/_titles.html.twig' with {
        title: title|default(''),
        subTitle: subTitle|default(''),
        titleAlignment: titleAlignment|default('left'),
        variant: variant|default(0)
    } only %}

    {% set articleItems = articles|default([]) %}

    {% if articleItems is iterable and articleItems|length > 0 %}
        {% set article = articleItems|first %}

        {% set articleTitle = article.title|default('') %}
        {% set articleUrl = article.routePath|default(article.url|default('#')) %}
        {% if articleUrl != '#' %}
            {% set articleUrl = sulu_content_path(articleUrl) %}
        {% endif %}
        {% set articleExcerpt = article.excerptDescription|default(article.excerpt.description|default('')) %}
        {% set articleDate = article.authored|default(null) %}
        {% set articleImage = article.excerptImages|default(article.excerpt.images|default(article.heroImage|default(null))) %}
        {% set articleCategories = article.excerptCategories|default(article.excerpt.categories|default([])) %}

        {# Resolve image #}
        {% set imgMedia = null %}
        {% if articleImage is not empty and articleImage is iterable and articleImage|length > 0 %}
            {% set imgId = articleImage.ids|default(articleImage)|first %}
            {% if imgId %}
                {% set imgMedia = sulu_resolve_media(imgId, app.request.locale) %}
            {% endif %}
        {% endif %}

        <a href="{{ articleUrl }}" class="group block relative overflow-hidden rounded-[var(--border-imageRadius)]">
            {# Image with aspect-ratio — the img is in-flow so it gives height to the <a> #}
            {% if imgMedia %}
                <img
                    src="{{ imgMedia.thumbnails['iw_theme_16_9']|default(imgMedia.url) }}"
                    alt="{{ imgMedia.title|default(articleTitle) }}"
                    class="w-full object-cover aspect-[21/9] sm:aspect-[2/1] lg:aspect-[21/9] transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                >
            {% else %}
                {# Fallback when no image: colored placeholder #}
                <div class="w-full aspect-[21/9] sm:aspect-[2/1] lg:aspect-[21/9] bg-[var(--color-primary-100)]"></div>
            {% endif %}

            {# Gradient overlay + text #}
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent flex flex-col justify-end p-6 sm:p-8 lg:p-12">
                {% if articleCategories is iterable and articleCategories|length > 0 %}
                    <div class="mb-3">
                        {% for category in articleCategories|slice(0, 1) %}
                            <span class="inline-block px-3 py-1 text-xs font-semibold rounded-[var(--border-radius)] bg-white/20 text-white backdrop-blur-sm">
                                {{ category.name|default(category.title|default('')) }}
                            </span>
                        {% endfor %}
                    </div>
                {% endif %}

                <h3 class="font-[var(--font-family-heading)] font-bold text-2xl sm:text-3xl lg:text-4xl text-white leading-tight mb-3">
                    {{ articleTitle }}
                </h3>

                {% if articleExcerpt is not empty %}
                    <p class="text-white/80 text-base sm:text-lg line-clamp-2 max-w-3xl mb-3">
                        {{ articleExcerpt|striptags|trim }}
                    </p>
                {% endif %}

                {% if articleDate is not empty %}
                    <time datetime="{{ articleDate|date('c') }}" class="text-sm text-white/60">
                        {{ iw_sulu_tailwind_theme_format_date(articleDate, 'medium') }}
                    </time>
                {% endif %}
            </div>
        </a>
    {% else %}
        <p class="text-center text-[var(--color-secondary-500)] py-12">
            {{ 'iw_sulu_tailwind_theme.article.no_articles'|trans }}
        </p>
    {% endif %}
{% endblock %}
