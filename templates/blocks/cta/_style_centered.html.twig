{# CTA block — centered layout #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% set alignMap = {'left': 'text-left', 'center': 'text-center', 'right': 'text-right'} %}
    {% set titleAlignClass = alignMap[titleAlignment|default('center')]|default('text-center') %}

    <div class="max-w-3xl mx-auto text-center">
        {% if title is defined and title is not empty %}
            <h2 class="block-title text-2xl md:text-3xl lg:text-4xl font-[var(--font-h2-weight)] {{ titleAlignClass }}">{{ title }}</h2>
        {% endif %}
        {% if subTitle is defined and subTitle is not empty %}
            <h3 class="block-subtitle text-lg md:text-xl mt-3 opacity-75 {{ titleAlignClass }}">{{ subTitle }}</h3>
        {% endif %}
        {% if text is defined and text is not empty %}
            <div class="block-text prose max-w-none mx-auto mt-6">
                {{ text|raw }}
            </div>
        {% endif %}

        <div class="flex flex-wrap items-center justify-center gap-4 mt-8">
            {% if primaryButtonLabel|default('') is not empty and primaryButtonUrl|default('') is not empty %}
                <a href="{{ primaryButtonUrl }}" class="btn-primary inline-block px-8 py-3 text-center no-underline">
                    {{ primaryButtonLabel }}
                </a>
            {% endif %}
            {% if secondaryButtonLabel|default('') is not empty and secondaryButtonUrl|default('') is not empty %}
                <a href="{{ secondaryButtonUrl }}" class="btn-secondary inline-block px-8 py-3 text-center no-underline">
                    {{ secondaryButtonLabel }}
                </a>
            {% endif %}
        </div>
    </div>
{% endblock %}
