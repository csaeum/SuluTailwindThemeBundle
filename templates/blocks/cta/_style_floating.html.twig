{# CTA block — floating card with gradient background #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    <div class="max-w-2xl mx-auto">
        <div class="relative rounded-2xl overflow-hidden shadow-2xl">
            {# Gradient background #}
            <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-secondary,var(--color-primary))]"></div>

            <div class="relative z-10 p-8 md:p-12 text-center text-white">
                {% if title is defined and title is not empty %}
                    <h2 class="block-title text-2xl md:text-3xl font-[var(--font-h2-weight)] text-white">{{ title }}</h2>
                {% endif %}
                {% if subTitle is defined and subTitle is not empty %}
                    <h3 class="block-subtitle text-lg mt-2 text-white/80">{{ subTitle }}</h3>
                {% endif %}
                {% if text is defined and text is not empty %}
                    <div class="block-text prose prose-invert max-w-none mx-auto mt-4">
                        {{ text|raw }}
                    </div>
                {% endif %}

                <div class="flex flex-wrap items-center justify-center gap-4 mt-8">
                    {% if primaryButtonLabel|default('') is not empty and primaryButtonUrl|default('') is not empty %}
                        <a href="{{ primaryButtonUrl }}" class="inline-block px-8 py-3 bg-white text-[var(--color-primary)] font-semibold rounded-[var(--border-radius,8px)] hover:bg-white/90 transition-colors no-underline">
                            {{ primaryButtonLabel }}
                        </a>
                    {% endif %}
                    {% if secondaryButtonLabel|default('') is not empty and secondaryButtonUrl|default('') is not empty %}
                        <a href="{{ secondaryButtonUrl }}" class="inline-block px-8 py-3 border-2 border-white text-white font-semibold rounded-[var(--border-radius,8px)] hover:bg-white/10 transition-colors no-underline">
                            {{ secondaryButtonLabel }}
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
