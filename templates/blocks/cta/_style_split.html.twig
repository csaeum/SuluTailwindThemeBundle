{# CTA block — split layout with image and text #}
{% extends '@ItechWorldSuluTailwindTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% set alignMap = {'left': 'text-left', 'center': 'text-center', 'right': 'text-right'} %}
    {% set titleAlignClass = alignMap[titleAlignment|default('left')]|default('text-left') %}
    {% set isContentRight = contentRight|default(false) %}

    {# HTML order determines mobile order:
       contentRight=false → text first, image below (mobile) / image right (desktop)
       contentRight=true  → image first, image above (mobile) / image left (desktop) #}
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-2 md:gap-5 items-center">
        {% if isContentRight %}
        {# Image LEFT (desktop) / Image TOP (mobile) #}
        <div{% if resolvedParagraphRadius %} class="{{ resolvedParagraphRadius }} overflow-hidden"{% endif %}>
            {% if image is defined and image.id is defined %}
                {% set resolvedImage = sulu_resolve_media(image.id, app.request.locale) %}
                <img
                    src="{{ resolvedImage.thumbnails['iw_theme_4_3']|default(resolvedImage.url) }}"
                    alt="{{ resolvedImage.title|default('') }}"
                    loading="lazy"
                    class="w-full object-cover"
                    style="aspect-ratio: 4/3;"
                >
            {% endif %}
        </div>

        <div>
        {% else %}
        {# Text LEFT (desktop) / Text TOP (mobile) #}
        <div>
        {% endif %}
            {% if title is defined and title is not empty %}
                <h2 class="block-title text-2xl md:text-3xl lg:text-4xl font-[var(--font-h2-weight)] {{ titleAlignClass }}">{{ title }}</h2>
            {% endif %}
            {% if subTitle is defined and subTitle is not empty %}
                <h3 class="block-subtitle text-lg md:text-xl mt-2 opacity-75 {{ titleAlignClass }}">{{ subTitle }}</h3>
            {% endif %}
            {% if text is defined and text is not empty %}
                <div class="block-text prose max-w-none mt-6 {{ resolvedParagraphRadius|default('') }}">
                    {{ text|raw }}
                </div>
            {% endif %}

            {% include '@ItechWorldSuluTailwindTheme/blocks/common/_cta_buttons.html.twig' with {
                primaryButtonLink: primaryButtonLink|default(''),
                primaryButtonView: view.blocks[_key].primaryButtonLink|default({}),
                primaryButtonStyle: primaryButtonStyle|default('primary'),
                secondaryButtonLink: secondaryButtonLink|default(''),
                secondaryButtonView: view.blocks[_key].secondaryButtonLink|default({}),
                secondaryButtonStyle: secondaryButtonStyle|default('secondary')
            } only %}
        </div>

        {% if not isContentRight %}
        {# Image RIGHT (desktop) / Image BOTTOM (mobile) #}
        <div{% if resolvedParagraphRadius %} class="{{ resolvedParagraphRadius }} overflow-hidden"{% endif %}>
            {% if image is defined and image.id is defined %}
                {% set resolvedImage = sulu_resolve_media(image.id, app.request.locale) %}
                <img
                    src="{{ resolvedImage.thumbnails['iw_theme_4_3']|default(resolvedImage.url) }}"
                    alt="{{ resolvedImage.title|default('') }}"
                    loading="lazy"
                    class="w-full object-cover"
                    style="aspect-ratio: 4/3;"
                >
            {% endif %}
        </div>
        {% endif %}
    </div>
{% endblock %}
