{# CTA block — full-width banner with background image or primary color #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{# Edge-to-edge display #}
{% block block_container_class %}{% endblock %}

{% block block_content %}
    {% set bgImageUrl = '' %}
    {% if image is defined and image.id is defined %}
        {% set resolvedImage = sulu_resolve_media(image.id, app.request.locale) %}
        {% set bgImageUrl = resolvedImage.thumbnails['iw_theme_16_9']|default(resolvedImage.url) %}
    {% endif %}

    <div class="relative py-16 md:py-20 lg:py-24 {{ bgImageUrl is empty ? 'bg-[var(--color-primary)]' : '' }}">
        {% if bgImageUrl is not empty %}
            <img src="{{ bgImageUrl }}" alt="" loading="lazy" class="absolute inset-0 w-full h-full object-cover">
            <div class="absolute inset-0 bg-black/50"></div>
        {% endif %}

        <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
            {% if title is defined and title is not empty %}
                <h2 class="block-title text-3xl md:text-4xl lg:text-5xl font-[var(--font-h2-weight)] text-white">{{ title }}</h2>
            {% endif %}
            {% if subTitle is defined and subTitle is not empty %}
                <h3 class="block-subtitle text-lg md:text-xl mt-3 text-white/80">{{ subTitle }}</h3>
            {% endif %}
            {% if text is defined and text is not empty %}
                <div class="block-text prose prose-invert max-w-2xl mx-auto mt-6">
                    {{ text|raw }}
                </div>
            {% endif %}

            {% include '@ItechWorldSuluTheme/blocks/common/_cta_buttons.html.twig' with {
                primaryButtonLabel: primaryButtonLabel|default(''),
                primaryButtonUrl: primaryButtonUrl|default(''),
                secondaryButtonLabel: secondaryButtonLabel|default(''),
                secondaryButtonUrl: secondaryButtonUrl|default('')
            } only %}
        </div>
    </div>
{% endblock %}
