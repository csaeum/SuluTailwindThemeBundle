{# Key figures block — inline row of figures #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% if figures is defined and figures is iterable %}
        <div
            data-controller="key-figures"
            class="flex flex-wrap justify-center gap-8 md:gap-16 text-center"
        >
            {% for figure in figures %}
                <div class="flex flex-col items-center min-w-[120px]">
                    {% if figure.number is defined and figure.number is not empty %}
                        <span
                            data-key-figures-target="counter"
                            data-key-figures-end-value="{{ figure.number }}"
                            class="text-4xl md:text-5xl lg:text-6xl font-bold text-[var(--color-primary)]"
                        >
                            0
                        </span>
                    {% endif %}
                    {% if figure.title is defined and figure.title is not empty %}
                        <span class="block-title mt-2 text-base md:text-lg font-semibold">{{ figure.title }}</span>
                    {% endif %}
                    {% if figure.subTitle is defined and figure.subTitle is not empty %}
                        <span class="block-subtitle text-sm opacity-75">{{ figure.subTitle }}</span>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
