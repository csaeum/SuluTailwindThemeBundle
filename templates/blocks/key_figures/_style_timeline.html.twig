{# Key figures block — vertical timeline layout #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% if figures is defined and figures is iterable %}
        <div class="relative" data-controller="key-figures">
            {# Vertical line — centered on desktop, left on mobile #}
            <div class="absolute left-4 md:left-1/2 md:-translate-x-px top-0 bottom-0 w-0.5 bg-[var(--color-primary)]/20"></div>

            <div class="space-y-8 md:space-y-12">
                {% for item in figures %}
                    {% if item.type|default('figure') == 'figure' %}
                        <div class="relative flex items-start md:items-center {{ loop.index is even ? 'md:flex-row-reverse' : '' }}">
                            {# Timeline dot #}
                            <div class="absolute left-4 md:left-1/2 -translate-x-1/2 w-4 h-4 rounded-full bg-[var(--color-primary)] border-4 border-[var(--color-background,#fff)] z-10"></div>

                            {# Content card #}
                            <div class="ml-12 md:ml-0 md:w-[calc(50%-2rem)] {{ loop.index is even ? 'md:mr-auto md:pr-8' : 'md:ml-auto md:pl-8' }}">
                                <div class="p-6 rounded-[var(--border-radius,8px)] border border-[var(--color-border,#e5e7eb)] bg-white/50">
                                    {% if item.number is defined and item.number is not empty %}
                                        <span class="text-2xl md:text-3xl font-bold text-[var(--color-primary)]" data-key-figures-target="counter" data-key-figures-end-value="{{ item.number }}">
                                            {{ item.number }}
                                        </span>
                                    {% endif %}
                                    {% if item.title is defined and item.title is not empty %}
                                        <h4 class="text-lg font-semibold mt-2">{{ item.title }}</h4>
                                    {% endif %}
                                    {% if item.subTitle is defined and item.subTitle is not empty %}
                                        <p class="text-sm opacity-75 mt-1">{{ item.subTitle }}</p>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
    {% endif %}
{% endblock %}
