{# Block wrapper — applies variant, margins, padding, radius, container and lightbox support. #}
{% set variantIndex = variant|default(0) %}
{% set allVariants = iw_sulu_theme.blockVariants|default([]) %}
{% if variantIndex >= allVariants|length %}
    {% set variantIndex = 0 %}
{% endif %}
{% set variantClass = 'block-variant-' ~ variantIndex %}
{% set mtClass = marginTop|default('mt-0') %}
{% set mbClass = marginBottom|default('mb-0') %}
{% set ptClass = paddingTop|default('pt-3') %}
{% set pbClass = paddingBottom|default('pb-3') %}
{% if paddingLateral is defined and paddingLateral %}
    {% set plClass = paddingLateral|replace({'px-': 'pl-'}) %}
    {% set prClass = paddingLateral|replace({'px-': 'pr-'}) %}
{% else %}
    {% set plClass = paddingLeft|default('pl-3') %}
    {% set prClass = paddingRight|default('pr-3') %}
{% endif %}
{% set lateralMode = lateralMargins|default('interior') %}
{# Backward compat: old checkbox true/false → map to exterior/none #}
{% if lateralMode is same as(true) or lateralMode == '1' %}
    {% set lateralMode = 'exterior' %}
{% elseif lateralMode is same as(false) or lateralMode == '0' or lateralMode == '' %}
    {% set lateralMode = 'interior' %}
{% endif %}
{% set sectionContainerClass = (lateralMode == 'exterior') ? 'container mx-auto' : '' %}
{% set radiusClass = (lateralMode == 'exterior' and blockRadius|default('') is not empty) ? 'sm:' ~ blockRadius : '' %}
{% set bgAttr = (showBackground|default(true)) ? 'data-has-bg="true"' : '' %}

{# Detect effective block padding per axis (same logic as text_images) #}
{% set hasTopPad = paddingTop is defined and paddingTop is not empty and paddingTop != 'pt-0' %}
{% set hasBotPad = paddingBottom is defined and paddingBottom is not empty and paddingBottom != 'pb-0' %}
{% set hasLatPad = false %}
{% if paddingLateral is defined and paddingLateral is not empty and paddingLateral != 'px-0' %}
    {% set hasLatPad = true %}
{% elseif (paddingLeft is defined and paddingLeft is not empty and paddingLeft != 'pl-0') or (paddingRight is defined and paddingRight is not empty and paddingRight != 'pr-0') %}
    {% set hasLatPad = true %}
{% endif %}

{# Compute conditional paragraph radius: only when lateral space exists (edges don't touch viewport) #}
{% set rawParagraphRadius = paragraphImageRadius|default('') %}
{% set resolvedParagraphRadius = '' %}
{% if rawParagraphRadius %}
    {% if hasLatPad %}
        {% set resolvedParagraphRadius = rawParagraphRadius %}
    {% elseif lateralMode == 'interior' %}
        {% set resolvedParagraphRadius = 'sm:' ~ rawParagraphRadius %}
    {% endif %}
{% endif %}

<section
    class="block {{ variantClass }} {{ sectionContainerClass }} {{ mtClass }} {{ mbClass }} {{ ptClass }} {{ pbClass }} {{ plClass }} {{ prClass }} {{ radiusClass }} {% if radiusClass %}sm:overflow-hidden{% endif %}"
    {{ bgAttr|raw }}
    data-controller="lightbox"
>
    {% if lateralMode == 'interior' %}
        <div class="container mx-auto">
            {{ block('block_content') }}
        </div>
    {% else %}
        {{ block('block_content') }}
    {% endif %}
</section>
