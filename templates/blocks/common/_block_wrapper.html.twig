{# Block wrapper — applies variant, margins, container and lightbox support #}
{% set variantClass = 'block-variant-' ~ (variant|default('clair')) %}
{% set mtClass = marginTop|default('mt-0') %}
{% set mbClass = marginBottom|default('mb-0') %}
{% set containerClass = (lateralMargins|default(true)) ? 'container mx-auto px-4 sm:px-6 lg:px-8' : '' %}
{% set bgAttr = (showBackground|default(true)) ? 'data-has-bg="true"' : '' %}

<section
    class="block {{ variantClass }} {{ mtClass }} {{ mbClass }}"
    {{ bgAttr|raw }}
    data-controller="lightbox"
>
    <div class="{{ containerClass }}">
        {{ block('block_content') }}
    </div>
</section>
