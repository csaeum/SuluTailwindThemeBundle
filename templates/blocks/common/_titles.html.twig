{# Block titles — renders h2 title, h3 subtitle, and optional separator #}
{% if title is defined and title is not empty %}
    <h2 class="block-title text-2xl md:text-3xl lg:text-4xl font-[var(--font-h2-weight)]">{{ title }}</h2>
{% endif %}
{% if subTitle is defined and subTitle is not empty %}
    <h3 class="block-subtitle text-lg md:text-xl mt-2">{{ subTitle }}</h3>
{% endif %}
{% if (title is defined and title is not empty) or (subTitle is defined and subTitle is not empty) %}
    <hr class="my-6">
{% endif %}
