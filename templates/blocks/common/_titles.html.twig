{# Block titles — renders h2 title, h3 subtitle, and optional separator #}
{% set alignMap = {'left': 'text-left', 'center': 'text-center', 'right': 'text-right'} %}
{% set alignClass = alignMap[titleAlignment|default('left')]|default('text-left') %}

{# Resolve separator config from the variant index #}
{% set variantIndex = variant|default(0) %}
{% set allVariants = iw_sulu_theme.blockVariants|default([]) %}
{% if variantIndex >= allVariants|length %}
    {% set variantIndex = 0 %}
{% endif %}
{% set variantConfig = allVariants[variantIndex]|default({}) %}
{% set separatorMode = variantConfig.separatorMode|default('style') %}

{% if (title is defined and title is not empty) or (subTitle is defined and subTitle is not empty) %}
<div class="{{ alignClass }} px-4">
    {% if title is defined and title is not empty %}
        <h2 class="block-title text-2xl md:text-3xl lg:text-4xl font-[var(--font-h2-weight)] {{ alignClass }}">{{ title }}</h2>
    {% endif %}
    {% if subTitle is defined and subTitle is not empty %}
        <h3 class="block-subtitle text-lg md:text-xl mt-2 {{ alignClass }}">{{ subTitle }}</h3>
    {% endif %}

    {# Separator: style mode → CSS handles rendering via .block-variant-* hr rules #}
    {% if separatorMode == 'style' or separatorMode is empty %}
        <hr class="my-6">
    {% elseif separatorMode == 'image' and variantConfig.separatorImage is defined and variantConfig.separatorImage.id is defined %}
        {# Image mode → render custom image separator #}
        {% set separatorMedia = sulu_resolve_media(variantConfig.separatorImage.id, app.request.locale) %}
        <div class="block-separator my-6">
            <img src="{{ separatorMedia.url }}" alt="" loading="lazy" class="mx-auto max-h-8 w-auto">
        </div>
    {% elseif separatorMode != 'none' %}
        {# Fallback to default hr if image is missing #}
        <hr class="my-6">
    {% endif %}
</div>
{% endif %}
