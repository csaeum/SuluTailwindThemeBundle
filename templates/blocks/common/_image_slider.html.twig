{# Image slider with lightbox — displays a single image or a carousel when multiple images.
   Expected variables:
     - images: array of media IDs
     - imageFormat: string (image format key, e.g. 'iw_theme_16_9')
     - showName: boolean (shows caption in lightbox only)
     - aspectRatio: string (CSS aspect-ratio value, e.g. '16/9', '4/3', '3/4')
     - autoplay: boolean (optional, default false)
     - interval: number (optional, autoplay interval in ms, default 5000)
#}

{% set resolvedImages = [] %}
{% if images is defined and images is iterable %}
    {% for mediaId in images %}
        {% set resolvedImages = resolvedImages|merge([sulu_resolve_media(mediaId, app.request.locale)]) %}
    {% endfor %}
{% endif %}

{% set ratio = aspectRatio|default('4/3') %}

{% if resolvedImages|length == 1 %}
    {# Single image with lightbox #}
    {% set media = resolvedImages[0] %}
    <figure class="block-image">
        <a
            href="{{ media.url }}"
            class="glightbox"
            data-title="{{ (showName|default(false)) and media.title is defined ? media.title : '' }}"
        >
            <img
                src="{{ media.thumbnails[imageFormat|default('iw_theme_4_3')]|default(media.url) }}"
                alt="{{ media.title|default('') }}"
                loading="lazy"
                class="w-full object-cover rounded-[var(--radius-img)] cursor-pointer"
                style="aspect-ratio: {{ ratio }};"
            >
        </a>
    </figure>

{% elseif resolvedImages|length > 1 %}
    {# Multiple images — carousel slider with lightbox on each slide #}
    <div
        class="relative overflow-hidden rounded-[var(--radius-img)]"
        data-controller="slider"
        data-slider-mode-value="carousel"
        data-slider-autoplay-value="{{ autoplay|default(false) ? 'true' : 'false' }}"
        data-slider-interval-value="{{ interval|default(5000) }}"
        style="aspect-ratio: {{ ratio }};"
    >
        {# Slides #}
        {% for media in resolvedImages %}
            <div
                data-slider-target="slide"
                class="absolute inset-0 w-full h-full {{ loop.first ? '' : 'hidden' }}"
            >
                <a
                    href="{{ media.url }}"
                    class="glightbox relative block w-full h-full"
                    data-title="{{ (showName|default(false)) and media.title is defined ? media.title : '' }}"
                >
                    <img
                        src="{{ media.thumbnails[imageFormat|default('iw_theme_4_3')]|default(media.url) }}"
                        alt="{{ media.title|default('') }}"
                        loading="lazy"
                        class="absolute inset-0 w-full h-full object-cover cursor-pointer"
                    >
                </a>
            </div>
        {% endfor %}

        {# Navigation arrows #}
        <button
            type="button"
            class="absolute left-2 top-1/2 -translate-y-1/2 z-10 bg-black/40 hover:bg-black/60 text-white rounded-full w-9 h-9 flex items-center justify-center transition-colors"
            data-action="slider#prev"
            aria-label="Previous"
        >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
            </svg>
        </button>
        <button
            type="button"
            class="absolute right-2 top-1/2 -translate-y-1/2 z-10 bg-black/40 hover:bg-black/60 text-white rounded-full w-9 h-9 flex items-center justify-center transition-colors"
            data-action="slider#next"
            aria-label="Next"
        >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
        </button>

        {# Dot indicators — overlaid on the image, a few pixels from the bottom edge #}
        <div data-slider-target="dots" class="absolute bottom-4 left-1/2 -translate-x-1/2 flex items-center gap-2 px-3 py-1.5 rounded-full bg-black/30 backdrop-blur-sm z-20">
            {% for media in resolvedImages %}
                <button
                    type="button"
                    class="w-2.5 h-2.5 rounded-full transition-colors {{ loop.first ? 'bg-white' : 'bg-white/50' }}"
                    data-action="slider#goTo"
                    data-slider-index-param="{{ loop.index0 }}"
                    aria-label="Slide {{ loop.index }}"
                ></button>
            {% endfor %}
        </div>
    </div>
{% endif %}
