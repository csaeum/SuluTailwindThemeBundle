{# Button component — primary or secondary style #}
{# Expected variables: url, label, buttonStyle (primary/secondary), target (optional) #}
{% set btnClass = (buttonStyle|default('primary') == 'secondary') ? 'btn-secondary' : 'btn-primary' %}
{% set targetAttr = (target|default('_self') == '_blank') ? 'target="_blank" rel="noopener noreferrer"' : '' %}

{% if url is defined and url is not empty %}
    <a href="{{ url }}" class="{{ btnClass }} inline-block px-6 py-3 text-center no-underline" {{ targetAttr|raw }}>
        {{ label|default(url) }}
    </a>
{% endif %}
