{# Linked pages block — horizontal scrolling #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% include '@ItechWorldSuluTheme/blocks/common/_titles.html.twig' with {
        title: title|default(''),
        subTitle: subTitle|default(''),
        titleAlignment: titleAlignment|default('left'),
        variant: variant|default('clair')
    } only %}

    {% if links is defined and links is iterable %}
        <div class="flex overflow-x-auto scroll-smooth snap-x snap-mandatory gap-4 pb-4 scrollbar-hide">
            {% for link in links %}
                {% if link.type == 'internal' and link.pages is defined %}
                    {% for page in link.pages %}
                        <a
                            href="{{ sulu_content_path(page.url|default('/')) }}"
                            class="flex-none w-[250px] md:w-[300px] snap-start p-6 rounded-[var(--border-radius,8px)] border border-[var(--color-border,#e5e7eb)] hover:shadow-lg transition-shadow no-underline"
                        >
                            <h4 class="text-base font-semibold truncate">{{ page.title|default('') }}</h4>
                            {% if page.excerpt is defined and page.excerpt.description is defined %}
                                <p class="mt-2 text-sm opacity-75 line-clamp-2">{{ page.excerpt.description }}</p>
                            {% endif %}
                        </a>
                    {% endfor %}
                {% elseif link.type == 'external' %}
                    {% set linkTarget = link.target|default('_self') %}
                    {% set linkUrl = link.url|default('#') %}
                    {% if link.anchor is defined and link.anchor is not empty %}
                        {% set linkUrl = linkUrl ~ '#' ~ link.anchor %}
                    {% endif %}
                    <a
                        href="{{ linkUrl }}"
                        target="{{ linkTarget }}"
                        {{ linkTarget == '_blank' ? 'rel="noopener noreferrer"' : '' }}
                        class="flex-none w-[250px] md:w-[300px] snap-start p-6 rounded-[var(--border-radius,8px)] border border-[var(--color-border,#e5e7eb)] hover:shadow-lg transition-shadow no-underline"
                    >
                        <h4 class="text-base font-semibold truncate">{{ link.label|default(link.url|default('')) }}</h4>
                    </a>
                {% endif %}
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
