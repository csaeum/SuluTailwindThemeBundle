{# Linked pages block — featured: first item large, rest small #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% include '@ItechWorldSuluTheme/blocks/common/_titles.html.twig' with {
        title: title|default(''),
        subTitle: subTitle|default(''),
        titleAlignment: titleAlignment|default('left'),
        variant: variant|default('clair')
    } only %}

    {% if links is defined and links is iterable %}
        {# Flatten all links into a single list of items #}
        {% set allItems = [] %}
        {% for link in links %}
            {% if link.type == 'internal' and link.pages is defined %}
                {% for page in link.pages %}
                    {% set allItems = allItems|merge([{type: 'internal', page: page}]) %}
                {% endfor %}
            {% elseif link.type == 'external' %}
                {% set allItems = allItems|merge([{type: 'external', link: link}]) %}
            {% endif %}
        {% endfor %}

        {% if allItems|length > 0 %}
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                {# Featured item (first) #}
                {% set firstItem = allItems|first %}
                <div class="lg:row-span-2">
                    {% if firstItem.type == 'internal' %}
                        <a href="{{ sulu_content_path(firstItem.page.url|default('/')) }}" class="block h-full p-8 rounded-[var(--border-radius,8px)] border-2 border-[var(--color-primary)] hover:shadow-xl transition-shadow no-underline group">
                            <h4 class="text-xl md:text-2xl font-bold group-hover:text-[var(--color-link)]">{{ firstItem.page.title|default('') }}</h4>
                            {% if firstItem.page.excerpt is defined and firstItem.page.excerpt.description is defined %}
                                <p class="mt-4 opacity-75">{{ firstItem.page.excerpt.description }}</p>
                            {% endif %}
                        </a>
                    {% else %}
                        {% set linkUrl = firstItem.link.url|default('#') %}
                        <a href="{{ linkUrl }}" target="{{ firstItem.link.target|default('_self') }}" class="block h-full p-8 rounded-[var(--border-radius,8px)] border-2 border-[var(--color-primary)] hover:shadow-xl transition-shadow no-underline group">
                            <h4 class="text-xl md:text-2xl font-bold group-hover:text-[var(--color-link)]">{{ firstItem.link.label|default(linkUrl) }}</h4>
                        </a>
                    {% endif %}
                </div>

                {# Remaining items #}
                {% for item in allItems|slice(1) %}
                    <div>
                        {% if item.type == 'internal' %}
                            <a href="{{ sulu_content_path(item.page.url|default('/')) }}" class="block p-5 rounded-[var(--border-radius,8px)] border border-[var(--color-border,#e5e7eb)] hover:shadow-lg transition-shadow no-underline group">
                                <h4 class="text-base font-semibold group-hover:text-[var(--color-link)]">{{ item.page.title|default('') }}</h4>
                            </a>
                        {% else %}
                            {% set linkUrl = item.link.url|default('#') %}
                            {% if item.link.anchor is defined and item.link.anchor is not empty %}
                                {% set linkUrl = linkUrl ~ '#' ~ item.link.anchor %}
                            {% endif %}
                            <a
                                href="{{ linkUrl }}"
                                target="{{ item.link.target|default('_self') }}"
                                {{ item.link.target|default('_self') == '_blank' ? 'rel="noopener noreferrer"' : '' }}
                                class="block p-5 rounded-[var(--border-radius,8px)] border border-[var(--color-border,#e5e7eb)] hover:shadow-lg transition-shadow no-underline group"
                            >
                                <h4 class="text-base font-semibold group-hover:text-[var(--color-link)]">{{ item.link.label|default(linkUrl) }}</h4>
                            </a>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    {% endif %}
{% endblock %}
