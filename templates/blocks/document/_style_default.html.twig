{# Document block — download list #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% include '@ItechWorldSuluTheme/blocks/common/_titles.html.twig' with {
        title: title|default(''),
        subTitle: subTitle|default(''),
        titleAlignment: titleAlignment|default('left'),
        variant: variant|default('clair')
    } only %}

    {% if documents is defined and documents is iterable %}
        <div class="space-y-3">
            {% for mediaId in documents %}
                {% set media = sulu_resolve_media(mediaId, app.request.locale) %}
                <a
                    href="{{ media.url }}"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-4 p-4 rounded-[var(--border-radius,8px)] border border-[var(--color-border,#e5e7eb)] hover:shadow-md transition-shadow no-underline group"
                    download
                >
                    {# File type icon #}
                    <div class="flex-none w-10 h-10 flex items-center justify-center rounded-lg bg-[var(--color-primary)]/10">
                        <svg class="w-5 h-5 text-[var(--color-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                    </div>

                    {# File info #}
                    <div class="flex-1 min-w-0">
                        <span class="block font-medium truncate group-hover:text-[var(--color-link)]">
                            {{ media.title|default(media.name|default('Document')) }}
                        </span>
                        {% if media.mimeType is defined %}
                            <span class="text-xs opacity-50 uppercase">
                                {{ media.mimeType|split('/')|last }}
                            </span>
                        {% endif %}
                    </div>

                    {# Download arrow #}
                    <svg class="flex-none w-5 h-5 opacity-50 group-hover:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                    </svg>
                </a>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
