{# Document block — accordion layout grouped by file type #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% include '@ItechWorldSuluTheme/blocks/common/_titles.html.twig' with {
        title: title|default(''),
        subTitle: subTitle|default(''),
        titleAlignment: titleAlignment|default('left'),
        variant: variant|default('clair')
    } only %}

    {% if documents is defined and documents is iterable %}
        {# Group documents by MIME type category #}
        {% set groups = {} %}
        {% for mediaId in documents %}
            {% set media = sulu_resolve_media(mediaId, app.request.locale) %}
            {% set mimeCategory = media.mimeType|default('other')|split('/')|first|default('other') %}
            {% set existing = groups[mimeCategory]|default([]) %}
            {% set groups = groups|merge({(mimeCategory): existing|merge([media])}) %}
        {% endfor %}

        <div data-controller="accordion" data-accordion-exclusive-value="false">
            {% for category, docs in groups %}
                <div class="border-b border-[var(--color-border,#e5e7eb)]">
                    <button
                        type="button"
                        data-accordion-target="trigger"
                        data-action="accordion#toggle"
                        class="w-full flex items-center justify-between py-4 text-left font-semibold hover:text-[var(--color-primary)] transition-colors"
                        aria-expanded="false"
                    >
                        <span class="capitalize">{{ category }} ({{ docs|length }})</span>
                        <svg data-accordion-icon class="w-5 h-5 flex-none ml-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </button>
                    <div data-accordion-target="panel" style="max-height: 0; overflow: hidden;">
                        <div class="space-y-2 pb-4">
                            {% for media in docs %}
                                <a
                                    href="{{ media.url }}"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="flex items-center gap-3 p-3 rounded-[var(--border-radius,8px)] hover:bg-[var(--color-primary)]/5 transition-colors no-underline group"
                                    download
                                >
                                    <svg class="w-5 h-5 text-[var(--color-primary)] flex-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                                    </svg>
                                    <span class="flex-1 truncate font-medium group-hover:text-[var(--color-link)]">
                                        {{ media.title|default(media.name|default('Document')) }}
                                    </span>
                                    <span class="text-xs opacity-50 uppercase">{{ media.mimeType|default('')|split('/')|last }}</span>
                                </a>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
