{# Document block — grid of document cards #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% include '@ItechWorldSuluTheme/blocks/common/_titles.html.twig' with {
        title: title|default(''),
        subTitle: subTitle|default(''),
        titleAlignment: titleAlignment|default('left'),
        variant: variant|default('clair')
    } only %}

    {% if documents is defined and documents is iterable %}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {% for mediaId in documents %}
                {% set media = sulu_resolve_media(mediaId, app.request.locale) %}
                <a
                    href="{{ media.url }}"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex flex-col items-center gap-3 p-6 rounded-[var(--border-radius,8px)] border border-[var(--color-border,#e5e7eb)] hover:shadow-lg transition-shadow no-underline group text-center"
                    download
                >
                    {# File type icon #}
                    <div class="w-14 h-14 flex items-center justify-center rounded-xl bg-[var(--color-primary)]/10">
                        <svg class="w-7 h-7 text-[var(--color-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                    </div>
                    <div>
                        <span class="block font-medium truncate group-hover:text-[var(--color-link)]">
                            {{ media.title|default(media.name|default('Document')) }}
                        </span>
                        {% if media.mimeType is defined %}
                            <span class="text-xs opacity-50 uppercase mt-1 block">
                                {{ media.mimeType|split('/')|last }}
                            </span>
                        {% endif %}
                    </div>
                </a>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
