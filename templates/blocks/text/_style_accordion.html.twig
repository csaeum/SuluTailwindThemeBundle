{# Text block — accordion / FAQ layout.
   Each <h3> in the text content becomes a trigger, the content
   between h3 tags becomes the collapsible panel. #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% include '@ItechWorldSuluTheme/blocks/common/_titles.html.twig' with {
        title: title|default(''),
        subTitle: subTitle|default('')
    } only %}

    {% if text is defined and text is not empty %}
        {% set sections = text|split('<h3') %}
        <div class="max-w-4xl mx-auto" data-controller="accordion" data-accordion-exclusive-value="true">
            {% for section in sections %}
                {% if section|trim is not empty %}
                    {% if loop.index0 == 0 and '<h3' not in '<h3' ~ section %}
                        {# Content before the first h3 — render as intro text #}
                        <div class="block-text prose max-w-none mb-6">
                            {{ section|raw }}
                        </div>
                    {% else %}
                        {# Extract title from h3 tag #}
                        {% set fullTag = '<h3' ~ section %}
                        {% set headingEnd = fullTag|split('</h3>') %}
                        {% set headingContent = headingEnd[0]|split('>')|last %}
                        {% set panelContent = headingEnd[1]|default('') %}

                        <div class="border-b border-[var(--color-border,#e5e7eb)]">
                            <button
                                type="button"
                                data-accordion-target="trigger"
                                data-action="accordion#toggle"
                                class="w-full flex items-center justify-between py-4 text-left text-lg font-semibold hover:text-[var(--color-primary)] transition-colors"
                                aria-expanded="false"
                            >
                                <span>{{ headingContent|striptags }}</span>
                                <svg data-accordion-icon class="w-5 h-5 flex-none ml-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                                </svg>
                            </button>
                            <div data-accordion-target="panel" style="max-height: 0; overflow: hidden;">
                                <div class="block-text prose max-w-none pb-4">
                                    {{ panelContent|raw }}
                                </div>
                            </div>
                        </div>
                    {% endif %}
                {% endif %}
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
