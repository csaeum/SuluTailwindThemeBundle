{# Text block — two-column grid layout #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% include '@ItechWorldSuluTheme/blocks/common/_titles.html.twig' with {
        title: title|default(''),
        subTitle: subTitle|default(''),
        titleAlignment: titleAlignment|default('left'),
        variant: variant|default('clair')
    } only %}

    {% if text is defined and text is not empty %}
        <div class="block-text prose max-w-none columns-1 md:columns-2 gap-8 {% if paragraphImageRadius is defined and paragraphImageRadius %}{{ paragraphImageRadius }}{% endif %}">
            {{ text|raw }}
        </div>
    {% endif %}
{% endblock %}
