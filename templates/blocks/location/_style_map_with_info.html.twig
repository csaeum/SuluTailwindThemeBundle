{# Location block — map with address info sidebar #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% include '@ItechWorldSuluTheme/blocks/common/_titles.html.twig' with {
        title: title|default(''),
        subTitle: subTitle|default(''),
        titleAlignment: titleAlignment|default('left'),
        variant: variant|default('clair')
    } only %}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {# Map — 2 columns #}
        <div class="lg:col-span-2">
            {% if latitude is defined and latitude is not empty and longitude is defined and longitude is not empty %}
                <div class="rounded-[var(--radius-img)] overflow-hidden h-full min-h-[300px]">
                    <iframe
                        src="https://www.openstreetmap.org/export/embed.html?bbox={{ longitude - 0.01 }}%2C{{ latitude - 0.01 }}%2C{{ longitude + 0.01 }}%2C{{ latitude + 0.01 }}&amp;layer=mapnik&amp;marker={{ latitude }}%2C{{ longitude }}"
                        class="w-full h-full min-h-[300px] border-0"
                        loading="lazy"
                        title="{{ title|default('Map') }}"
                        allowfullscreen
                    ></iframe>
                </div>
            {% endif %}
        </div>

        {# Info sidebar — 1 column #}
        <div class="lg:col-span-1 space-y-6">
            {% if address is defined and address is not empty %}
                <div>
                    <h4 class="font-semibold mb-2 flex items-center gap-2">
                        <svg class="w-5 h-5 text-[var(--color-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        {{ 'iw_theme.address'|trans({}, 'messages')|default('Address') }}
                    </h4>
                    <p class="whitespace-pre-line opacity-75">{{ address }}</p>
                </div>
            {% endif %}

            {% if text is defined and text is not empty %}
                <div>
                    <div class="block-text prose max-w-none">
                        {{ text|raw }}
                    </div>
                </div>
            {% endif %}

            {# Link to open in external maps app #}
            {% if latitude is defined and latitude is not empty and longitude is defined and longitude is not empty %}
                <a
                    href="https://www.openstreetmap.org/?mlat={{ latitude }}&mlon={{ longitude }}#map=16/{{ latitude }}/{{ longitude }}"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn-primary inline-block px-6 py-3 text-center no-underline"
                >
                    {{ 'iw_theme.open_map'|trans({}, 'messages')|default('Open in maps') }} &#8599;
                </a>
            {% endif %}
        </div>
    </div>
{% endblock %}
