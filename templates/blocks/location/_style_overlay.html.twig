{# Location block — map with collapsible floating info card #}
{% extends '@ItechWorldSuluTailwindTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% if location is defined and location.lat is defined and location.long is defined %}
        {% set zoom = location.zoom|default(15) %}
        {% set offset = 0.02 * (2 ** (15 - zoom)) %}

        {# Build formatted address from structured location fields #}
        {% set addressParts = [] %}
        {% if location.street is defined and location.street is not empty %}
            {% set streetLine = location.street %}
            {% if location.number is defined and location.number is not empty %}
                {% set streetLine = location.number ~ ' ' ~ streetLine %}
            {% endif %}
            {% set addressParts = addressParts|merge([streetLine]) %}
        {% endif %}
        {% set cityLine = [location.code|default(''), location.town|default('')]|filter(v => v is not empty)|join(' ') %}
        {% if cityLine is not empty %}
            {% set addressParts = addressParts|merge([cityLine]) %}
        {% endif %}
        {% if location.country is defined and location.country is not empty %}
            {% set addressParts = addressParts|merge([location.country]) %}
        {% endif %}
        {% set formattedAddress = addressParts|join("\n") %}

        {% set hasInfo = (title is defined and title is not empty) or formattedAddress is not empty or (text is defined and text is not empty) %}

        <div class="relative"
             style="--card-border: var(--variant-hr-color, var(--color-border, #e5e7eb));"
        >
            {# Map background #}
            <div class="{{ paragraphImageRadius|default('') }} overflow-hidden">
                <iframe
                    src="https://www.openstreetmap.org/export/embed.html?bbox={{ location.long - offset }}%2C{{ location.lat - offset }}%2C{{ location.long + offset }}%2C{{ location.lat + offset }}&amp;layer=mapnik&amp;marker={{ location.lat }}%2C{{ location.long }}"
                    class="w-full h-[400px] md:h-[500px] border-0"
                    loading="lazy"
                    title="{{ title|default('Map') }}"
                    allowfullscreen
                ></iframe>
            </div>

            {# Floating collapsible info card #}
            {% if hasInfo %}
                <div class="location-overlay-card"
                     data-controller="location-overlay"
                     data-location-overlay-target="card"
                >
                    {# Always-visible header with title + toggle #}
                    <button type="button"
                            class="location-overlay-card__header"
                            data-location-overlay-target="header"
                            data-action="location-overlay#toggle"
                            aria-expanded="false"
                    >
                        <span class="location-overlay-card__header-content">
                            {% if title is defined and title is not empty %}
                                <span class="text-base font-semibold text-black leading-tight">{{ title }}</span>
                            {% endif %}
                            {% if formattedAddress is not empty and (title is not defined or title is empty) %}
                                <span class="text-sm text-black/75 leading-tight">{{ formattedAddress|split("\n")|first }}</span>
                            {% endif %}
                        </span>
                        <svg class="location-overlay-card__chevron"
                             data-location-overlay-target="chevron"
                             fill="none" stroke="currentColor" viewBox="0 0 24 24"
                        >
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </button>

                    {# Collapsible body — hidden by default #}
                    <div class="location-overlay-card__body"
                         data-location-overlay-target="body"
                         style="display: none; max-height: 0px; opacity: 0;"
                    >
                        {% if formattedAddress is not empty %}
                            <div class="flex items-start gap-2">
                                <svg class="w-5 h-5 text-[var(--variant-link-color,var(--color-primary))] flex-none mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                <p class="text-sm whitespace-pre-line text-black/75">{{ formattedAddress }}</p>
                            </div>
                        {% endif %}

                        {% if text is defined and text is not empty %}
                            <div class="prose prose-sm max-w-none text-black">
                                {{ text|raw }}
                            </div>
                        {% endif %}

                        <a
                            href="https://www.openstreetmap.org/?mlat={{ location.lat }}&mlon={{ location.long }}#map={{ zoom }}/{{ location.lat }}/{{ location.long }}"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="btn-variant inline-block px-4 py-2 text-sm text-center no-underline flex-shrink-0"
                        >
                            {{ 'iw_sulu_tailwind_theme.open_map'|trans|default('Open in maps') }} &#8599;
                        </a>
                    </div>

                    {# Scroll indicator — visible only when body is open and has overflow #}
                    <div class="location-overlay-card__scroll-hint"
                         data-location-overlay-target="scrollHint"
                         data-action="click->location-overlay#scrollDown"
                         style="display: none; opacity: 0; pointer-events: none;"
                    >
                        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </div>
                </div>
            {% endif %}
        </div>
    {% endif %}
{% endblock %}
