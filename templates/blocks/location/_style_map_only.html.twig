{# Location block — map iframe only #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% include '@ItechWorldSuluTheme/blocks/common/_titles.html.twig' with {
        title: title|default(''),
        subTitle: subTitle|default(''),
        titleAlignment: titleAlignment|default('left'),
        variant: variant|default(0)
    } only %}

    {% if location is defined and location.lat is defined and location.long is defined %}
        {% set zoom = location.zoom|default(15) %}
        {% set offset = 0.01 * (2 ** (15 - zoom)) %}
        <div class="{{ paragraphImageRadius|default('') }} overflow-hidden">
            <iframe
                src="https://www.openstreetmap.org/export/embed.html?bbox={{ location.long - offset }}%2C{{ location.lat - offset }}%2C{{ location.long + offset }}%2C{{ location.lat + offset }}&amp;layer=mapnik&amp;marker={{ location.lat }}%2C{{ location.long }}"
                class="w-full h-[400px] md:h-[500px] border-0"
                loading="lazy"
                title="{{ title|default('Map') }}"
                allowfullscreen
            ></iframe>
        </div>
    {% endif %}
{% endblock %}
