{# Form block — form + info side by side #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% include '@ItechWorldSuluTheme/blocks/common/_titles.html.twig' with {
        title: title|default(''),
        subTitle: subTitle|default(''),
        titleAlignment: titleAlignment|default('left'),
        variant: variant|default('clair')
    } only %}

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        {# Info / decorative side #}
        <div class="flex flex-col justify-center p-8 rounded-[var(--border-radius,8px)] bg-[var(--color-primary)] text-white">
            {% if title is defined and title is not empty %}
                <h3 class="text-2xl md:text-3xl font-bold text-white">{{ title }}</h3>
            {% endif %}
            {% if subTitle is defined and subTitle is not empty %}
                <p class="mt-4 text-white/80 text-lg">{{ subTitle }}</p>
            {% endif %}
        </div>

        {# Form side #}
        <div>
            {% if formId is defined and formId is not empty %}
                <div data-form-id="{{ formId }}">
                    {# {{ sulu_form(formId) }} #}
                    <noscript>
                        <p class="text-sm opacity-75">JavaScript is required to display this form.</p>
                    </noscript>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
