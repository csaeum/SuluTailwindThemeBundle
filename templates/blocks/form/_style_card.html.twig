{# Form block — card layout #}
{% extends '@ItechWorldSuluTailwindTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    <div class="max-w-xl mx-auto rounded-[var(--border-radius,8px)] shadow-lg bg-white p-8 md:p-10">
        {% include '@ItechWorldSuluTailwindTheme/blocks/common/_titles.html.twig' with {
            title: title|default(''),
            subTitle: subTitle|default(''),
            titleAlignment: titleAlignment|default('left'),
            variant: variant|default(0)
        } only %}

        <div class="mt-6 text-left">
            {% include '@ItechWorldSuluTailwindTheme/blocks/common/_form_content.html.twig' with {
                useSuluFormBundle: useSuluFormBundle|default(false),
                form: form|default(null),
                twigTemplate: twigTemplate|default('')
            } only %}
        </div>
    </div>
{% endblock %}
