{# Separator block — horizontal line #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% set widthMap = {
        'thin': 'border-t',
        'medium': 'border-t-2',
        'thick': 'border-t-4'
    } %}
    {% set styleMap = {
        'solid': 'border-solid',
        'dashed': 'border-dashed',
        'dotted': 'border-dotted'
    } %}

    <div class="{{ widthMap[lineWidth|default('thin')]|default('border-t') }} {{ styleMap[lineStyle|default('solid')]|default('border-solid') }} border-[var(--variant-hr-color,var(--color-border,currentColor))]"></div>
{% endblock %}
