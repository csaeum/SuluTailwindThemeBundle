{# Separator block — divider with centered text or icon #}
{% extends '@ItechWorldSuluTheme/blocks/common/_block_wrapper.html.twig' %}

{% block block_content %}
    {% set widthMap = {
        'thin': 'border-t',
        'medium': 'border-t-2',
        'thick': 'border-t-4'
    } %}
    {% set borderClass = widthMap[lineWidth|default('thin')]|default('border-t') %}

    <div class="flex items-center gap-4">
        <div class="flex-1 {{ borderClass }} border-current opacity-20"></div>

        {% if text is defined and text is not empty %}
            <span class="text-sm font-medium opacity-60 px-2">{{ text }}</span>
        {% elseif icon is defined and icon.id is defined %}
            {% set iconMedia = sulu_resolve_media(icon.id, app.request.locale) %}
            <img src="{{ iconMedia.url }}" alt="" class="w-6 h-6 opacity-60" loading="lazy">
        {% else %}
            <span class="text-[var(--color-primary)] opacity-40">&#9670;</span>
        {% endif %}

        <div class="flex-1 {{ borderClass }} border-current opacity-20"></div>
    </div>
{% endblock %}
