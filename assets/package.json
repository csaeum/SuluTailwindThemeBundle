{
    "name": "@itech-world/sulu-theme-bundle",
    "description": "Frontend assets (Stimulus controllers, CSS) for SuluThemeBundle",
    "license": "MIT",
    "style": "styles/app.css",
    "dependencies": {
        "glightbox": "^3.3.0"
    },
    "symfony": {
        "controllers": {
            "lightbox": {
                "main": "controllers/lightbox_controller.js",
                "name": "lightbox",
                "fetch": "lazy",
                "enabled": true
            },
            "menu": {
                "main": "controllers/menu_controller.js",
                "name": "menu",
                "fetch": "lazy",
                "enabled": true
            },
            "slider": {
                "main": "controllers/slider_controller.js",
                "name": "slider",
                "fetch": "lazy",
                "enabled": true
            },
            "carousel3d": {
                "main": "controllers/carousel3d_controller.js",
                "name": "carousel3d",
                "fetch": "lazy",
                "enabled": true
            },
            "key_figures": {
                "main": "controllers/key_figures_controller.js",
                "name": "key-figures",
                "fetch": "lazy",
                "enabled": true
            },
            "location_overlay": {
                "main": "controllers/location_overlay_controller.js",
                "name": "location-overlay",
                "fetch": "lazy",
                "enabled": true
            }
        },
        "importmap": {
            "@hotwired/stimulus": "^3.0.0"
        }
    },
    "peerDependencies": {
        "@hotwired/stimulus": "^3.0.0"
    }
}
